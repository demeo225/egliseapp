                {{ form_row(form.montant, {'label':'Montant '}) }}
            </div>

        </div>
        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.datedepense, {'label':'Date '}) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.detail, {'label':'Details '}) }}
            </div> 
        </div>
        <div class="row"> 
            <div  class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div></p>

            <div  class="col-md-2.5"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

            <div  class="col-md-2"><a href="{{ path('app_depensefamille_index') }}" class="btn btn-success">Afficher la liste</a> </div>
