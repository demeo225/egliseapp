 <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion de recommandation</h3>
        </div>
        
        <div class="card card-body">
   <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
            {{ form_start(form) }}
            <div class="my-custom-class-for-errors">
                {{ form_errors(form) }}
            </div>
            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.dateop, {'label':' Date '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.fidele, {'label':'Choix du fidèle '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.objet, {'label':'Objet '}) }}
                </div>

            </div>

            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.destination, {'label':'Eglise de destination '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.pasteur, {'label':'Pasteur principal '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.reference, {'label':' Reférence '}) }}
                </div>

            </div>

            <div class="row">

                <div class="col-md-4">
                    {{ form_row(form.fidelite, {'label':'Fidelité '}) }}
                </div>

                <div class="col-md-4">
                    {{ form_row(form.soummission, {'label':'Soummission '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.stabilite, {'label':'Stabilité '}) }}
                </div>
            </div>



            <div class="row"> 
                <div class="col-md-1.5">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div></p>

                <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

                <div class="col-md-3"><a href="{{ path('recommandation_index') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 
            {{ form_end(form) }}
        </div>
    </div>