
<div class="card card-primary">

    <div class="card card-body">
        {{ form_start(form) }}
  <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.visiteur, {'label':'Visiteur '}) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.datevisite, {'label':'Date '}) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.sexe, {'label':'Genre  '}) }}
            </div>
        </div>
        <div class="row">

            <div class="col-md-4">
                {{ form_row(form.contact1, {'label':'Contact '}) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.receptionpar, {'label':'Reçu par '}) }}
            </div>

        </div>


        <div class="row"> 
            <div class="col-md-2">{{ form_row(form.save, {'label':'Enregistrer ','attr':{'value':'save'}}) }}</div>
            <div class="col-md-3"> {{ form_row(form.saveAndAdd, {'label':'Enregistrer et continuer ','attr':{'value':'save-and-add'}}) }} </div>
            <div class="col-md-3"><a href="{{ path('app_visite_index') }}" class="btn btn-success">Afficher la liste</a> </div>
        </div> 
        {{ form_end(form) }}

    </div>
</div>