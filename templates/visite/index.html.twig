{% extends 'home/index.html.twig' %}

{% block title %}Visite index{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des visiteurs</h3>
        </div>
         <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
        <div class="container-fluid">
       

                <!-- /.card-header -->
                <div class="card-body">
             

                    <a href='{{ path('app_visite_new') }}'>
                        <button class="btn btn-primary">Nouveau</button>
                    </a>

                    <hr style="visibility: hidden" />

                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Date visite</th>
                                <th>Visiteurs</th>
                                <th>Genre</th>
                                <th>Contact</th>
                                <th>Reçu par</th>
                                <th>Details</th>
                                <th>Modifier</th>
                            </tr>
                        </thead>
                        <tbody>


                            {% for visite in visites %}




                                <tr>
                                    <td>{{ visite.datevisite ? date_format(visite.datevisite) }}</td>
                                    <td>{{ visite.visiteur }}</td>
                                    <td>{{ visite.sexe }}</td>
                                    <td>{{ visite.contact1 }}</td>
                                    <td> {% if visite.receptionpar is not empty %} {{ visite.receptionpar }} {% else %} {% endif %}</td>

                                    <td>
                                        <a href="{{ path('app_visite_show', {'id': visite.id}) }}"><i class="fas fa-list" title="Details"></i></a>
                                    </td>

                                    <td>
                                        <a href="{{ path('app_visite_edit', {'id': visite.id}) }}"><i class="fas fa-edit" title="Modifier"></i></a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    {% endblock %}
