{% extends "home/index.html.twig" %}

{% block title %}Objet de recette{% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des objets de recettes</h3>
        </div>
        {% for message in app.flashes('message') %}
            <div class="primary">
                {{ message }}
            </div>
        {% endfor %}
        
        
        <!-- /.card-header -->
        <div class="car card-body">
            <a href='{{ path('app_objetrecette_new') }}'>
                <button class="btn btn-primary">Nouveau</button>
            </a>


            <hr style="visibility: hidden" />  
            <table id="example1" class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>Libellé</th>
                          <th>Modifier</th>
                        <th>Supprimer</th>


                    </tr>
                </thead>
                <tbody>
                    {% for objetrecette in objetrecettes %}
                        <tr>
                            <td>{{ objetrecette.libelle }}</td>
                     
                     



                            <td>
                                <a href="{{ path('app_objetrecette_edit', {'id': objetrecette.id}) }}">
                                    <span style="font-size: 1em; color: Dodgerblue;">
                                        <i class="fas fa-edit"></i>
                                    </span>
                                </a>
                            </td>
                            <td>
                                <form method="post" action="{{ path('app_objetrecette_delete', {'id': objetrecette.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ objetrecette.id) }}">
                                    <button class="btn">
                                        <span style="font-size: 1em; color: red;">
                                            <i class="fas fa-trash-alt"></i>
                                        </span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                   
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>




{% endblock %}


