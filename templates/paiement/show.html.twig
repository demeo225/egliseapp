{% extends 'home/index.html.twig' %}

{% block title %}Paiement{% endblock %}

{% block body %}
    <h1>Paiement</h1>

    <table class="table">
        <tbody>
        
            <tr>
                <th>Date paiement</th>
                <td>{{ paiement.datepaiement ? paiement.datepaiement|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Montant</th>
                <td>{{ paiement.montant }}</td>
            </tr>
            <tr>
                <th>Date écheance</th>
                <td>{{ paiement.dateecheance ? paiement.dateecheance|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Paiement enregistré le</th>
                <td>{{ paiement.createdAt ? paiement.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>

        </tbody>
    </table>

    <a href="{{ path('app_paiement_index') }}">Retour à la liste</a>

    <a href="{{ path('app_paiement_edit', {'id': paiement.id}) }}">Modifier</a>

   {# {{ include('paiement/_delete_form.html.twig') }} #}
{% endblock %}
