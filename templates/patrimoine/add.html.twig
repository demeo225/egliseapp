{% extends "home/index.html.twig" %}

{% block title %}Gestion du patrimoine{% endblock %}

{% block body %}


    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion de patrimoine</h3>
        </div>
         <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        <div class="card card-body">
            {{ form_start(form) }}

            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.datepatrimoine, {'label':' Date '}) }}
                </div>

                <div class="col-md-4">
                    {{ form_row(form.article, {'label':' Article '}) }}
                </div>
            </div>

            <div class="row">


                <div class="col-md-4">
                    {{ form_row(form.quantite, {'label':' Quantité '})}}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.prixunitaire, {'label':' Prix unitaire '}) }}
                </div>
               
            </div>


            <div class="row"> 
                <div  class="col-md-2">{{ form_row(form.save, {'label':'Enregistrer ','attr':{'value':'save'}}) }}</div>

                <div  class="col-md-3"> {{ form_row(form.saveAndAdd, {'label':'Enregistrer et continuer ','attr':{'value':'save-and-add'}}) }} </div>
                <div  class="col-md-2"><a href="{{ path('patrimoine') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 
            <div>
                {{ form_rest(form) }}
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>




{% endblock %}