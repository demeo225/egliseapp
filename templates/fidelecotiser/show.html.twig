{% extends "home/index.html.twig" %}

{% block title %}Fidelecotiser{% endblock %}

{% block body %}
      <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Details paiement {{ fidelecotiser.cotisation.objet }} Montant: {{ fidelecotiser.cotisation.montant }}
              effectué  par  {{ fidelecotiser.fidele.nomfidele }}</h3>
        </div>

    <table class="table">
        <tbody>
          
            <tr>
                <th>Date</th>
                <td>{{ fidelecotiser.datecotiser ? fidelecotiser.datecotiser|date('d-m-Y') : '' }}</td>
            </tr>
            <tr>
                <th>Montant payé</th>
                <td>{{ fidelecotiser.montpaye }}</td>
            </tr>
            <tr>
                <th>Restecotiser</th>
                <td>{{ fidelecotiser.restecotiser }}</td>
            </tr>
 
        </tbody>
    </table>

            <div class="btn btn-default"><a href="{{ path('fidelecotiser_index') }}" class="btn btn-success">Afficher la liste</a> </div>
      </div>
  
{% endblock %}
