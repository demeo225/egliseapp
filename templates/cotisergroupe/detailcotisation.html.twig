{% extends "home/index.html.twig" %}

{% block title %}Detail des cotisations{% endblock %}

{% block body %}

        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Details paeiment</h3>
            </div>

            <!-- /.card-header -->
            <div class="card-body">
              
                <a href='{{ path('cotisergroupe_new') }}'>
                    <button class="btn btn-primary">Paie de cotisation</button>
                </a>
                <a href='{{ path('cotisationgroupe_index') }}'>
                    <button class="btn btn-success">Liste des cotisations</button>
                </a>

                <hr style="visibility: hidden" />  

                <table id="example1" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Département</th>
                            <th>Groupe</th>
                            <th>Code fidèle</th>
                            <th>Fidèle</th>
                            <th>Objet</th>
                            <th>Montant à payer</th>
                            <th>Mont payé</th>
                            <th>Reste </th>

                        </tr>
                    </thead>
                    <tbody>
                        {% for detail in details %}
                              {% if is_granted("cotisergroupe_detailgroupe", detail) %}
                            <tr>
                                <td>{{ detail.datecotiser ? date_format(detail.datecotiser) }}</td>
                                <td>{{ detail.groupe.departement.nom }}</td>
                                <td>{{ detail.groupe.nom }}</td>
                                <td>{{ detail.fidele.code|upper }}</td>

                                <td>{{ detail.fidele.nomfidele }}</td>
                                <td>{{ detail.cotisationgroupe.objet }}</td>
                                <td>{{ detail.cotisationgroupe.montant|number_format(0, '.', ' ') }}</td>
                                <td>{{ detail.montantpayer }}</td>
                                <td>

                                    {% if  detail.reste > 0 %}
                                        <b>{{ detail.reste|number_format(0, '.', ' ') }}</b>


                                    {% else %}
                                        <i class="btn btn-success">    Soldée</i> 
                                    {% endif %}


                                </td>

                            </tr>
                              {% endif %}
                        {% else %}
                            <tr>
                                <td colspan="13">Aucuné donnée trouvée</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
