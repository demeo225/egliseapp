{% extends 'home/index.html.twig' %}

{% block title %}Cotiserpazone index{% endblock %}

{% block body %}
    <div class="card-body">

        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Paiement des cotisations</h3>
            </div>
    <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger', 'commune', 'suppcommune']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
            <!-- /.card-header -->
            <div class="card-body">
                <a href='{{ path('app_cotiserpazone_new') }}'>
                    <button class="btn btn-primary">Nouveau</button>
                </a>
                <a href='{{ path('cotiserpazone_detailcotisation') }}'>
                    <button class="btn btn-danger">Details paiement</button>
                </a>

                <a href='{{ path('app_cotisationparzone_index') }}'>
                    <button class="btn btn-success">Liste cotisations</button>
                </a>
                <hr style="visibility: hidden" />  

                <table id="example1" class="table table-bordered table-striped">
                    <thead>
                        <tr>

                            <th>Zone</th>
                            <th>Objet </th>
                            <th>Montant </th>
                            <th>Montant payé</th>
                            <th>Reste</th>
                            <th>Date limite</th>

                        </tr>
                    </thead>
                    <tbody>
                        {% for cotiserpazone in cotiserpazones %}
                            <tr>
                                <td> {% if cotiserpazone.zone is not empty %} {{ cotiserpazone.zone.nom }} {% else %} {% endif %}</td>
                                <td> {% if cotiserpazone.cotisationparzone is not empty %} {{ cotiserpazone.cotisationparzone.objet }} {% else %} {% endif %}</td>
                                <td> {% if cotiserpazone.cotisationparzone is not empty %} {{ cotiserpazone.cotisationparzone.montant|number_format(0, '.', ' ') }} {% else %} {% endif %}</td>
                                <td>{{ cotiserpazone.montantpayer|number_format(0, '.', ' ') }}</td>
                                <td>
                                    {% if  cotiserpazone.reste ==0 %} <b>Soldé</b> 
                                    {% elseif cotiserpazone.reste >0 %} {{ cotiserpazone.reste }} {% elseif cotiserpazone.reste < 0 %} 
                                        <i class="btn btn-success"> Soldé </i> {% endif %}


                                    </td>

                                    <td>{{ cotiserpazone.datecotiser ? cotiserpazone.datecotiser|date('d-m-Y') : '' }}</td>

                                  {#  <td>
                                        {% if cotiserpazone.reste <= 0 %} {% else %}
                                            <a href="{{ path('app_cotiserpazone_edit', {'id': cotiserpazone.id}) }}">   <span style="font-size: 1em; color: Dodgerblue;">
                                                    <i class="fas fa-edit"></i>
                                                </span></a>
                                            {% endif %}
                                    </td> #}
                                </tr>
                        
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                {% endblock %}
