{% extends "home/index.html.twig" %}

{% block title %}Ordre de nommination{% endblock %}

{% block body %}

    <div class="card-body">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Ordres de Nomination</h3>
            </div>
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
            <!-- /.card-header -->
            <div class="card-body">

                <a href='{{ path('app_nommination_new') }}'>
                    <button class="btn btn-primary">Nouveau</button>
                </a>


                <hr style="visibility: hidden" />
                <table id="example1" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Date nommination</th>
                            <th>Decret</th>
                            <th>Fidèles</th>

                        </tr>
                    </thead>
                    <tbody>
                        {% for nommination in nomminations %}
                            <tr>
                                <td>  {{ nommination.datenomination|date('d-m-Y')  }} </td>
                                <td>{{ nommination.decret }} </td>
                                <td> 
                                    <div>


                                        <button type="button" id="btn-fideles-modal" class="btn btn-primary" data-target="{{ path('nommination_search_fideles', {'id':nommination.id}) }}">Voir les fideles</button>

                                    </div>

                                </td>




                            </tr>
                        {% else %}

                        {% endfor %}


                    </tbody>
                </table>

            </div>
        </div>


        <div class="modal fade" id="fidelesModal" tabindex="-1" aria-labelledby="fidelesModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="fidelesModalLabel">Liste des promus </h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-primary" data-dismiss="modal">Fermer</button>
                    </div>
                </div>
            </div>
        </div>
    {% endblock %}

    {% block javascripts %}
        {{ parent() }}
        <script>
            $(document).ready(function () {
                // quand on clic sur le button voir les fideles pour ouvrir la fenêtre modal
                $(document).on('click', 'button#btn-fideles-modal', function () {
                    // créer le modal qui porte l'id fidelesModal
                    let modal = new bootstrap.Modal(document.getElementById('fidelesModal'), {
                        keyboard: false
                    });

                    // recupere le div class="modal-body" du div id="fidelesModal"
                    let container = $('#fidelesModal .modal-body');

                    $.ajax({
                        type: 'POST',
                        url: $(this).attr('data-target'),
                        async: true,
                        beforeSend: function () { // avant d'envoyé le post on vide le div.modal-body
                            container.empty();
                        },
                        success: function (html) {
                            container.append(html); // une fois la réponse, on rempli le div.modal-body
                            modal.show(); // on affiche la fenêtre modal
                            //console.log(html);
                        }
                    });
                });
            });
        </script>
    {% endblock %}