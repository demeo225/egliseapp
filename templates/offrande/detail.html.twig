{% extends "home/index.html.twig" %}

{% block title %}Gestion des communes{% endblock %}

{% block body %}



    <section class="content">
        <div class="container-fluid">
            <div class="row">

                <!-- /.card-header -->
                <div class="card-body">
                    <a href='{{ path('commune_add') }}'>
                        <button class="btn btn-primary">Nouveau</button>
                    </a>
                   <a href='{{ path('commune_print') }}'>
                        <button class="btn btn-primary">Imprimer</button>
                    </a>
                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Nbre 10 000f</th>
                                <th>Nbre 5000f</th>
                                <th>Nbre 2000F</th>
                                <th>Date</th>
                                <th>Date</th>
                                <th>Date</th>
                                <th>Detail</th>
                                <th>Modifier</th>
                                <th>Supprimer</th>


                            </tr>
                        </thead>
                        <tbody>
                            {% for commune in commune %}
                                <tr>
                                    <td>{{ commune.nom|upper}}</td>
                                 



                                    <td>
                                        <a href="{{ path('commune_detail', {'id': commune.id}) }}">
                                            <span style="font-size: 1em; color: Dodgerblue;">
                                                <i class="fas fa-address-card"></i>
                                            </span>
                                        </a>
                                    </td>


                                    <td>
                                        <a href="{{ path('commune_update', {'id': commune.id}) }}">
                                            <span style="font-size: 1em; color: Dodgerblue;">
                                                <i class="fas fa-edit"></i>
                                            </span>
                                        </a>
                                    </td>
                                    <td>
                                        <form method="post" action="{{ path('commune_delete', {'id': commune.id}) }}" onsubmit="return confirm('etes vous sur de vouloir supprimer?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ commune.id) }}">

                                            <button class="btn">
                                                <span style="font-size: 1em; color: Dodgerblue;">
                                                    <i class="fas fa-trash-alt"></i>
                                                </span>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5">aucune donnee trouve</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>


        </div>
    </section>


{% endblock %}
