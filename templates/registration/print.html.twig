{% block title %}
    {% block stylesheets %}

        {# { encore_entry_link_tags('app') } #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
        <style>

            #footer {
                text-align:center;
                font-style: italic;
                clear:both;
                width: 100%;
                position: absolute;
                bottom: 0;
                padding-top: 50px;
                height: 20px;
            }


            .centrage {
                text-align: center;
                position: sticky;
                top: 40px;
                margin-left: 70px;
            }

            .communaute {
                position: absolute;
                top: 10px;
                left: auto;
                clear: both;
                border-radius: 4px;
                padding: 5px;
                font-size:smaller ;
                z-index: 5;
                text-align: left;
                justify-content: space-between;
                height: 10px;
                width: 300px;

            }

            .agrement {
                font-size:smaller ;
                z-index: -1;
            }

            .eglise {
                position: absolute;
                top: 10px;
                right:  5px;
                clear: both;
                border-radius: 4px;
                padding: 5px;
                font-size:smaller ;
            }

            .global  {
                display: flex;
                justify-content: center;
                align-items: center;
                justify-content: space-between;

            }
            .verset{
                text-align: center;
                border: 3px solid;
                font-size:smaller ;

            }
            .pasteur{
                position: absolute;
                right: 0px;
                width: 300px;
                border: 0px solid #73AD21;
                padding: 10px;
            }
        </style>
    {% endblock %}


{% endblock %}
</head>
{% block body %}


    <div class="row">
        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-body text-center">


                    {{ eglise.sigle }} <b>-</b> {{ eglise.communaute.libelle }}
                    <hr />
                    <h5 class="my-3"> Agrement: {{ eglise.communaute.agrement }} </div>


            </div>
        </div>





        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-body text-center">


                    <img src="{{ base64(absolute_url(asset('uploads/photos/'~eglise.logo ))) }}"  style="img {
                             border: 1px solid #ddd;
                             border-radius: 4px;
                             padding: 5px;
                             width: 100px;
                         }"  alt="logo">  


                </div>
            </div>


        </div>


        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-body text-center">

                    {{ eglise.denomination }} <strong>-</strong> {{ eglise.quartier }}
                    <hr />
                    {{ eglise.contact1 }} /
                    {{ eglise.adresse }}

                    <div class="text-muted mb-1">Siège social: {{ eglise.communaute.siege }} / {{ eglise.communaute.adresse }} / Email: {{ eglise.communaute.email }} / {{ eglise.communaute.verset }} :<b> {{ eglise.communaute.texte }}</b> </div>


                </div>
            </div>


        </div>

    </div>




    <hr style="visibility: hidden" />

    <div class="full-page"><br><br>

        <!-- /.card-header -->


        <h4 style="text-align: center"><b>LETTRE DE RECOMMANDATION <u> {% if recommandation.reference is not empty  %} N° {{ recommandation.reference }} {% else %} de {{ recommandation.fidele.nomfidele }}{% endif %}  </b></u></h4>

        <img width="80px;" style="float: right;" src="{{base64(absolute_url(asset('uploads/photos/'~recommandation.fidele.photoFile ))) }}" alt="Photo" >

        <div class="form-row">

            {% if recommandation.destination is not empty %} 
                <p>   Chers frères et soeurs de la communauté {{ recommandation.destination }},</p><p>
                    que la grâce et la paix de notre Seigneur Jésus vous soient multipliées.

                {% else %} Chers frères et soeurs en Christ, que la grâce et la paix de notre Seigneur Jésus vous soient multipliées.  </p> {% endif %} 

            <p>Nous, {{ eglise.communaute.libelle }},  </p>

            <p>   Temple {{ eglise.denomination }} </p>
            <p>avons le grand plaisir de recommander à votre communion fraternelle</p>

            {% set sexefidele = recommandation.fidele.sexe %}
            {% if sexefidele == 'Homme' %}

                le frère {{ recommandation.fidele.nomfidele }}
            {% else %}

                la soeur {{ recommandation.fidele.nomfidele }}
            {% endif %}

            qui est en pleine communion avec nous et qui doit séjourner dans votre cité
            <p> pour causes de: {{ recommandation.objet }}</p>

            Pour servir et valoir ce que de droit, nous vous donnons
            ces autres informations concernant   
            {% set sexefidele = recommandation.fidele.sexe %}
            {% if sexefidele == 'Homme' %}

                le  frère {{ recommandation.fidele.nomfidele }}
            {% else %}

                la soeur {{ recommandation.fidele.nomfidele }}
            {% endif %} :
            <ul>
                {% if recommandation.fidele.stutbapteme == 'Oui'  %}
                    <li>Date baptême: {{ recommandation.fidele.datebapteme|date('d-m-Y') }}</li>
                    <li>Batpême effectué par {{ recommandation.fidele.pasteurbapteme }}</li>
                    <li> Lieu du baptême : {{ recommandation.fidele.lieubapteme }}</li>
                    {% else %} 
                    <li> Baptême: non baptisé(e)</li>
                    {% endif %}
                <li>Situation matrimoniale: {{ recommandation.fidele.statutmatri }}</li>
                <li>Responsabilité à l'église: {{ recommandation.fidele.fonction }}</li>
                <li>Stabilité: {{ recommandation.stabilite}}</li>
                <li>Fidelité: {{ recommandation.fidelite }}</li>
                <li>Soummission: {{ recommandation.soummission }}</li>

            </ul>

            <p>Nous vous prions de bien vouloir l’accueillir d’une manière digne des Saints.</p> 

        </div>


        <div class="pasteur">

            <p>Fait à  {{ eglise.commune }} le {{ recommandation.dateop|date('d-m-Y') }} </p>
            <p>Pour l'église locale de <u>{{ eglise.denomination }} -  {{ eglise.quartier|capitalize }}</u></p>
            <p>Le Pasteur principal</p>
            <p>{{ recommandation.pasteur }}</p>
        </div>
    </div>

{% endblock %}
