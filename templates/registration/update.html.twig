{# /app/templates/registration/register.html.twig #}
{% extends "home/index.html.twig" %}

{% block title %}Administration{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h4 class="card-title">Modification utilisateur</h4>
        </div>

        <div class="card card-body">
            {# Render the Form #}
            {{ form_start(form)}}

            <div class="row">
                <div class="col-md-3">
                    {{ form_row(form.nomuser, {'label':'Nom :','attr':{'class':'form-control'}}) }}
                </div>

                <div class="col-md-3">
                    {{ form_row(form.prenom, {'label':'Prenoms :','attr':{'class':'form-control'}}) }}
                </div>
                <div class="col-md-3">
                    {{ form_row(form.roles, {'label':'Role :'}) }}
                </div>




            </div>
            <div class="row"> 
                <div class="col-md-2">{{ form_row(form.save, {'label':'Modifier ','attr':{'value':'save'}}) }}</div>
            </div>


            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}{# empty Twig template #}
