{% extends 'home/index.html.twig' %}

{% block title %}Cartes du social{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des cartes du social</h3>
        </div>
           <div class="offset-1 col-md-10 mt-2 mb-2">
                {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} my-alert" role="alert">
                            <h5 class="m-0 flash-text">{{ message }}</h5>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

        <div class="card-body">
            <a href="{{ path('app_cartesocial_new') }}">
                <button class="btn btn-primary">Nouveau</button></a>
            <a href="{{ path('app_cotisationsociale_index') }}">
                <button class="btn btn-success">Liste Cotisations</button>
            </a>
            <a href="{{ path('app_activitesociale_adultesociaux') }}">
                <button class="btn btn-success">Cas sociaux</button>
            </a>

            <hr style="visibility: hidden" />
            <table id="example1" class="table table-bordered table-striped">
                <thead>
                    <tr>

                        <th>N° carte</th>
                        <th>Date d'expiration</th>
                        <th>Propriétaire</th>
                        <th>Contact</th>
                        <th>Modifier</th>
                        <th>Supprimer</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cartesocial in cartesocials %}
                        <tr>
                            <td>{{ cartesocial.numero }}</td>
                            <td>{{ cartesocial.datesocial ? date_format(cartesocial.datesocial) }}</td>
                            <td>{{ cartesocial.fidele.nomfidele }}</td>
                            <td>{{ cartesocial.fidele.contact1 }}</td>
                            <td>

                                <a href="{{ path('app_cartesocial_edit', {'id': cartesocial.id}) }}"> 
                                    <span style="font-size: 1em; color: Dodgerblue;">
                                        <i class="fas fa-edit" title="Modifier"></i>
                                    </span></a>

                            </td>
                            <td>
                                <form method="post" action="{{ path('app_cartesocial_delete', {'id': cartesocial.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cartesocial.id) }}">

                                    <button class="btn">
                                        <span style="font-size: 1em; color: red;">
                                            <i class="fas fa-trash-alt"></i>
                                        </span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="12">Aucune donnée trouvée</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
