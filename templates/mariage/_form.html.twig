
    <div class="card card-body">
        {{ form_start(form) }}
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.datemariage, {'label':' Date '})}}
            </div>
            <div class="col-md-4">
                {{ form_row(form.typeregime, {'label':' Categorie mariage '})}}
            </div>
        </div>
        <div class="row">

            <div class="col-md-4">
                {{ form_row(form.epouse, {'label':' Epouse non membre '}) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.epousemembre, {'label':' Epouse membre '})}}
            </div>
            <div class="col-md-4">
                {{ form_row(form.temoinepouse, {'label':' Témoin de la mariée '}) }}
            </div>
        </div>
        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.epoux, {'label':' Epoux non membre '})}}
            </div>
            <div class="col-md-4">
                {{ form_row(form.epouxmembre, {'label':' Epoux membre '})}}
            </div>

            <div class="col-md-4">
                {{ form_row(form.temoinepoux, {'label':' Témoin du marié '}) }}
            </div>


        </div>

        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.pasteurmariage, {'label':' Pasteur officiant ', 'class': 'foo'}) }}
            </div>

            <div class="col-md-4">
                {{ form_row(form.regime, {'label':' Regime '}) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.parrain, {'label':' Parrain '})}}
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.especedon, {'label':' Don Espèce '}) }}
            </div>

            <div class="col-md-4">
                {{ form_row(form.lieumariage, {'label':' Lieu du mariage'}) }}
            </div>

            <div class="col-md-4">
                {{ form_row(form.photo, {'label':'Photo '}) }}
            </div>
        </div>



        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.naturedon, {'label':' Dons en nature '}) }}

            </div>
        </div>

        <div class="row"> 
            <div  class="col-md-2">{{ form_row(form.save, {'label':'Enregistrer ','attr':{'value':'save'}}) }}</div>

            <div  class="col-md-3"> {{ form_row(form.saveAndAdd, {'label':'Enregistrer et continuer ','attr':{'value':'save-and-add'}}) }} </div>

            <div  class="col-md-2"><a href="{{ path('mariage_index') }}" class="btn btn-success">Afficher la liste</a> </div>
        </div> 
        {{ form_end(form) }}
    </div>


