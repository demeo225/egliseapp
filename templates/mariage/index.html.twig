{% extends "home/index.html.twig" %}

{% block title %}Liste des mariages{% endblock %}

{% block body %}

    <div class="card-body">

        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Liste des mariages</h3>
            </div>
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
            <!-- /.card-header -->
            <div class="card-body">
                <a href='{{ path('mariage_new') }}'>
                    <button class="btn btn-primary">Nouveau Mariage</button>
                </a>
                <a href='{{ path('fiancaille_index') }}'>
                    <button class="btn btn-success">Fiancaille</button>
                </a>
                <a href="{{ path('couple_index') }}"><button class="btn btn-success">Liste des couples</button>
                </a>
                <hr style="visibility: hidden" />                    

                <table class="table table-bordered table-striped" id="example1">
                    <thead>
                        <tr>
                            <th>Date </th>
                            <th>Epouse</th>
                            <th>Epoux</th>
                            <th>Regime</th>
                            <th>Photo</th>
                            <th>Modifier</th>

                        </tr>
                    </thead>
                    <tbody>
                        {% for mariage in mariages %}
                            <tr>
                                <td>{{ mariage.datemariage ? date_format(mariage.datemariage) }}</td>
                                <td>{% if mariage.epousemembre is not empty %} {{ mariage.epousemembre.nomfidele}} {% else %}{{ mariage.epouse}}{% endif %}</td>
                                <td>{% if mariage.epouxmembre is not empty %} {{ mariage.epouxmembre.nomfidele}} {% else %}{{ mariage.epoux}}{% endif %}</td>
                                <td> {{ mariage.regime }}
                                <td> {% if mariage.photo is not empty %}
                                        <img src="{{ asset('uploads/photos/'~mariage.photoFile )}}"  class="img-size-50 mr-3 img-suqare" />
                                    {% else %}  {% endif %}
                                        
                                    </td>

                                    <td>
                                        <button type="button" id="btn-fideles-modal" class="btn btn-primary" data-target="{{ path('mariage_show', {'id':mariage.id}) }}"> 
                                            <i class="fas fa-list" title="Details"></i>
                                        </button> 

                                        <a href="{{ path('mariage_edit', {'id': mariage.id}) }}"> <i class="fas fa-edit"></i></a>
                                    </td>

                                </tr>
                              
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>


                    <div class="modal fade bd-example-modal-lg" id="fidelesModal" tabindex="-1" aria-labelledby="fidelesModalLabel" aria-hidden="true">

                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-body">

                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% endblock %}

                        {% block javascripts %}
                            {{ parent() }}
                            <script>
                                $(document).ready(function () {
                                    // quand on clic sur le button voir les fideles pour ouvrir la fenêtre modal
                                    $(document).on('click', 'button#btn-fideles-modal', function () {
                                        // créer le modal qui porte l'id fidelesModal
                                        let modal = new bootstrap.Modal(document.getElementById('fidelesModal'), {
                                            keyboard: false
                                        });

                                        // recupere le div class="modal-body" du div id="fidelesModal"
                                        let container = $('#fidelesModal .modal-body');

                                        $.ajax({
                                            type: 'POST',
                                            url: $(this).attr('data-target'),
                                            async: true,
                                            beforeSend: function () { // avant d'envoyé le post on vide le div.modal-body
                                                container.empty();
                                            },
                                            success: function (html) {
                                                container.append(html); // une fois la réponse, on rempli le div.modal-body
                                                modal.show(); // on affiche la fenêtre modal
                                                //console.log(html);
                                            }
                                        });
                                    });
                                });
                            </script>


                        {% endblock %}
