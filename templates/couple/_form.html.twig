

<div class="card card-primary">

    <div class="card-body ">
    {{ form_start(form) }}
    <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger', 'commune', 'suppcommune']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
   
    <div class="row">
        <div class="col-md-4">
            {{ form_row(form.epoux, {'label':'Epoux :'}) }}
        </div>
        <div class="col-md-4">
            {{ form_row(form.epouse, {'label':'Epouse :'}) }}
        </div>
    </div>
  
   

    <hr style="visibility: hidden" />


     <div class="row"> 
                <div class="col-md-2">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div></p>

               <div class="col-md-3"> {{ form_row(form.saveAndAdd, {'label':'Enregistrer et continuer ','attr':{'value':'save-and-add'}}) }} </div>

                <div class="col-md-2"><a href="{{ path('couple_index') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 
    {{ form_end(form) }}

</div>
</div>
    