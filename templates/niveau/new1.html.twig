 <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion des Niveaux d'étude</h3>
        </div>
        <div class="card card-body">

       {{ form_start(form, {'attr': {'action': path('app_niveau_new1')} }) }}
            {{ form_errors(form) }}
          
       <div class="row mb-4">

            <div class="col-md-3">
                {{ form_row(form.libelle, {'libelle':'Objet depense ', 'attr':{'class':'form-control'}}) }}

            </div>


        </div>
            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

                <div class="col-md-2" style="display: none"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

            </div> 
            <div>
                {{ form_rest(form) }}
            </div>
            {{ form_end(form) }}
        </div>


    </div>
