{% extends 'base.html.twig' %}

{% block title %}Niveau{% endblock %}

{% block body %}
    <h1>Niveau</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ niveau.id }}</td>
            </tr>
            <tr>
                <th>Libelle</th>
                <td>{{ niveau.libelle }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ niveau.createdAt ? niveau.createdAt|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>UpdateedAt</th>
                <td>{{ niveau.updateedAt ? niveau.updateedAt|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Ideglise</th>
                <td>{{ niveau.ideglise }}</td>
            </tr>
            <tr>
                <th>CreatedFromIp</th>
                <td>{{ niveau.createdFromIp }}</td>
            </tr>
            <tr>
                <th>UpdatedFromIp</th>
                <td>{{ niveau.updatedFromIp }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ niveau.deletedAt ? niveau.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedFromIp</th>
                <td>{{ niveau.deletedFromIp }}</td>
            </tr>
            <tr>
                <th>Editable</th>
                <td>{{ niveau.editable ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_niveau_index') }}">back to list</a>

    <a href="{{ path('app_niveau_edit', {'id': niveau.id}) }}">edit</a>

    {{ include('niveau/_delete_form.html.twig') }}
{% endblock %}
