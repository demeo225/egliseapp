{% extends "home/index.html.twig" %}

{% block title %}Gestion des programmes{% endblock %}

{% block body %}


    <div class="card card-primary">
        <div class="card-header">
            <h4 class="card-title">Enregistrement des programmes</h4>
        </div>
   <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
        <div class="card card-body">

            {{ form_start(form) }}
 
  <div class="row">

                <div class="col-md-4">
                    {{ form_row(form.title, {'label':'Titre ','attr':{'class':'form-control'}}) }}
                </div>   

                <div class="col-md-4">
                    {{ form_row(form.description, {'label':'Description'}) }}
                </div>

                <div class="col-md-4">
                    {{ form_row(form.start, {'label':'Debut  '}) }}
                </div>
            </div>
                            <div class="row">

                <div class="col-md-4">
                    {{ form_row(form.end, {'label':'fin  '}) }}
                </div>



                <div class="col-md-4">
                    {{ form_row(form.background_color, {'label':'Arrière plan','attr':{'class':'form-control'}}) }}
                </div>   

                <div class="col-md-4">
                    {{ form_row(form.border_color, {'label':'Couleur de bordure'}) }}
                </div>
                            </div>
                            <div class="row">

                <div class="col-md-4">
                    {{ form_row(form.text_color, {'label':'Couleur du texte','attr':{'class':'form-control'}}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.all_day, {'label':'Tous les jours '}) }}
                </div>




            </div>

            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

                <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

                <div class="col-md-2"><a href="{{ path('programme') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div>

            {{ form_end(form) }}
        </div>
    </div>


{% endblock %}