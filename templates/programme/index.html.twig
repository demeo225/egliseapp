{% extends "home/index.html.twig" %}

{% block title %}Les programmes de l'église{% endblock %}

{% block body %}

    <div class="card-body">

        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Liste des programmes</h3>
            </div>
  <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
            <!-- /.card-header -->
            <div class="card-body">
                <a href='{{ path('programme_add') }}'>
                    <button class="btn btn-primary">Nouveau</button>
                </a>
                <a href='{{ path('programme_detail') }}'>
                    <button class="btn btn-primary">Calendrier des evenements</button>
                </a>


                <hr style="visibility: hidden" />
                <table id="example1" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Programme</th>
                            <th>Description</th>
                            <th>Debut</th>
                            <th>Fin</th>
                         
                            <th>Modifier</th>
                            <th>Supprimer</th>


                        </tr>
                    </thead>
                    <tbody>
                        {% for programme in programme %}
                            <tr>
                                <td>{{ programme.title}}</td>

                                <td>{{ programme.description}}</td>

                        
                                <td>{{ date_format(programme.start)}} à {{ programme.start|date('H:i:s') }}</td>
                                <td>{{ date_format(programme.end)}} à {{ programme.end|date('H:i:s') }}</td>

                     

                                    <td>
                        
                                            <a href="{{ path('programme_update', {'id': programme.id}) }}">
                                                <span style="font-size: 1em; color: Dodgerblue;">
                                                    <i class="fas fa-edit"></i>
                                                </span>
                                            </a>
                                      
                                    </td>

                                    <td>

                                  

                                            <form method="post" action="{{ path('programme_delete', {'id': programme.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ programme.id) }}">

                                                <button class="btn">
                                                    <span style="font-size: 1em; color: red;">
                                                        <i class="fas fa-trash-alt" title="Suppression"></i>
                                                    </span>
                                                </button>
                                            </form>
                                       
                                    </td>
                                </tr>
                            
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>

                    </div>


                </div>





                {% endblock %}
