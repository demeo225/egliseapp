{% extends "home/index.html.twig" %}

{% block title %}Necrologie{% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Enregistrement décès</h3>
        </div>
        <div class="card card-body">


            {{ form_start(form) }}
       <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.fidele, {'label':'Choix du fidèle '}) }}
                </div>

                <div class="col-md-4">
                    {{ form_row(form.datedeces, {'label':' Date du décès '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.lieudeces, {'label':'Lieu du décès '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.raisondeces, {'label':'Cause du décès '}) }}
                </div>
            </div>



        <div class="row"> 
            <div class="col-md-2">{{ form_row(form.save, {'label':'Enregistrer ','attr':{'value':'save'}}) }}</div>

           <div class="col-md-2"><a href="{{ path('deces_index') }}" class="btn btn-success">Afficher la liste</a> </div>
        </div> 
                </div>

        {{ form_end(form) }}
    </div>





{% endblock %}