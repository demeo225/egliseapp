{% extends 'base.html.twig' %}

{% block title %}Invitezone{% endblock %}

{% block body %}
    <h1>Invitezone</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>CreateAt</th>
                <td>{{ invitezone.createAt ? invitezone.createAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdateAt</th>
                <td>{{ invitezone.updateAt ? invitezone.updateAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ invitezone.nom }}</td>
            </tr>
            <tr>
                <th>Contact</th>
                <td>{{ invitezone.contact }}</td>
            </tr>
            <tr>
                <th>Habitation</th>
                <td>{{ invitezone.habitation }}</td>
            </tr>
            <tr>
                <th>Sexe</th>
