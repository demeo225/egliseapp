            </tr>
            <tr>
                <th>Fonction</th>
                <td>{{ invitezone.fonction }}</td>
            </tr>
            <tr>
                <th>Id</th>
                <td>{{ invitezone.id }}</td>
            </tr>
            <tr>
                <th>CreatedFromIp</th>
                <td>{{ invitezone.createdFromIp }}</td>
            </tr>
            <tr>
                <th>UpdatedFromIp</th>
                <td>{{ invitezone.updatedFromIp }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ invitezone.deletedAt ? invitezone.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedFromIp</th>
                <td>{{ invitezone.deletedFromIp }}</td>
            </tr>
            <tr>
                <th>Editable</th>
                <td>{{ invitezone.editable ? 'Yes' : 'No' }}</td>
            </tr>
