{% extends 'home/index.html.twig' %}

{% block title %}Invitezone index{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des invités de zone</h3>
        </div>
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        
        <div class="card-body">
                    <a href={{ path('app_seancezone_index') }}>
                <button class="btn btn-success">Liste activités</button>
            </a>
         <a href="{{ path('app_cotiserzone_new') }}" class="btn btn-danger">
                <i class="fas fa-money-bill"></i> Paiement cotisation
            </a>
            <a href="{{ path('app_cotiserzone_index') }}" class="btn btn-success">
                <i class="fas fa-list"></i> Liste des paiements
            </a>
                               <a href={{ path('app_depensezone_index') }}>
                        <button class="btn btn-success">Depense</button>

                    </a>
                <a href={{ path('app_cotiserzone_detailzone') }}>
                    <button class="btn btn-success">Detail cotisation</button>
                </a>
            <a href="{{ path('app_invitezone_new') }}">
                <button class="btn btn-primary">Nouveau</button></a>



            <hr style="visibility: hidden" />
            <table id="example1" class="table table-bordered table-striped">
                <thead>
                    <tr>

                        <th>Date</th>
                        <th>Cone</th>
                        <th>Nom</th>
                        <th>Contact</th>
                        <th>Habitation</th>
                        <th>Sexe</th>
                        <th>Fonction</th>

                        <th>Modifier</th>
                        <th>Supprimer</th>
                    </tr>
                </thead>
                <tbody>
                    {% for invitezone in invitezones %}
                        {% if is_granted("invitezone_view", invitezone) %}
                            <tr>
                                <td> {% if invitezone.seancezone is not empty %} {{ invitezone.seancezone.datesuper|date('d-m-Y') }} {% else %} {% endif %}</td>
                                <td> {% if invitezone.seancezone is not empty %} {{ invitezone.seancezone.zone.nom }} {% else %} {% endif %}</td>

                                <td>{{ invitezone.nom }}</td>
                                <td>{{ invitezone.contact }}</td>
                                <td>{{ invitezone.habitation }}</td>
                                <td>{{ invitezone.sexe }}</td>
                                <td>{{ invitezone.fonction }}</td>

                                <td>
                                         <button type="button"  id="btn-fideles-modal" data-target="{{ path('app_invitezone_edit', {'id': invitezone.id}) }}"> 
                                        <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-edit" title="Modifier"></i>
                                        </span>
                                    </button>
                                </td>
                                 <td>
                                <form method="post" action="{{ path('app_invitezone_delete', {'id': invitezone.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ invitezone.id) }}">
                                    <button class="btn">
                                        <span style="font-size: 1em; color: red;">
                                            <i class="fas fa-trash-alt"></i>
                                        </span>
                                    </button>
                                </form>
                            </td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>


    <!-- Modal des fidèles -->
    <div class="modal fade bd-example-modal-lg" id="fidelesModal" tabindex="-1" aria-labelledby="fidelesModalLabel" aria-hidden="true">

        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-body">

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            // quand on clic sur le button voir les fideles pour ouvrir la fenêtre modal
            $(document).on('click', 'button#btn-fideles-modal', function () {
                // créer le modal qui porte l'id fidelesModal
                let modal = new bootstrap.Modal(document.getElementById('fidelesModal'), {
                    keyboard: false
                });

                // recupere le div class="modal-body" du div id="fidelesModal"
                let container = $('#fidelesModal .modal-body');

                $.ajax({
                    type: 'POST',
                    url: $(this).attr('data-target'),
                    async: true,
                    beforeSend: function () { // avant d'envoyé le post on vide le div.modal-body
                        container.empty();
                    },
                    success: function (html) {
                        container.append(html); // une fois la réponse, on rempli le div.modal-body
                        modal.show(); // on affiche la fenêtre modal
                        //console.log(html);
                    }
                });
            });
        });
    </script>



{% endblock %}