
 <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion de congé</h3>
        </div>
              <div class="offset-1 col-md-10 mt-2 mb-2">
                {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} my-alert" role="alert">
                            <h5 class="m-0 flash-text">{{ message }}</h5>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        <div class="card card-body">
        {{ form_start(form) }}

        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.dateconge, {'label':'Date debut '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.datefin, {'label':'Date retour '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.fidele, {'label':'Choix du fidèle  '}) }}
            </div>

            <div class="col-md-3">
                {{ form_row(form.cause, {'label':'Causes'}) }}
            </div>
        </div>

        <div class="row"> 
            <div class="col-md-12">
                {{ form_row(form.detail, {'label':'Notes'}) }}
            </div>

        </div>

        <div class="row"> 
            <div class="col-md-2">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>
            <div class="col-md-2.5"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>
            <div class="col-md-3"><a href="{{ path('app_conge_index') }}" class="btn btn-success">Afficher la liste</a> </div>
        </div> 
        {{ form_end(form) }}

    </div>
</div>
