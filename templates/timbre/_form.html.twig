<div class="card card-primary">

    <div class="card card-body">
        {{ form_start(form) }}
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
  </div>
          
        {{ form_start(form) }}
        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.cartemembre, {'label':'Choix de la carte *  :'}) }}
            </div>
            <div class="col-md-4">
                {{ form_row(form.annee, {'label':'Année *:','attr':{'class':'form-control'}}) }}
            </div>
          
             <div class="col-md-4">
                {{ form_row(form.numero, {'label':'N° Timbre :','attr':{'class':'form-control'}}) }}
            </div>
          
        </div>
        <div class="row">
            <div class="col-md-4">
                {{ form_row(form.dateachat, {'label':'Date acquisition * :','attr':{'class':'form-control'}}) }}

            </div>
            
          
          
        </div>
            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>
                <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>
                <div class="col-md-3"><a href="{{ path('app_courrier_index') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 
            {{ form_end(form) }}
        </div>
    </div>
