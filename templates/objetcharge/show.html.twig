{% extends 'base.html.twig' %}

{% block title %}Objetcharge{% endblock %}

{% block body %}
    <h1>Objetcharge</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ objetcharge.id }}</td>
            </tr>
            <tr>
                <th>Libelle</th>
                <td>{{ objetcharge.libelle }}</td>
            </tr>
            <tr>
                <th>Ideglise</th>
                <td>{{ objetcharge.ideglise }}</td>
            </tr>
            <tr>
                <th>CreatedFromIp</th>
                <td>{{ objetcharge.createdFromIp }}</td>
            </tr>
            <tr>
                <th>UpdatedFromIp</th>
                <td>{{ objetcharge.updatedFromIp }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ objetcharge.deletedAt ? objetcharge.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedFromIp</th>
                <td>{{ objetcharge.deletedFromIp }}</td>
            </tr>
            <tr>
                <th>Editable</th>
                <td>{{ objetcharge.editable ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_objetcharge_index') }}">back to list</a>

    <a href="{{ path('app_objetcharge_edit', {'id': objetcharge.id}) }}">edit</a>

    {{ include('objetcharge/_delete_form.html.twig') }}
{% endblock %}
