{% extends 'home/index.html.twig' %}

{% block title %}Invite groupe index{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des invités de groupe</h3>
        </div>
<div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        
        <div class="card-body">
            <a href="{{ path('app_invitegroupe_new') }}">
                <button class="btn btn-primary">Nouveau</button></a>
            <a href={{ path('seancegroupe_index') }}>
                <button class="btn btn-success">Liste activités</button>
            </a>


            <hr style="visibility: hidden" />
            <table id="example1" class="table table-bordered table-striped">
                <thead>
                    <tr>

                        <th>Date</th>
                        <th>Groupe</th>
                        <th>Nom</th>
                        <th>Contact</th>
                        <th>Habitation</th>
                        <th>Sexe</th>
                        <th>Fonction</th>
                        <th>Modifier</th>
                         <th>Supprimer</th>
                    </tr>
                </thead>
           <tbody>
              {% for invitegroupe in invitegroupes %}
                <tr>
                    <td>{{ invitegroupe.seancegroupe ? invitegroupe.seancegroupe.datesuper|date('d-m-Y') : '-' }}</td>
                    <td>{{ invitegroupe.seancegroupe ? invitegroupe.seancegroupe.groupe.nom : '-' }}</td>
                    <td>{{ invitegroupe.nom }}</td>
                    <td>{{ invitegroupe.contact }}</td>
                    <td>{{ invitegroupe.habitation }}</td>
                    <td>{{ invitegroupe.sexe }}</td>
                    <td>{{ invitegroupe.fonction }}</td>
                    
                    {% if is_granted('invitegroupe_edit', invitegroupe) %}
                        <td class="text-center">
                            <a href="{{ path('app_invitegroupe_edit', {'id': invitegroupe.id}) }}" 
                            class="btn btn-sm btn-info" title="Modifier">
                                <i class="fas fa-edit"></i>
                            </a>
                        </td>
                    {% else %}
                        <td class="text-center">-</td>
                    {% endif %}
                    
                    {% if is_granted('invitegroupe_delete', invitegroupe) %}
                        <td class="text-center">
                            <form method="post" action="{{ path('app_invitegroupe_delete', {'id': invitegroupe.id}) }}" 
                                onsubmit="return confirm('Voulez-vous supprimer cet invité ?');"
                                style="display: inline-block;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ invitegroupe.id) }}">
                                <button class="btn btn-sm btn-danger" title="Supprimer">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </form>
                        </td>
                    {% else %}
                        <td class="text-center">-</td>
                    {% endif %}
                </tr>
     
            {% endfor %}
        </tbody>
            </table>
        </div>
    </div>


    <!-- Modal des fidèles -->
    <div class="modal fade bd-example-modal-lg" id="fidelesModal" tabindex="-1" aria-labelledby="fidelesModalLabel" aria-hidden="true">

        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-body">

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            // quand on clic sur le button voir les fideles pour ouvrir la fenêtre modal
            $(document).on('click', 'button#btn-fideles-modal', function () {
                // créer le modal qui porte l'id fidelesModal
                let modal = new bootstrap.Modal(document.getElementById('fidelesModal'), {
                    keyboard: false
                });

                // recupere le div class="modal-body" du div id="fidelesModal"
                let container = $('#fidelesModal .modal-body');

                $.ajax({
                    type: 'POST',
                    url: $(this).attr('data-target'),
                    async: true,
                    beforeSend: function () { // avant d'envoyé le post on vide le div.modal-body
                        container.empty();
                    },
                    success: function (html) {
                        container.append(html); // une fois la réponse, on rempli le div.modal-body
                        modal.show(); // on affiche la fenêtre modal
                        //console.log(html);
                    }
                });
            });
        });
    </script>



{% endblock %}