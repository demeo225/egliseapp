    <body id="{% block body_id %}{% endblock %}">



        <div class="card-body col-12"> 
            {{ form_start(form) }}

            <div class="my-custom-class-for-errors">
                {{ form_errors(form) }}
            </div>



            <fieldset>

         


                <div class="card mb-3" style="border:5px solid #1c7430;border-color: #1c7430;">
                    <div class="card-header" style="background-color: #1c7430;color: white;font-size: medium;font-weight: bold;">Donn&eacute;es Eglise</div>
                    <div class="card-body" style="font-weight: bold;color: black;">


                        <div class="row">

                            <div class="col-md-4">
                                {{ form_row(form.congregation, {'label':'Communauté chrétienne * '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.denomination, {'label':'Nom du Temple * '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.contact1, {'label':'Contact * '}) }}
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                {{ form_row(form.administrateur, {'label':'Email  * '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.contact2, {'label':'Fixe '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.adresse, {'label':'Adresse '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.photo, {'label':'Logo '}) }}
                            </div>

                            <div class="col-md-4">
                                {{ form_row(form.quartier, {'label':'Quartier * '}) }}
                            </div>  

                            <div class="col-md-4">
                                {{ form_row(form.verset, {'label':'Verset de base '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.texte, {'label':'Texte de base '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.sigle, {'label':'Sigle '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.facebook, {'label':'Cpte Facebook '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.agrement, {'label':'Agrement '}) }}
                            </div>

                            <div class="col-md-4">
                                {{ form_row(form.commune, {'label':'Ville ou Commune * '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.annee, {'label':'Année d\'implantation° '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.regionpastorale, {'label':'Region pastorale '}) }}
                            </div>
                        </div>
                    </div>
       <div class="card-header" style="background-color: #1c7430;color: white;font-size: medium;font-weight: bold;">Donn&eacute;es Administrateur</div>
                    <div class="card-body" style="font-weight: bold;color: black;">


                        <div class="row">

                            <div class="col-md-4">
                                {{ form_row(form.nomuser, {'label':'Nom * '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.prenom, {'label':'Prenom * '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.photo1, {'label':'Photo profile * '}) }}
                            </div>
                            <div class="col-md-4">
                                {{ form_row(form.email, {'label':'Email * '}) }}
                            </div>
                             <div class="col-md-4">
                                {{ form_row(form.plainPassword, {'label':'Mot de passe * '}) }}
                            </div>
                        </div>
                   
                </div>
                        <div class="col-md-4">
                            <button class="btn btn-success">{{ button_label|default('Valider') }}</button>
                        </div>
                    </div>

                </div>
            </fieldset>

            {{ form_end(form) }}
