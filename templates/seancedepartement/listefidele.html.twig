


<div class="card card-primary">

    <div class="card-header">
        <h3 class="card-title">Liste des invités  </h3>
    </div>

    <!-- /.card-header -->
    <div class="card-body">

        <table id="example1" class="table table-bordered table-striped">

            <thead>
                <tr>
                    <th>Nom & prenoms</th>
                    <th>Genre</th>
                    <th>Teléphone</th>
                    <th>Lieu de residence</th>
                    <th>Fonction</th>



                </tr>
            </thead>
            <tbody>
                {% for invitedepartement in invitedepartements %}
                    <tr>
                        <td>{{ invitedepartement.nom|upper}}</td>
                        <td>{{ invitedepartement.sexe}}</td>
                        <td>{{ invitedepartement.contact}}</td>
                        <td>{{ invitedepartement.habitation}}</td>
                        <td>{{ invitedepartement.fonction}}</td>

                    </tr>
                      
                {% endfor %}
            </tbody>
        </table>

    </div>

</div>


</div>

