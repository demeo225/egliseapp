{% extends "home/index.html.twig" %}

{% block title %}Liste des séances{% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Activités des departements</h3>
        </div>
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
        {% if is_granted('ROLE_RESPONSABLE_GROUPE') %}
            <div class="card-body">

                <a href='{{ path('seancedepartement_new') }}'>
                    <button class="btn btn-primary">Nouveau</button>
                </a>
                <a href={{ path('app_invitedepartement_index') }}>
                    <button class="btn btn-success">Invités</button>
                </a>
                <a href='{{ path('cotisationdepartement_index') }}'>
                    <button class="btn btn-success">Cotisations </button>
                </a>

                <a href={{ path('cotiserdepartement_index') }}>
                    <button class="btn btn-success">Paiements de cotisation</button>

                </a>
                <a href={{ path('seancedepartement_listeparticipant') }}>
                    <button class="btn btn-success">Liste présence</button>
                </a>
                <a href={{ path('app_bilan_departement2') }}>
                    <button class="btn btn-danger">Bilan</button>

                </a>
                <a href={{ path('app_depensedepartement_index') }}>
                    <button class="btn btn-success">Depenses</button>

                </a>

               <a href={{ path('seancedepartement_membredep') }}>
                    <button class="btn btn-success">Membres</button>

                </a>
            {% endif %}
            <hr style="visibility: hidden" />
            <table id="example1" class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Departement</th>
                        <th>Lieu</th>
                        <th>Theme</th>
                        <th>Total présents</th>
                        <th>Invités</th>
                        <th>Présents</th>
                        <th>Absents</th>
                        <th>Details</th>


                    </tr>
                </thead>
                <tbody>
                    {% if is_granted('ROLE_SECRETAIRE') %}
                        {% for diff in differences %}
                            {% set totaux = 0 %}
                            {% for seancedepartement in seancedepartements %}
                                {% if diff.datesuper ==  seancedepartement.datesuper %}
                                    {% if is_granted("seancedepartement_edit", seancedepartement) %}
                                        <tr>
                                            <td>{{ seancedepartement.datesuper ? seancedepartement.datesuper|date('d-m-Y') : '' }}</td>
                                            <td>{{ seancedepartement.departement.nom }}</td>
                                            <td>{{ seancedepartement.lieu }}</td>
                                            <td>{{ seancedepartement.theme }}</td>
                                            <td>                                    {% set nbrepresent =seancedepartement.nbrepresent %}
                                                {% set femme =seancedepartement.femme %}
                                                {% set enfant =seancedepartement.enfant %}
                                                {% set total = enfant +nbrepresent + femme %}
                                                {% set totaux = total + totaux ?? 0 %}
                                                {{ total }}
                                            </td>
                                          <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-info btn-invites" 
                                                    data-target="{{ path('seancedepartement_search_invitedepartements', {'id': seancedepartement.id}) }}">
                                                <i class="fas fa-users"></i> {{ seancedepartement.invitedepartements|length }}
                                            </button>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-success btn-present" 
                                                    data-id="{{ seancedepartement.id }}"
                                                    data-departement="{{ seancedepartement.departement.id }}">
                                                <i class="fas fa-check-circle"></i> Présents
                                            </button>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-danger btn-absent" 
                                                    data-id="{{ seancedepartement.id }}"
                                                    data-departement="{{ seancedepartement.departement.id }}">
                                                <i class="fas fa-times-circle"></i> Absents
                                            </button>
                                        </td>
                                        <td class="text-center">
                                            <a href="{{ path('seancedepartement_show', {'id': seancedepartement.id}) }}" class="btn btn-sm btn-primary">
                                                <i class="fas fa-list"></i>
                                            </a>
                                        </td>

                                        </tr>
                                    {% endif %}
                                {% endif %}

                            {% endfor %}
                            {% if totaux == 0  %}
                            {% else %}
                                <tr>
                                    <td colspan="4"> <b>Totaux</b> </td>
                                    <td><b> {{ totaux }}</b> </td>
                                    <td colspan="2"></td>
                                </tr>
                            {% endif %}
                        {% endfor %}


                    {% else %}
                        {% for diff in differences %}
                            {% set totaux = 0 %}
                            {% for seancedepartement in seancedepartements %}
                                {% if diff.datesuper ==  seancedepartement.datesuper %}
                                    {% if is_granted("seancedepartement_edit", seancedepartement) %}
                                        <tr>
                                            <td>{{ seancedepartement.datesuper ? seancedepartement.datesuper|date('d-m-Y') : '' }}</td>
                                            <td>{{ seancedepartement.departement.nom }}</td>
                                            <td>{{ seancedepartement.lieu }}</td>
                                            <td>{{ seancedepartement.theme }}</td>
                                            <td>                                    {% set nbrepresent =seancedepartement.nbrepresent %}
                                                {% set femme =seancedepartement.femme %}
                                                {% set enfant =seancedepartement.enfant %}
                                                {% set total = enfant +nbrepresent + femme %}
                                                {% set totaux = total + totaux ?? 0 %}
                                                {{ total }}
                                            </td>
                                            <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-info btn-invites" 
                                            data-target="{{ path('seancedepartement_search_invitedepartements', {'id': seancedepartement.id}) }}">
                                        <i class="fas fa-users"></i> {{ seancedepartement.invitedepartements|length }}
                                    </button>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-success btn-present" 
                                            data-id="{{ seancedepartement.id }}"
                                            data-departement="{{ seancedepartement.departement.id }}">
                                        <i class="fas fa-check-circle"></i> Présents
                                    </button>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-danger btn-absent" 
                                            data-id="{{ seancedepartement.id }}"
                                            data-departement="{{ seancedepartement.departement.id }}">
                                        <i class="fas fa-times-circle"></i> Absents
                                    </button>
                                </td>
                                <td class="text-center">
                                    <a href="{{ path('seancedepartement_show', {'id': seancedepartement.id}) }}" class="btn btn-sm btn-primary">
                                        <i class="fas fa-list"></i>
                                    </a>
                                </td>

                                        </tr>
                                    {% endif %}
                                {% endif %}

                            {% endfor %}

                        {% endfor %}  
                    {% endif %}
                </tbody>
            </table>

        </div>
    </div>


{# Modal pour les présents #}
<div class="modal fade" id="presentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success">
                <h5 class="modal-title">
                    <i class="fas fa-check-circle"></i> Liste des présents
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

{# Modal pour les absents #}
<div class="modal fade" id="absentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-danger">
                <h5 class="modal-title">
                    <i class="fas fa-times-circle"></i> Liste des absents
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

{# Modal pour les invités (existant) #}
<div class="modal fade" id="fidelesModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info">
                <h5 class="modal-title">
                    <i class="fas fa-users"></i> Liste des invités
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}


{% block javascripts %}
    {{ parent() }}
    
<script>
$(document).ready(function() {
    // Modal pour les invités
    $(document).on('click', 'button.btn-invites', function() {
        let modal = new bootstrap.Modal(document.getElementById('fidelesModal'), { keyboard: false });
        let container = $('#fidelesModal .modal-body');
        
        container.html('<div class="text-center"><i class="fas fa-spinner fa-spin fa-2x"></i><p>Chargement...</p></div>');
        
        $.ajax({
            type: 'POST',
            url: $(this).data('target'),
            success: function(html) {
                container.html(html);
                modal.show();
            },
            error: function() {
                container.html('<div class="alert alert-danger">Erreur lors du chargement</div>');
                modal.show();
            }
        });
    });
    
    // Modal pour les présents
    $(document).on('click', 'button.btn-present', function() {
        let modal = new bootstrap.Modal(document.getElementById('presentModal'), { keyboard: false });
        let container = $('#presentModal .modal-body');
        let seanceId = $(this).data('id');
        let departementId = $(this).data('departement');
        
        container.html('<div class="text-center"><i class="fas fa-spinner fa-spin fa-2x"></i><p>Chargement de la liste des présents...</p></div>');
        
        $.ajax({
            type: 'POST',
            url: '{{ path('seancedepartement_presents') }}',
            data: {
                seance_id: seanceId,
                departement_id: departementId
            },
            success: function(html) {
                container.html(html);
                modal.show();
            },
            error: function() {
                container.html('<div class="alert alert-danger">Erreur lors du chargement de la liste des présents</div>');
                modal.show();
            }
        });
    });
    
    // Modal pour les absents
    $(document).on('click', 'button.btn-absent', function() {
        let modal = new bootstrap.Modal(document.getElementById('absentModal'), { keyboard: false });
        let container = $('#absentModal .modal-body');
        let seanceId = $(this).data('id');
        let departementId = $(this).data('departement');
        
        container.html('<div class="text-center"><i class="fas fa-spinner fa-spin fa-2x"></i><p>Chargement de la liste des absents...</p></div>');
        
        $.ajax({
            type: 'POST',
            url: '{{ path('seancedepartement_absents') }}',
            data: {
                seance_id: seanceId,
                departement_id: departementId
            },
            success: function(html) {
                container.html(html);
                modal.show();
            },
            error: function() {
                container.html('<div class="alert alert-danger">Erreur lors du chargement de la liste des absents</div>');
                modal.show();
            }
        });
    });
});
</script>



{% endblock %}

