{% extends "home/index.html.twig" %}

{% block title %}Cotisationfamille{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Details de la cotisation :{{cotisationfamille.objet}}</h3>
        </div>

    <table class="table">
        <tbody>


            <tr>
                <th>Objet</th>
                <td>{{ cotisationfamille.objet }}</td>
            </tr>
            <tr>
                <th>Montant</th>
                <td>{{ cotisationfamille.montant|number_format(0, '.', ' ') }}</td>
            </tr>
            <tr>
                <th>Montantal cotisé</th>
                <td>
                    {% set detail = cotisationfamille.cotiserfamilles  %}
                    {% for detail in detail %}
                        {% set sum = detail.montantpayer + sum ?? 0 %}
                        {% if loop.last  %} <b> {{ sum|number_format(0, '.', ' ') }}</b>  {% endif %}
                    {% endfor %}

                </td>
            </tr>

            <tr>
                <th>Etat</th>
                <td> 
                    {% if date('now') < date(cotisationfamille.datefin) %}
                    <b>En cours</b>

                    {% else %}

                        <i class="btn btn-success">  Achévée</i>
                        {% endif %}

                        </td>
                    </tr>


                </tbody>
            </table>
                            <a href='{{ path('cotisationfamille_index') }}'>
                        <button class="btn btn-success">Liste cotisations</button>
                    </a>
    </div>

            {% endblock %}
