<div class="card card-primary">

    <div class="card card-body">
        {{ form_start(form) }}
           <div class="offset-1 col-md-10 mt-2 mb-2">
                {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} my-alert" role="alert">
                            <h5 class="m-0 flash-text">{{ message }}</h5>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        {{ form_start(form) }}
        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.datecarte, {'label':'Date limite :'}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.numero, {'label':'N° :','attr':{'class':'form-control'}}) }}
            </div>

            <div class="col-md-3">
                {{ form_row(form.fidele, {'label':'Fidèle :','attr':{'class':'select2'}}) }}
            </div>



        </div>

        <div class="row"> 
            <div class="col-md-1">{{ form_row(form.save, {'label':'Valider','attr':{'value':'save'}}) }}</div>
            <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>
            <div class="col-md-3"><a href="{{ path('app_cartemembre_index') }}" class="btn btn-success">Afficher la liste</a> </div>
        </div> 
        {{ form_end(form) }}
    </div>
</div>
