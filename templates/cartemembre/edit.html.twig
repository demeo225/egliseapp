{% extends "home/index.html.twig" %}

{% block title %}Modification carte de membre{% endblock %}

{% block body %}
   <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Modification carte du membre</h3>
        </div>
         <div class="card card-body">
       {{ form_start(form) }}
        <div class="my-custom-class-for-errors">
            {{ form_errors(form) }}
            {% for message in app.flashes('success') %}
                <div class="primary">
                    {{ message }}
                </div>
            {% endfor %}
        </div>
        {{ form_start(form) }}
        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.datecarte, {'label':'Date limite :'}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.numero, {'label':'N° :','attr':{'class':'form-control'}}) }}
            </div>
      
            <div class="col-md-3">
                {{ form_row(form.fidele, {'label':'Fidèle :','attr':{'class':'select2'}}) }}
            </div>



        </div>

        <div class="row"> 
            <div class="col-md-2">{{ form_row(form.save, {'label':'Modifier ','attr':{'value':'save'}}) }}</div>
            <div class="col-md-3"><a href="{{ path('app_cartemembre_index') }}" class="btn btn-success">Afficher la liste</a> </div>
            <div class="col-md-3" style="visibility: hidden"> {{ form_row(form.saveAndAdd, {'label':'Enregistrer et continuer ','attr':{'value':'save-and-add'}}) }} </div>
        </div> 
        {{ form_end(form) }}
         </div>

   </div>
{% endblock %}
