{% extends 'home/index.html.twig' %}

{% block title %}Cartes de membres{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des cartes de membre</h3>
        </div>
           <div class="offset-1 col-md-10 mt-2 mb-2">
                {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} my-alert" role="alert">
                            <h5 class="m-0 flash-text">{{ message }}</h5>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        
        <div class="card-body">
            <a href="{{ path('app_cartemembre_new') }}">
                <button class="btn btn-primary">Nouveau</button></a>


            <hr style="visibility: hidden" />
            <table id="example1" class="table table-bordered table-striped">
                <thead>
                    <tr>

                        <th>N°</th>
                        <th>Date expiration</th>
                        <th>Propriétaire</th>
                        <th>CONTACT</th>
                        <th>Details</th>
                        <th>Modifier</th>
                        <th>Supprimer</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cartemembre in cartemembres %}
                        <tr>
                            <td>{{ cartemembre.numero }}</td>
                            <td>{{ cartemembre.datecarte ? date_format(cartemembre.datecarte) }}</td>
                            <td>{{ cartemembre.fidele.nomfidele }}</td>
                            <td>{{ cartemembre.fidele.contact1 }}</td>

                            <td>
                                <a href="{{ path('app_cartemembre_show', {'id': cartemembre.id}) }}">  
                                    <span style="font-size: 1em; color: Dodgerblue;">
                                        <i class="fas fa-list"></i>
                                    </span></a>
                            </td>
                            <td>
                                <a href="{{ path('app_cartemembre_edit', {'id': cartemembre.id}) }}"> 
                                    <span style="font-size: 1em; color: Dodgerblue;">
                                        <i class="fas fa-edit" title="Modifier"></i>
                                    </span>
                                </a>
                            </td> 
                            <td>
                                <form method="post" action="{{ path('app_cartemembre_delete', {'id': cartemembre.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cartemembre.id) }}">

                                    <button class="btn">
                                        <span style="font-size: 1em; color: red;">
                                            <i class="fas fa-trash-alt"></i>
                                        </span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
