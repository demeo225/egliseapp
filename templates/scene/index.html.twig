{% extends "home/index.html.twig" %}

{% block title %}Cene index{% endblock %}

{% block body %}

    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Saintes Cènes</h3>
        </div>
        <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
        <!-- /.card-header -->
        <div class="card-body">
            <a href='{{ path('app_scene_new') }}'>
                <button class="btn btn-primary">Nouveau</button>
            </a>

            <hr style="visibility: hidden" />
            <table id="example1" class="table table-bordered table-striped">
                <thead>
                    <tr>

                        <th>Date</th>
                        <th>Pasteur officiant</th>
                        <th>Pasteur 2nd</th>

                        <th>actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for scene in scenes %}
                        <tr>
                            <td>{{ scene.datescene ? scene.datescene|date('d-m-Y') : '' }}</td>

                            <td>{% if scene.pasteur1 is not empty %} {{ scene.pasteur1.nomfidele  }}{% else %} {% endif %} </td>
                            <td>{% if scene.pasteur2 is not empty %} {{ scene.pasteur2.nomfidele  }}{% else %} {% endif %} </td>
                            <td>
                                <a href="{{ path('app_scene_show', {'id': scene.id}) }}">  <span style="font-size: 1em; color: Dodgerblue;">
                                        <i class="fas fa-list" title="Voir les details"></i>
                                    </span></a>
                                <a href="{{ path('app_scene_edit', {'id': scene.id}) }}">     <span style="font-size: 1em; color: Dodgerblue;">
                                        <i class="fas fa-edit"></i>
                                    </span></a>
                            </td>
                        </tr>
                    {% else %}

                    {% endfor %}
                </tbody>
            </table>
        </div></div>
    {% endblock %}
