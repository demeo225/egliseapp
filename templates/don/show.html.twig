{% extends "home/index.html.twig" %}

{% block title %}Details dons
{% endblock %}

{% block body %}

    <h3>
        <u>
            <strong>Don du {{ don.datedon|date('d-m-Y')}}</strong>
        </u>
    </h3>

    <table class="table">

        <thead>
            <tr class="btn-success">
                <th>Donateur</th>
                <th>Nature</th>
                <th>Description</th>
                <th>Montant</th>
                <th>Enregistré le</th>
                <th>Enregistré par</th>
            

            </tr>
        </thead>
        <tbody>
            <tr>

                <td>{{ don.donateur|upper}}</td>
                <td>{{ don.nature}}</td>
                <td>{{ don.description}}</td>
                <td> <b> {{ don.valeurdon|number_format(0, '.', ' ')}} </b></td>
                <td>{{ don.createAt|date('m-d-Y à H:m:s')}}</td>
                    <td>{{ don.createdBy.nomuser}}</td>
             
            </tr>
        </tbody>
    </td>
</tr></tbody><tfooter>
    <tr>
        <td>
            <a href='{{ path('don_index') }}'>
                <button class="btn btn-primary">Retour</button>
            </a>
        </td>


    </tr></table>
{% endblock %}
