{% extends "home/index.html.twig" %}

{% block title %}Liste dons{% endblock %}

{% block body %}
    <div class="card-body">


        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Liste des dons</h3>
            </div>
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
            <!-- /.card-header -->
            <div class="card-body">
                <a href='{{ path('don_new') }}'>
                    <button class="btn btn-primary">Nouveau</button>
                </a>
                <hr style="visibility: hidden">
                <table id="example1" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Donateur</th>
                            <th>Type</th>
                            <th>Date</th>
                            <th>Valeur monétaire</th>
                            <th>Actions</th>
                            <th>Supprimer</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for don in dons %}
                            <tr>
                                <td>{{ don.donateur }}</td>
                                <td>{{ don.nature }}</td>
                                <td>{{ don.datedon ? don.datedon|date('d-m-Y') : '' }}</td>
                                <td> <b> {{ don.valeurdon|number_format(0, '.', ' ') }} </b> </td>

                                <td>
                                    <a href="{{ path('don_show', {'id': don.id}) }}"> <i class="fas fa-list" title="Details sur le don"></i></a>
                                </td>
                                <td>   <form method="post" action="{{ path('don_delete', {'id': don.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ don.id) }}">

                                            <button class="btn">
                                                <span style="font-size: 1em; color: red;">
                                                    <i class="fas fa-trash-alt"></i>
                                                </span>
                                            </button>
                                        </form></td>
                            </tr>
                  
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
