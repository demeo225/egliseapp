{% extends 'home/index.html.twig' %}
{% block title %}{{ eglise.denomination }} : Cotisations de: {{ nomfamille|upper }} {% endblock %}

{% block body %}



    <section class="content">
        <div class="container-fluid">
            <div class="row">

                <!-- /.card-header -->
                <div class="card-body">

                    <a href='{{ path('famille') }}'>
                        <button class="btn btn-success">Retour à la liste</button>
                    </a>
                        <div class="btn btn-primary">
                            Cotisations de : {{ nomfamille|upper }} </div>
                    <hr style="visibility: hidden" />
                    <table id="example1" class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Famille</th>
                                <th>Cotisation</th>
                                <th>Montant</th>
                                <th>Date buttoire</th>
                                <th>Etat</th>

                            </tr>
                        </thead>
                        <tbody>
                            {% for cotisationfamille in cotisationfamilles %}
                                <tr>

                                    <td> {% if cotisationfamille.famille is not null  %} {{ cotisationfamille.famille.nom|upper }}{% else %} {% endif %}</td>
                                    <td>{{ cotisationfamille.objet }}</td>
                                    <td>{{ cotisationfamille.montant }}</td>
                                    <td>{{ cotisationfamille.datefin ? cotisationfamille.datefin|date('d-m-Y') : '' }}</td>

                                    <td>
                                        {% if date('now') < date(cotisationfamille.datefin) %}
                                            <b>En cours</b>

                                        {% else %}

                                            <i class="btn btn-success">  Achévée</i>
                                        {% endif %}
                                    </td>


                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="16">Aucune donnée trouvée</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>


        </div>
    </section>


{% endblock %}
