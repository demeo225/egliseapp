{% extends 'home/index.html.twig' %}
{% block title %}{{ eglise.denomination }}  Liste de présence de : {{ nomfamille|upper }} {% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">    
                Liste de présence de : {{ nomfamille|upper }}
            </h3>
        </div>
        <div class="container-fluid">
            <div class="row">

                <!-- /.card-header -->
                <div class="card-body">

                    <a href='{{ path('famille') }}'>
                        <button class="btn btn-success">Retour à la liste</button>
                    </a>

                    <hr style="visibility: hidden" />

                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                        <th>Date</th>
                        <th>Objet</th>
                        <th>Lieu</th>
                        <th>Fidèle</th>
                        <th>Contact</th>
                        <th>Photo</th>
                        </thead>
                        </tr>
                        <tbody>
                            {% for presencefamille in presencefamilles %}

                                <tr>
                                    <td>{{ presencefamille.senacefamille.datesuper ? presencefamille.senacefamille.datesuper|date('d-m-Y') : '' }}</td>
                                    <td>{{ presencefamille.senacefamille.objet}}</td>
                                    <td>{{ presencefamille.senacefamille.lieu}}</td>
                                    <td>{{ presencefamille.fidele.nomfidele|upper}}</td>
                                    <td> {% if presencefamille.fidele.contactwhatssap is not empty %} {{ presencefamille.fidele.contactwhatssap}} {% else %} {{ presencefamille.fidele.contact1}} {% endif %}</td>
                                    <td>    
                                        <img src="{{ asset('uploads/photos/'~presencefamille.fidele.photoFile )}}"  class="img-size-50 mr-3 img-suqare"/> 

                                    </td>

                                </tr>

                            {% else %}
                                <tr>
                                    <td colspan="5">aucune donnée trouvée</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>


        </div>
    </div>


{% endblock %}
