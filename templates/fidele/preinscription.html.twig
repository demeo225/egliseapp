          <script>
            // Validation du formulaire
            document.getElementById('preinscriptionForm')?.addEventListener('submit', function(e) {
                let isValid = true;
                const requiredFields = this.querySelectorAll('[required]');
                
                requiredFields.forEach(field => {
                    if (!field.value.trim()) {
                        field.classList.add('is-invalid');
                        isValid = false;
                    } else {
                        field.classList.remove('is-invalid');
                    }
                });
                
                if (!isValid) {
                    e.preventDefault();
                    alert('Veuillez remplir tous les champs obligatoires.');
                }
            });
            
            // Gestion des champs conditionnels (baptême)
            document.querySelector('[name$="[stutbapteme]"]')?.addEventListener('change', function() {
                const baptemeFields = document.querySelectorAll('.bapteme-fields');
                if (this.value === 'Oui') {
                    baptemeFields.forEach(field => field.style.display = 'block');
                } else {
                    baptemeFields.forEach(field => field.style.display = 'none');
                }
            });
        </script>
    
        
        <script>
document.getElementById('preinscription_commune').addEventListener('change', function() {
    const communesId = this.value;

    if (communesId === '') return;

    fetch(`/fidele/quartiers/${communesId}`)
        .then(response => response.json())
        .then(data => {
            const quartierSelect = document.getElementById('preinscription_quartier');
            quartierSelect.innerHTML = '<option value="">-- Choisissez un quartier --</option>';

            data.forEach(quartier => {
                const option = document.createElement('option');
                option.value = quartier.id;
                option.textContent = quartier.libelle;
                quartierSelect.appendChild(option);
            });
        })
        .catch(error => console.error('Erreur lors du chargement des quartiers:', error));
});
</script>

    
