            <script>
            document.addEventListener("DOMContentLoaded", function () {

    const statut = document.getElementById("preinscription_statutmatri");
    const blocMariage = document.getElementById("bloc-mariage");

    function toggleMariage() {
        if (statut.value === "Marié(e)") {
            blocMariage.style.display = "flex"; // ou "block"
        } else {
            blocMariage.style.display = "none";
        }
    }

    // Vérifie au chargement
    toggleMariage();

    // Vérifie à chaque changement
    statut.addEventListener("change", toggleMariage);
});
            </script>


