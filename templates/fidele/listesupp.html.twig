{% extends "home/index.html.twig" %}

{% block title %}Archive fidèles{% endblock %}

{% block body %}


    <section class="content">
        <div class="container-fluid">
            <div class="row">

                <!-- /.card-header -->
                <div class="card-body">

                    <a href='{{ path('fidele_print') }}'>
                        <button class="btn btn-primary">Imprimer</button>
                    </a>
                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Fidèle</th>
                                <th>Quartier</th>
                                <th>Teléphone</th>
                                <th>Baptisé(e)</th>
                                <th>Photo</th>
                                <th>Fiche individuele</th>
                                <th>Detail</th>
                                <th>Modifier</th>
                                <th>Supprimer</th>


                            </tr>
                        </thead>
                        <tbody>
                            {% for fidele in fidele %}
                                <tr>
                                    <td>{{ fidele.code}}</td>
                                    <td>{{ fidele.nomfidele|upper}}</td>
                                    <td>{{ fidele.quartier.libelle}}</td>
                                    <td>{{ fidele.contact1}}</td>
                                    <td> {% set stutbapteme= fidele.stutbapteme %}
                                        {% set sexe= fidele.sexe %}

                                        {% if stutbapteme == 'Oui' and sexe == 'Homme' %}
                                            Baptisé
                                        {% elseif stutbapteme == 'Non' and sexe == 'Homme' %}
                                            Non baptisé
                                        {% elseif stutbapteme == 'Oui' and sexe == 'Femme' %}
                                            Baptisée
                                        {% else %}
                                            Non Baptisée
                                        {% endif %}


                                    </td>
                                    <td>
                                        <img src="{{ asset('uploads/photos/'~fidele.photo_file )}}"  class="img-size-50 mr-3 img-suqare"/>                                               



                                    <td>
                                        <a href="{{ path('fidele_detail', {'id': fidele.id}) }}">
                                            <span style="font-size: 1em; color: Dodgerblue;">
                                                <i class="fas fa-address-card"></i>
                                            </span>
                                        </a>
                                    </td>


                                    <td>
                                        <a href="{{ path('fidele_update', {'id': fidele.id}) }}">
                                            <span style="font-size: 1em; color: Dodgerblue;">
                                                <i class="fas fa-edit"></i>
                                            </span>
                                        </a>
                                    </td>
                                    <td>
                                        <a href="{{ path('fidele_supp', {'id': fidele.id}) }}">
                                            <span style="font-size: 1em; color: Dodgerblue;">
                                                <i class="fas fa-edit"></i>
                                            </span>
                                        </a>
                                    </td>
                                </tr>
                           
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>


        </div>
    </section>


{% endblock %}
