{% extends "home/index.html.twig" %}

{% block title %}Details de {{ fidele.nomfidele}}
{% endblock %}

{% block body %}




    <div class="container-fluid">
        <table class="table" border="1">

            <thead>

            </thead>
            <tbody>
                <tr class="btn-success">

            <b><td>Code</td>
                <td>Catégorie</td>
                <td>Nom & prénoms</td>
                <td>Contact</td>
                <td>Whatssap</td>
                <td>email</td>
                <td>Genre</td>
                </tr>
                <tr>

                    <td>{{ fidele.code |upper}}</td>
                    <td>{% set typefidele = fidele.typefidele %}
                        {% if  typefidele == 'Oui' %}
                            Fidèle
                        {% else %}

                            Serviteur
                        {% endif %}

                    </td>
                    <td>{{ fidele.nomfidele|upper}}</td>
                    <td>{{ fidele.contact1}}</td>
                    <td>{{ fidele.contactwhatssap}}</td>
                    <td>{{ fidele.email}}</td>
                    <td>{{ fidele.sexe}}</td>

                </tr>   
                <tr class="btn-success">

                    <td>Né(e) le</td>
                    <td>Nbre. Enfants</td>
                    <td>Statut matri.</td>
                    <td>Type Pièce</td>
                    <td>N° pièce</td>
                    <td>Domaie d'activité</td>
                    <td>Profession</td>
                </tr>
                <tr>
                    <td>{{ fidele.datenaiss|date(' d-m-Y')}}</td>
                    <td>{{ fidele.nbrenfant}}</td>
                    <td>{{ fidele.statutmatri}}</td>
                    <td>{{ fidele.typepiece}}</td>
                    <td>{{ fidele.numpiece}}</td>
                    <td>{{ fidele.domaineactivite}}</td>
                    <td>{{ fidele.profession }}</td>

                </tr>


                <tr class="btn-success">
                    <td>Nationalité</td>
                    <td>Commune</td>
                    <td>Date enreg.</td>
                    <td>Enregistré par</td>
                    <td>Facebook</td>
                    <td>Famille Eglise</td>
                    <td>Zone</td>

                </tr>

                <tr>
                    <td> {% if  fidele.nationalite is not null %} {{ fidele.nationalite|country_name}} {% else %} {% endif %}</td>
                    <td> {% if fidele.quartier is not null %} {{ fidele.quartier.commune.nom|upper}} {% else %} {% endif %}</td>
                    <td>{{ fidele.createAt|date(' d-m-Y à H:i:s ')}}</td>
                    <td>{% if  fidele.createdBy is not null %} {{ fidele.createdBy.nomuser}}  {{ fidele.createdBy.prenom}}{% else %} {% endif %}</td>
                    <td>{{ fidele.comptefacebook}}</td>
                    <td>{% if  fidele.famille is not null %}{{ fidele.famille.nom}}{% else %} {% endif %}</td>
                    <td>{% if  fidele.zone is not null %}{{ fidele.zone.nom}}{% else %} {% endif %}</td>

                </tr>



                <tr class="btn-success">
                    <td>Groupe sanguin</td>
                    <td>Statut baptème</td>
                    <td>Date de baptème</td>
                    <td>Fonction Eglise</td>
                    <td>Ethnie</td>
                    <td>Cellule</td>
                    <td>Quartier</td>

                </tr>

                <tr>
                    <td>{{ fidele.groupesang}}</td>
                    <td> {% set stutbapteme= fidele.stutbapteme %}
                        {% set sexe= fidele.sexe %}

                        {% if stutbapteme == 'Oui' and sexe == 'Homme' %}
                            Baptisé
                        {% elseif stutbapteme == 'Non' and sexe == 'Homme' %}
                            Non baptisé
                        {% elseif stutbapteme == 'Oui' and sexe == 'Femme' %}
                            Baptisée
                        {% else %}
                            Non Baptisée
                        {% endif %}


                    </td>
                    <td>{% if fidele.datebapteme is not null %}{{ fidele.datebapteme|date('d-m-Y')}}{% else %} {% endif %}</td>
                    <td>{% if fidele.fonction is not null %}{{ fidele.fonction.libelle}}{% else %} {% endif %}</td>
                    <td> {% if fidele.ethnie is not null %}  {{ fidele.ethnie.libelle}} {% else %} {% endif %}</td>
                    <td> {% if fidele.cellule is not null  %} {{ fidele.cellule.nom}} {% else %} {% endif %}</td>
                    <td>{% if fidele.quartier is not null %} {{ fidele.quartier.libelle }}{% else %} {% endif %}</td>


                </tr>

                <tr class="btn-success">

                    <td>Lieu baptème</td>
                    <td>Pasteur officient</td>
                    <td>Ancienne communauté</td>
                    <td>Année de conversion</td>
                    <td>Date d'arrivée dans la communauté</td>
                    <td>Age</td>
                    <td>Maladie</td>
                </tr>
                <tr>
                    <td>{{ fidele.lieubapteme }}</td>
                    <td>{{ fidele.pasteurbapteme}}</td>
                    <td>{{ fidele.anciennecommunaute}}</td>
                    <td>{{ fidele.dateconversion|date('Y')}}</td>
                    <td>{{ fidele.datearriver|date('d-m-Y')}}</td>
                    <td>

                        {% set naissance = fidele.datenaiss|date('Y') %}
                        {% set today = "now"|date('Y') %}
                        {% set difference = today - naissance %}

                        {{ difference }}

                    </td>
                    <td>{{ fidele.maladie }}</td>

                </tr>


                <tr class="btn-success">

                    <td>Date mariage</td>
                    <td>Pasteur officient</td>
                    <td>Lieu du mariage</td>
                    <td>Nom conjoint(e)</td>
                    <td>N° en cas d'urgence</td>
                    <td>Niveau d'étude</td>
                    <td>Visualiser la photo</td>
                </tr>
                <tr>

                    <td>{% if fidele.datemariage is not null %}{{ fidele.datemariage|date('d-m-Y')}}{% else %} {% endif %}</td>

                    <td>{{ fidele.pasteurmariage}}</td>
                    <td>{{ fidele.lieumariage}}</td>
                    <td>{{ fidele.nommariage}}</td>
                    <td>{{ fidele.urgence}}</td>
                    <td>{{ fidele.etude}}</td>
                    
                    <td>  {% if fidele.photoFile is not empty %} <a href="{{ asset('uploads/photos/' ~ fidele.photoFile) }}">Voir photo</a> {% else %} Photo indisponible {% endif %}</td>

              
                </tr>



                </tbody>

                <tr>
                    <td>
                        <a href='{{ path('fidele') }}'>
                            <button class="btn btn-success">Retour à la liste</button>
                        </a>
                    </td>

                    <td>
                        <a href="{{ path('fidele_update', {'id': fidele.id}) }}">
                            <span style="font-size: 1em; color: Dodgerblue;">
                                <i class="fas fa-edit" title="Mettre à jour"></i>
                            </span>
                        </a>
                    </td>



                    <td>
                        <form method="post" action="{{ path('fidele_delete', {'id': fidele.id}) }}" onsubmit="return confirm('etes vous sur de vouloir supprimer?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ fidele.id) }}">
                            <button class="btn">
                                <span style="font-size: 1em; color: red;">
                                    <i class="fas fa-trash-alt"></i>
                                </span>
                            </button>
                        </form>
                    </td>

                    <td>
                        <a href="{{ path('fidele_printbyid', {'id': fidele.id}) }}">
                            <span style="font-size: 1em; color: Dodgerblue;">
                                <i class="fa fa-print" title="Imprimer la fiche"></i>
                            </span>
                        </a>
                    </td>


                </tr>

        </table>
    </div>
{% endblock %}
