{% extends "home/index.html.twig" %}

{% block title %}Archive fideles{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }
        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>


    <section class="content">
        <div class="container-fluid">
            <div class="row">

                <!-- /.card-header -->
                <div class="card-body">

                    <a href='{{ path('fidele_print') }}'>
                        <button class="btn btn-primary">Imprimer</button>
                    </a>
                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Fidèle</th>
                                <th>Quartier</th>
                                <th>Teléphone</th>
                                <th>Baptisé(e)</th>
                                <th>Photo</th>
                                <th>Date de suppression</th>
                                <th>Suppression par</th>

                                <th>Restaurer</th>


                            </tr>
                        </thead>
                        <tbody>
                            {% for fidele in fidele %}
                                <tr>
                                    <td>{{ fidele.code}}</td>
                                    <td>{{ fidele.nomfidele|upper}}</td>
                                    <td>{{ fidele.quartier.nom}}</td>
                                    <td>{{ fidele.contact1}}</td>
                                    <td> {% set stutbapteme= fidele.stutbapteme %}
                                        {% if stutbapteme == 1 %}
                                            Baptisé(e)
                                        {% else %}
                                            Non baptisé()
                                        {% endif %}


                                    </td>
                                    <td>{{ fidele.createdBy.nomuser}}</td>

                                    <td>
                                        <img src="{{ asset('uploads/photos/'~fidele.photo_file)}}"  class="img-size-50 mr-3 img-suqare"/>                                               

                                    <td>{{ fidele.updateAt|date('d-m-YYYY')}}</td>


                                    <td>
                                        <a href="{{ path('fidele_detail', {'id': fidele.id}) }}">
                                            <span style="font-size: 1em; color: Dodgerblue;">
                                                <i class="fas fa-address-card"></i>
                                            </span>
                                        </a>
                                    </td>



                                    <td>

                                        <form method="post" action="{{ path('fidele_restaure', {'id': fidele.id}) }}" onsubmit="return confirm('Voulez-vous restaurer ce fidèle ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('restaurefi' ~ fidele.id) }}">
                                            <button class="btn">
                                                <span style="font-size: 1em; color: red;">
                                                    <i class="fas fa-trash-alt" title="Restaurer"></i>
                                                </span>
                                            </button>
                                        </form>

                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5">aucune donnée trouvée</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>


        </div>
    </section>


{% endblock %}
