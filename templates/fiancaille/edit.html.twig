{% extends "home/index.html.twig" %}

{% block title %}Fiançailles{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion de couple</h3>
        </div>
        {{ form_start(form) }}
        {{ form_errors(form) }}
        {% for message in app.flashes('success') %}
            <div class="primary">
                {{ message }}
            </div>
        {% endfor %}
        <div class="card card-body">
            <div class="row">

                <div class="col-md-4">
                    {{ form_row(form.fiance, {'label':'Fiancé externe', 'class': 'foo'}) }}
                </div>


                <div class="col-md-4">
                    {{ form_row(form.fiancemembre, {'label':' Choix du fiancé membre ', 'class': 'foo'})}}
                </div>
            </div>
            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.fiancee, {'label':'Fiancée externe', 'class': 'foo'}) }}
                </div>


                <div class="col-md-4">
                    {{ form_row(form.fianceemembre, {'label':' Choix de la fiancée membre ', 'class': 'foo'})}}
                </div>
            </div>
            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.datefiancaille, {'label':' Date fiançaille'})}}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.pasteurfiancaille, {'label':' Pasteur officiant ', 'class': 'foo'})}}
                </div>
            </div>



            <div class="row">
                <p><div class="btn btn-default">{{ form_row(form.save, {'label':'Modifier ','attr':{'value':'save'}}) }}</div></p>
                <div class="btn btn-default" style="display: none"> {{ form_row(form.saveAndAdd, {'label':'Enregistrer et continuer ','attr':{'value':'save-and-add'}}) }} </div>

                <div class="btn btn-default"><a href="{{ path('fiancaille_index') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div>
        </div>

        <div>
            {{ form_rest(form) }}
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
