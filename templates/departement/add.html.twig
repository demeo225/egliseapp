
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion de Departement</h3>
        </div>
        <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        <div class="card card-body">

        {{ form_start(form, {'attr': {'action': path('departement_add')} }) }}
             <div class="row mb-4">

                
                    <div class="col-md-3">
                    {{ form_row(form.nom, {'libelle':'Depaartement ', 'attr':{'class':'form-control'}}) }}
                </div>
                    <div class="col-md-3">
                    {{ form_row(form.description, {'libelle':'Description ', 'attr':{'class':'form-control'}}) }}
                </div>
                
                    <div class="col-md-3">
                    {{ form_row(form.responsable1, {'libelle':'Responsable ', 'attr':{'class':'form-control'}}) }}
                </div>
                    <div class="col-md-3">
                    {{ form_row(form.responsable2, {'libelle':'Responsable nd. ', 'attr':{'class':'form-control'}}) }}
                </div>
                
         

            </div>
         
            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

                <div class="col-md-2.5" style="display: none"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

            </div> 
        
            {{ form_end(form) }}
        </div>
    </div>

