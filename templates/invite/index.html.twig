{% extends "home/index.html.twig" %}

{% block title %}Gestions des Invités{% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des invités</h3>
        </div>
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
  </div>
        <!-- /.card-header -->
        <div class="car card-body">
            <a href='{{ path('invite_add') }}'>
                <button class="btn btn-primary">Nouveau</button>
            </a>


            <hr style="visibility: hidden" />  
            <table id="example1" class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>Invite</th>
                        <th>Numéro</th>
                        <th>Genre</th>
                        <th>Culte</th>
                        <th>Detail</th>
                        <th>Modifier</th>
                        <th>Supprimer</th>
                    </tr>
                </thead>
                <tbody>
                    {% for invite in invite %}
                        <tr>
                            <td>{{ invite.nom}}</td>
                            <td>{{ invite.contact}}</td>
                            <td>{{ invite.sexe}}</td>
                            <td> {% if invite.culte is not empty %} {{ date_format(invite.culte.dateculte)}} {% else %} {% endif %}</td>
                            <td>
                                <a href="{{ path('invite_detail', {'id': invite.id}) }}">
                                    <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-list" title="Details"></i></a>
                                    </span>
                                </a>
                            </td>
                            <td>
                                <a href="{{ path('invite_update', {'id': invite.id}) }}">
                                    <span style="font-size: 1em; color: Dodgerblue;">
                                        <i class="fas fa-edit"></i>
                                    </span>
                                </a>
                            </td>
                            <td>
                                <form method="post" action="{{ path('invite_delete', {'id': invite.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ invite.id) }}">
                                    <button class="btn">
                                        <span style="font-size: 1em; color: red;">
                                            <i class="fas fa-trash-alt"></i>
                                        </span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                 
                   
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>




{% endblock %}


