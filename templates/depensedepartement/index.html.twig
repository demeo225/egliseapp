{% extends "home/index.html.twig" %}

{% block title %}Depenses departement index{% endblock %}

{% block body %}
    <!-- /.card-header -->
    <div class="card-body">




        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Depense des Departements</h3>
            </div>
<div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

            {% if is_granted('ROLE_RESPONSABLE_DEPARTEMENT') %}
                <div class="card-body">
                    <a href='{{ path('app_depensedepartement_new') }}'>
                        <button class="btn btn-primary">Nouveau</button>
                    </a>
                    <a href='{{ path('cotisationdepartement_index') }}'>
                        <button class="btn btn-success">Cotisations </button>
                    </a>

                    <a href={{ path('cotiserdepartement_index') }}>
                        <button class="btn btn-success">Paiements de cotisation</button>
                    </a>

                    <a href={{ path('seancedepartement_listeparticipant') }}>
                        <button class="btn btn-success">Liste de présence</button>

                    </a>
                {% endif %} 

                <b>Solde</b>
                <button class="btn btn-info">
                    {% for solde in soldes %}
                        {{ solde.montant|number_format(0, '.', ' ') }}
                    {% endfor %}
                </button>
                <hr style="visibility: hidden" />
                <table id="example1" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Departement</th>
                            <th>Date</th>
                            <th>Objet</th>
                            <th>Montant</th>

                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for depensedepartement in depensedepartements %}
                            <tr>
                                <td> {% if depensedepartement.departement is not empty %}  {{ depensedepartement.departement.nom }} {% else %} {% endif %}</td>
                                <td>{{ depensedepartement.datedepense ? depensedepartement.datedepense|date('d-m-Y') : '' }}</td>
                                <td>{{ depensedepartement.objet }}</td>
                                <td>{{ depensedepartement.montant|number_format(0, '.', ' ')  }}</td>

                                <td>
                                    <a href="{{ path('app_depensedepartement_show', {'id': depensedepartement.id}) }}">      <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-list" title="Details"></i>
                                        </span></a>
                                    <a href="{{ path('app_depensedepartement_edit', {'id': depensedepartement.id}) }}">          <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-edit" title="Modification"></i>
                                        </span></a>
                                </td>
                            </tr>
                      

                        {% endfor %}
                    </tbody>
                </table>

            </div>
        </div>
    {% endblock %}
