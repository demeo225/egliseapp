{% extends "home/index.html.twig" %}

{% block title %}Présences & absences{% endblock %}

{% block body %}
<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Gestion présence de : {{ cellule.nom|upper }}</h3>
    </div>
    
    <div class="card card-body">
        <form action="{{ path('seancecellule_presence') }}" method="post" id="presenceForm">
            <div class="row">
                <div class="col-md-4">
                    <label for="seancecellule">Sélectionnez la séance <span class="text-danger">*</span></label>
                    <select name="seancecellule" id="seancecellule" class="select2" required>
                        <option value="">-- Choisir une séance --</option>
                        {% for seance in seancecellules %}
                            <option value="{{ seance.id }}">
                                {{ seance.datesuper|date('d-m-Y') }} - {{ seance.theme }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                
                {% if seancecellules|length == 0 %}
                <div class="col-md-12">
                    <div class="alert alert-warning mt-3">
                        Aucune séance disponible pour cette cellule. Veuillez d'abord créer une séance.
                    </div>
                </div>
                {% endif %}
            </div>

            <hr/>

            <div class="table-responsive">
                <table id="example1" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th width="50">
                                <input type="checkbox" id="checkAll" title="Tout cocher/Décocher">
                            </th>
                            <th>Fidèle</th>
                            <th>Contact</th>
                            <th>Cellule</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody id="fidele-table-body">
                        {% for fidele in fideles %}
                            <tr class="fidele-row" data-fidele-id="{{ fidele.id }}">
                                <td class="text-center">
                                    <input type="checkbox" name="tab[]" class="fidele-checkbox" value="{{ fidele.id }}" title="Présent(e)">
                                </td>
                                <td>{{ fidele.nomfidele|upper }}</td>
                                <td>
                                    {% if fidele.contactwhatssap is not empty %}
                                        {{ fidele.contactwhatssap }}
                                    {% else %}
                                        {{ fidele.contact1 }}
                                    {% endif %}
                                </td>
                                <td>
                                    {% if fidele.cellule is not null %}
                                        {{ fidele.cellule.nom|upper }}
                                    {% else %}
                                        <span class="badge badge-warning">Non assigné</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="status-badge badge badge-secondary">Non vérifié</span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            <div class="mt-3">
                <button type="submit" class="btn btn-primary" {% if seancecellules|length == 0 %}disabled{% endif %}>
                    <i class="fas fa-save"></i> {{ button_label|default('Valider') }}
                </button>
                <a href="{{ path('seancecellule_listeparticipant') }}" class="btn btn-success">
                    <i class="fas fa-list"></i> Liste de présence
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function() {
        // Variable pour stocker l'état des présences
        var presencesData = {};
        
        // Gestion du checkbox "Tout cocher"
        $('#checkAll').on('change', function() {
            $('.fidele-checkbox:not(:disabled)').prop('checked', $(this).prop('checked'));
        });
        
        // Si un checkbox est décoché, décocher "Tout cocher"
        $(document).on('change', '.fidele-checkbox', function() {
            if ($('.fidele-checkbox:checked:not(:disabled)').length == $('.fidele-checkbox:not(:disabled)').length) {
                $('#checkAll').prop('checked', true);
            } else {
                $('#checkAll').prop('checked', false);
            }
        });
        
        // Chargement des présences quand la séance change
        $('#seancecellule').on('change', function() {
            var seanceId = $(this).val();
            
            if (!seanceId) {
                // Réinitialiser l'affichage
                $('.fidele-checkbox').prop('disabled', false).prop('checked', false);
                $('.fidele-row').removeClass('table-success');
                $('.status-badge').removeClass('badge-success').addClass('badge-secondary').text('Non vérifié');
                $('#checkAll').prop('checked', false);
                return;
            }
            
            // Afficher un indicateur de chargement
            $('.status-badge').removeClass('badge-secondary').addClass('badge-info').text('Chargement...');
            
            // Requête AJAX
            $.ajax({
                url: '{{ path("seancecellule_get_presences") }}',
                type: 'POST',
                data: { seanceId: seanceId },
                dataType: 'json',
                success: function(response) {
                    if (response.success) {
                        presencesData = response;
                        
                        // Mettre à jour les checkboxes
                        $('.fidele-checkbox').each(function() {
                            var fideleId = parseInt($(this).val());
                            var $row = $(this).closest('.fidele-row');
                            var $statusBadge = $row.find('.status-badge');
                            
                            if (response.presences.includes(fideleId)) {
                                $(this).prop('disabled', true).prop('checked', true);
                                $row.addClass('table-success');
                                $statusBadge.removeClass('badge-secondary badge-info').addClass('badge-success').text('Déjà présent');
                            } else {
                                $(this).prop('disabled', false).prop('checked', false);
                                $row.removeClass('table-success');
                                $statusBadge.removeClass('badge-success badge-info').addClass('badge-secondary').text('Non présent');
                            }
                        });
                        
                        // Décocher le checkbox "Tout cocher"
                        $('#checkAll').prop('checked', false);
                        
                        // Afficher un message avec les infos de la séance
                        console.log('Séance chargée: ' + response.seanceDate + ' - ' + response.seanceTheme);
                        
                    } else {
                        console.error('Erreur:', response.error);
                        $('.status-badge').removeClass('badge-info').addClass('badge-danger').text('Erreur');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Erreur AJAX:', error);
                    $('.status-badge').removeClass('badge-info').addClass('badge-danger').text('Erreur chargement');
                }
            });
        });
        
        // Validation avant soumission
        $('#presenceForm').on('submit', function(e) {
            var seancecellule = $('#seancecellule').val();
            var checked = $('.fidele-checkbox:checked:not(:disabled)').length;
            
            if (!seancecellule) {
                e.preventDefault();
                alert('Veuillez sélectionner une séance.');
                return false;
            }
            
            if (checked === 0) {
                e.preventDefault();
                alert('Veuillez sélectionner au moins un fidèle présent.');
                return false;
            }
            
            return true;
        });
        
        // Déclencher le changement de séance si une séance est déjà sélectionnée
        if ($('#seancecellule').val()) {
            $('#seancecellule').trigger('change');
        }
    });
</script> 
{% endblock %}