


<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Enregistrement des ethnies</h3>
    </div>
    <div class="card card-body">


        {{ form_start(form, {'attr': {'action': path('ethnie_add')} }) }}
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        <div class="row mb-4">

            <div class="col-md-3">
                {{ form_row(form.libelle, {'libelle':'Ethnie ', 'attr':{'class':'form-control'}}) }}

            </div>


        </div>

        <div class="row"> 
            <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

            <div class="col-md-2" style="display: none"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

        </div> 
        <div>
            {{ form_rest(form) }}
        </div>
        {{ form_end(form) }}
    </div>
</div>
</div>

