{% extends 'base.html.twig' %}

{% block title %}Charge{% endblock %}

{% block body %}
    <h1>Charge</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ charge.id }}</td>
            </tr>
            <tr>
                <th>Montant</th>
                <td>{{ charge.montant }}</td>
            </tr>
            <tr>
                <th>Detail</th>
                <td>{{ charge.detail }}</td>
            </tr>
            <tr>
                <th>Datecharge</th>
                <td>{{ charge.datecharge ? charge.datecharge|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Ideglise</th>
                <td>{{ charge.ideglise }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_charge_index') }}">back to list</a>

    <a href="{{ path('app_charge_edit', {'id': charge.id}) }}">edit</a>

    {{ include('charge/_delete_form.html.twig') }}
{% endblock %}
