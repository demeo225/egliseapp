  <div class="card card-body">


            {{ form_start(form) }}
                  <div class="offset-1 col-md-10 mt-2 mb-2">
                {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} my-alert" role="alert">
                            <h5 class="m-0 flash-text">{{ message }}</h5>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.datecharge, {'label':'Date '}) }}
                </div>
                  <div class="col-md-4">
                    {{ form_row(form.objetcharge, {'label':'Objet '}) }}
                </div>
                  <div class="col-md-4">
                    {{ form_row(form.departement, {'label':'Departement '}) }}
                </div>
                      <div class="col-md-4">
                    {{ form_row(form.detail, {'label':'Detail  '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.montant, {'label':'Montant '}) }}
                </div>
            
            </div>
           
            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>
                <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>
                <div class="col-md-2"><a href="{{ path('app_charge_index') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 

            {{ form_end(form) }}
        </div>
