  <script>
                                                    // À ajouter dans votre fichier JavaScript principal ou dans la balise <script>
                document.addEventListener('DOMContentLoaded', function() {
                    // Sélectionner tous les messages flash
                    const flashMessages = document.querySelectorAll('.my-alert');
                    
                    flashMessages.forEach(function(message) {
                        // Durée d'affichage en millisecondes (5 secondes)
                        const duration = 5000;
                        
                        // Timer pour faire disparaître le message
                        setTimeout(function() {
                            // Ajouter une classe pour l'animation de disparition
                            message.style.transition = 'opacity 0.5s ease';
                            message.style.opacity = '0';
                            
                            // Supprimer l'élément après l'animation
                            setTimeout(function() {
                                message.remove();
                            }, 500);
                        }, duration);
                        
                        // Permettre de fermer manuellement avec un clic
                        message.style.cursor = 'pointer';
                        message.addEventListener('click', function() {
                            message.style.transition = 'opacity 0.3s ease';
                            message.style.opacity = '0';
                            setTimeout(function() {
                                message.remove();
                            }, 300);
                        });
                    });
                });
            </script>
