{% extends "home/index.html.twig" %}

{% block title %}Bilan des depenses {% endblock %}

{% block body %}

    <div class="card card-body">
        <form action="{{ path('app_bilan_operationn') }}" method="POST" >

            <div class="card card-success">
                <div class="card-header">
                    <h3 class="card-title">Critères</h3>
                </div>
                <div class="row">

                    <div class="col-md-3">
                        {{ form_row(form_recherche.objet , {'label':'Nature operation'}) }}
                    </div>
                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateDebut, {'label':'Date debut'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateFin , {'label':'Date fin'}) }}
                    </div>
                </div>

                <div class="col-md-4">
                    <input type="submit" value="Rechercher">
                </div>


            </div>    
    </div>
</form>    
</div> 

<div class="rows">
    {% if app.request.method == 'POST' and operations |length==0 %}
        Aucune depense trouvée

    {% else %}

        {% if operations |length >0 %}
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">Resultats de la recherche</h3>
                </div>

                <div style="align-content: center">
                    {% for operation in operations %}
                        {% set seance = operations|length %}
                        {% set sum = operation.montant + sum ?? 0 %}
                        {% if loop.last  %}
                            Moyenne:  <b> {{ (sum/seance)|number_format(0, '.', ' ') }} F CFA </b> par séance <br />

                            Montant total :  <b> {{ sum|number_format(0, '.', ' ')}}F CFA -- {{ sum|format_number(style='spellout')}} F CFA</b>  {% endif %}
                            {% endfor %}
                            </div>
                            <hr style="visibility: hidden" /> 
                            <div class="card-body">

                                <table id="example1" class="table table-bordered table-striped">

                                    <thead>
                                        <tr>
                                            <th>Region</th>
                                            <th>Region pastorale</th>
                                            <th>Eglise</th>
                                            <th>Date </th>
                                            <th>Objet</th>
                                            <th>Montant</th>


                                        </tr>
                                    </thead>

                                    <tbody>
                                        {% for operation in operations %}

                                            <tr>
                                                <td> {% if operation.eglise.region is not empty %} {{ operation.eglise.region }}{% else %} Non rensigné {% endif %}</td>
                                                <td> {% if operation.eglise.regionpastorale is not empty %} {{ operation.eglise.regionpastorale }}{% else %} Non renseignée {% endif %}</td>
                                                <td> {% if operation.eglise is not empty %} {{ operation.eglise }}{% else %} {% endif %}</td>

                                                <td>{{ date_format(operation.dateop) }}</td>

                                                <td>{{ operation.objet }}</td>


                                                <td>{{ operation.montant|number_format(0, '.', ' ')  }}</td>


                                            </tr>


                                        {% endfor %}


                                    </tbody>
                                </table>
                            </div>
                            {% endif %}
                                {% endif %}

                                    {% endblock %}

