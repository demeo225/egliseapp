{% extends "home/index.html.twig" %}

{% block title %}Bilan des offrandes {% endblock %}

{% block body %}

    <div class="card card-body">
        <form action="{{ path('app_bilan_offranden') }}" method="POST" >

            <div class="card card-success">
                <div class="card-header">
                    <h3 class="card-title">Critères</h3>
                </div>
                <div class="row">


                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateDebut, {'label':'Date debut'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateFin , {'label':'Date fin'}) }}
                    </div>
                </div>

                <div class="col-md-4">
                    <input type="submit" value="Rechercher">
                </div>


            </div>    


        </form>    
    </div> 

    <div class="rows">
        {% if app.request.method == 'POST' and offrandes |length==0 %}
            Aucune donnée trouvée

        {% else %}

            {% if offrandes |length >0 %}
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Resultats de la recherche</h3>
                    </div>
                    <div style="align-content: center">
                        {% for offrande in offrandes %}
                            {% set seance = offrandes|length %}
                            {% set sum = offrande.montant + sum ?? 0 %}
                            {% if loop.last  %}
                                Moyenne:  <b> {{ (sum/seance)|number_format(0, '.', ' ') }} F CFA </b> par séance <br />
                                Montant total :  <b> {{ sum|number_format(0, '.', ' ')}}F CFA -- {{ sum|format_number(style='spellout')}} C CFA</b>  {% endif %}
                                {% endfor %}
                                </div>

                                <hr style="visibility: hidden" /> 
                                <div class="card-body">

                                    <table id="example1" class="table table-bordered table-striped">

                                        <thead>
                                            <tr>
                                                <th>Region</th>
                                                <th>Region pastorale</th>
                                                <th>Eglise</th>
                                                <th>Date </th>
                                                <th>Montant</th>


                                            </tr>
                                        </thead>

                                        <tbody>
                                            {% for offrande in offrandes %}

                                                <tr>
                                                    <td> {% if offrande.eglise.region is not empty %} {{ offrande.eglise.region }}{% else %} Non rensigné {% endif %}</td>
                                                    <td> {% if offrande.eglise.regionpastorale is not empty %} {{ offrande.eglise.regionpastorale }}{% else %} Non renseignée {% endif %}</td>
                                                    <td> {% if offrande.eglise is not empty %} {{ offrande.eglise }}{% else %} {% endif %}</td>

                                                    <td>{{ date_format(offrande.dateoff) }}</td>

                                                    <td>{{ offrande.montant|number_format(0, '.', ' ')  }}</td>


                                                </tr>


                                            {% endfor %}


                                        </tbody>
                                    </table>
                                </div>
                                {% endif %}
                                    {% endif %}

                                        {% endblock %}

