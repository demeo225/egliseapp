{% extends "home/index.html.twig" %}

{% block title %}Bilan global departements {% endblock %}

{% block body %}

    <div class="card card-body">
        <form action="{{ path('app_bilan_activite') }}" method="POST" >

            <div class="card card-success">
                <div class="card-header">
                    <h3 class="card-title">Critères</h3>
                </div>
                <div class="row">


                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateDebut, {'label':'Date debut'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateFin , {'label':'Date fin'}) }}
                    </div>
                </div>

                <div class="row">
                    <br />
                    <div class="col-md-4">
                        <input type="submit" value="Rechercher">
                    </div>

                </div>    
            </div>
        </form>    
    </div> 

    <div class="rows">
        {% if app.request.method == 'POST' and seancecellules |length==0 %}
            Aucune activité de cellule

        {% else %}

            {% if seancecellules |length >0 %}
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Bilan cellules</h3>
                    </div>


                    <div style="align-content: center">
                        {% for seancecellule in seancecellules %}
                            {% set seance = (seancecellule|length)  + seance ?? 0 %}
                            {% set nmbreseance = seance / 10 %}
                            {% set sum = seancecellule.offrande + sum ?? 0 %}
                            {% if loop.last  %} Total offrandes: <b> {{ sum|number_format(0, '.', ' ')}}F CFA -- {{ sum|format_number(style='spellout')}} F CFA</b><br />
                            {% endif %}  

                            {% set total = seancecellule.nbrepresent + seancecellule.femme + seancecellule.enfant + total ?? 0 %}
                            {% if loop.last  %}

                                {% set moyene1 = total / nmbreseance  %}
                                Nombre de séances:   {{ nmbreseance }} <br />

                                Moyenne de présence :<b> {{ moyene1|number_format() }}</b> Personne(s) par séance

                            {% endif %}
                        {% endfor %}
                    </div>

                   
                    <div class="card-body">

                        <table id="example1" class="table table-bordered table-striped">

                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Cellule</th>
                                    <th>Lieu</th>
                                    <th>Offrande</th>
                                    <th>Total présents</th>
                                    <th>Invités</th>
                                    <th>Detail</th>

                                </tr>
                            </thead>

                            <tbody>

                                {% for diff in differencecs %}


                                    {% for seancecellule in seancecellules %}
                                        {% if diff.datesuper ==  seancecellule.datesuper %}
                                            {% if is_granted("seancecellule_edit", seancecellule) %}
                                                <tr>
                                                    <td>{{ date_format(seancecellule.datesuper) }}</td>
                                                    <td>{{ seancecellule.cellule.nom }}</td>
                                                    <td>{{ seancecellule.lieu }}</td>
                                                    <td>{{ seancecellule.offrande }}</td>
                                                    <td>
                                                        {% set nbrepresent =seancecellule.nbrepresent %}
                                                        {% set femme =seancecellule.femme %}
                                                        {% set enfant =seancecellule.enfant %}
                                                        {% set total = enfant +nbrepresent + femme %}


                                                        {{ total }}


                                                    </td>
                                                    <td>   
                                                        <button type="button" id="btn-fideles-modal" data-target="{{ path('seancecellule_search_invitecellules', {'id':seancecellule.id}) }}"> 
                                                            <span style="font-size: 1em; color: Dodgerblue;">
                                                                <i class="fas fa-users" title="Voir invités"></i>
                                                            </span>
                                                        </button>

                                                    </td>


                                                    <td>
                                                        <a href="{{ path('seancecellule_show', {'id': seancecellule.id}) }}"> <i class="fas fa-list" title="Details "></i></a>
                                                    </td>

                                                </tr>
                                            {% endif %}
                                        {% endif %}

                                    {% endfor %}

                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            {% endif %}
        </div>
    </div>


