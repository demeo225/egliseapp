{% extends "home/index.html.twig" %}

{% block title %}Bilan complet des groupes{% endblock %}

{% block body %}
<div class="card card-body">
    {{ form_start(form_recherche, {'action': path('app_bilan_groupe'), 'method': 'POST'}) }}
        
        <div class="card card-success">
            <div class="card-header">
                <h3 class="card-title">Critères de recherche</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        {{ form_row(form_recherche.groupe, {'label': 'Groupe'}) }}
                    </div>
                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateDebut, {'label': 'Date début'}) }}
                    </div>
                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateFin, {'label': 'Date fin'}) }}
                    </div>
                    <div class="col-md-2">
                        {{ form_row(form_recherche.rechercher) }}
                    </div>
                </div>
            </div>
        </div>
        
    {{ form_end(form_recherche) }}
</div>

{# Récapitulatif financier global #}
{% if bilanComplet is defined and bilanComplet is not null and not bilanComplet.isEmpty %}
<div class="row mt-3">
    <div class="col-md-12">
        <div class="card card-dark">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-pie"></i> Récapitulatif financier
                </h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <div class="small-box bg-success">
                            <div class="inner">
                                <h3>{{ bilanComplet.bilanCotisations ? bilanComplet.bilanCotisations.totalMontantPayes|number_format(0, ',', ' ') }} FCFA</h3>
                                <p>Total des cotisations perçues</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-hand-holding-usd"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="small-box bg-danger">
                            <div class="inner">
                                <h3>{{ bilanComplet.totalMontantDepenses|default(0)|number_format(0, ',', ' ') }} FCFA</h3>
                                <p>Total des dépenses</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="small-box bg-info">
                            <div class="inner">
                                {% set solde = (bilanComplet.bilanCotisations ? bilanComplet.bilanCotisations.totalMontantPayes : 0) - (bilanComplet.totalMontantDepenses|default(0)) %}
                                <h3>{{ solde|number_format(0, ',', ' ') }} FCFA</h3>
                                <p>Solde disponible</p>
                            </div>
                            <div class="icon">
                                <i class="fas fa-chart-line"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ==================== SECTION ACTIVITÉS ==================== #}
{% if bilanComplet.hasActivites %}
<div class="card card-primary mt-3">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-calendar-alt"></i> Activités des groupes
        </h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Groupe</th>
                        <th>Lieu</th>
                        <th>Offrande</th>
                        <th>Total participants</th>
                    </tr>
                </thead>
                <tbody>
                    {% for seance in bilanComplet.activites %}
                    <tr>
                        <td>{{ seance.datesuper|date('d/m/Y') }}</td>
                        <td>{{ seance.groupe ? seance.groupe.nom : '-' }}</td>
                        <td>{{ seance.lieu|default('-') }}</td>
                        <td class="text-right">{{ seance.offrande|number_format(0, ',', ' ') }} FCFA</td>
                        <td class="text-right">{{ seance.nbrepresent|default(0) + seance.femme|default(0) + seance.enfant|default(0) }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endif %}

{# ==================== SECTION PRÉSENCES ==================== #}
{% if bilanComplet.hasPresences %}
<div class="card card-warning mt-3">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-user-check"></i> Présences par groupe
        </h3>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-3">
                <div class="info-box bg-warning">
                    <div class="info-box-content">
                        <span class="info-box-text">Total présences</span>
                        <span class="info-box-number">{{ bilanComplet.bilanPresences.totalPresences|number_format }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="info-box bg-info">
                    <div class="info-box-content">
                        <span class="info-box-text">Fidèles distincts</span>
                        <span class="info-box-number">{{ bilanComplet.bilanPresences.fidelesDistincts|number_format }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="info-box bg-success">
                    <div class="info-box-content">
                        <span class="info-box-text">Moyenne/fidèle</span>
                        <span class="info-box-number">{{ bilanComplet.bilanPresences.moyennePresencesParFidele|number_format(1) }}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="info-box bg-primary">
                    <div class="info-box-content">
                        <span class="info-box-text">Séances concernées</span>
                        <span class="info-box-number">{{ bilanComplet.bilanPresences.seancesAvecPresences|number_format }}</span>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Fidèle</th>
                        <th>Groupe</th>
                        <th>Nombre présences</th>
                        <th>Dernière présence</th>
                    </tr>
                </thead>
                <tbody>
                    {% for fideleId, data in bilanComplet.bilanPresences.presencesGroupees %}
                    <tr>
                        <td>{{ data.fidele_nom }} {{ data.fidele_prenom }}</td>
                        <td>{{ data.groupe_nom ?? '-' }}</td>
                        <td class="text-center">{{ data.total_presences }}</td>
                        <td>{{ data.derniere_presence ? data.derniere_presence|date('d/m/Y') : '-' }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endif %}

{# ==================== SECTION COTISATIONS ==================== #}
{% if bilanComplet.hasCotisations %}
<div class="card card-success mt-3">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-hand-holding-usd"></i> Cotisations des groupes
        </h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Groupe</th>
                        <th>Objet</th>
                        <th>Montant prévu</th>
                        <th>Montant payé</th>
                        <th>Reste</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cotisation in bilanComplet.cotisations %}
                        {% set montantPaye = cotisation.montantPayeCalcule ?? 0 %}
                        {% set reste = cotisation.resteCalcule ?? cotisation.montant %}
                    <tr>
                        <td>{{ cotisation.createAt ? cotisation.createAt|date('d/m/Y') : '-' }}</td>
                        <td>{{ cotisation.groupe ? cotisation.groupe.nom : '-' }}</td>
                        <td>{{ cotisation.objet|default('-') }}</td>
                        <td class="text-right">{{ cotisation.montant|number_format(0, ',', ' ') }} FCFA</td>
                        <td class="text-right text-success">{{ montantPaye|number_format(0, ',', ' ') }} FCFA</td>
                        <td class="text-right">{{ reste|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="bg-light">
                        <th colspan="3" class="text-right">TOTAUX :</th>
                        <th class="text-right">{{ bilanComplet.bilanCotisations.totalMontantPrevus|number_format(0, ',', ' ') }} FCFA</th>
                        <th class="text-right">{{ bilanComplet.bilanCotisations.totalMontantPayes|number_format(0, ',', ' ') }} FCFA</th>
                        <th class="text-right">{{ bilanComplet.bilanCotisations.totalReste|number_format(0, ',', ' ') }} FCFA</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>
{% endif %}

{% elseif bilanComplet is defined and bilanComplet is not null and bilanComplet.isEmpty %}
<div class="alert alert-info mt-3">
    <i class="fas fa-info-circle"></i> Aucune donnée trouvée pour les critères sélectionnés.
</div>
{% endif %}
{% endblock %}