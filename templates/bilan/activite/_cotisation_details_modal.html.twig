{# _cotisation_details_modal.html.twig #}
<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5>{{ cotisation.objet }}</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <div class="info-box bg-info">
                                <div class="info-box-content">
                                    <span class="info-box-text">Montant prévu</span>
                                    <span class="info-box-number">{{ cotisation.montant|number_format(0, ',', ' ') }} FCFA</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-box bg-success">
                                <div class="info-box-content">
                                    <span class="info-box-text">Total payé</span>
                                    <span class="info-box-number">{{ totalPaye|number_format(0, ',', ' ') }} FCFA</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="info-box bg-warning">
                                <div class="info-box-content">
                                    <span class="info-box-text">Reste à payer</span>
                                    <span class="info-box-number">{{ reste|number_format(0, ',', ' ') }} FCFA</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <h6 class="mt-3">Détail des versements</h6>
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Fidèle</th>
                                <th>Montant payé</th>
                                <th>Reste après paiement</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for versement in versements %}
                                <tr>
                                    <td>{{ versement.datecotiser ? versement.datecotiser|date('d/m/Y') : '-' }}</td>
                                    <td>{{ versement.fidele ? versement.fidele.nomfidele ~ ' ' ~ versement.fidele.prenomfidele : '-' }}</td>
                                    <td class="text-success">{{ versement.montantpayer|number_format(0, ',', ' ') }} FCFA</td>
                                    <td>{{ versement.reste|number_format(0, ',', ' ') }} FCFA</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center">Aucun versement enregistré</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr class="bg-light">
                                <th colspan="2" class="text-right">TOTAL :</th>
                                <th class="text-success">{{ totalPaye|number_format(0, ',', ' ') }} FCFA</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>