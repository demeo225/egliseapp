{% extends "home/index.html.twig" %}

{% block title %}Bilan des patrimoines {% endblock %}

{% block body %}

    <div class="card card-body">
        <form action="{{ path('app_bilan_patrimoine') }}" method="POST" >

            <div class="card card-success">
                <div class="card-header">
                    <h3 class="card-title">Critères</h3>
                </div>
                <div class="row">

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateDebut, {'label':'Date debut'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateFin , {'label':'Date fin'}) }}
                    </div>
                </div>

                <div class="col-md-4">
                    <input type="submit" value="Rechercher">
                </div>


            </div>    


        </form>    
    </div> 

    <div class="rows">
        {% if app.request.method == 'POST' and patrimoines |length==0 %}
            Aucune donnée trouvée

        {% else %}

            {% if patrimoines |length >0 %}
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Resultats de la recherche</h3>
                    </div>
                    <div style="align-content: center">
                        <div style="align-content: center">
                            Montant depensé à cette periode:
                        </div>
                        <div class="btn btn-success">

                            {% for patrimoine in patrimoines %}
                                {% set quantite = patrimoine.quantite %}
                                {% set prixunitaire = patrimoine.prixunitaire %}
                                {% set montant = quantite * prixunitaire  %}
                                {% set sum = montant + sum ?? 0 %}
                                {% if loop.last  %} <b> {{ sum|number_format(0, '.', ' ')}}F CFA -- {{ sum|format_number(style='spellout')}} F CFA </b>  {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="card-body">

                        <table id="example1" class="table table-bordered table-striped">

                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Article</th>
                                    <th>Quantité</th>
                                    <th>Prix unitaire</th>
                                    <th>Prix total</th>
                                </tr>
                            </thead>

                            <tbody>
                                {% for patrimoine in patrimoines %}

                                    <tr>

                                        <td>{{ date_format(patrimoine.datepatrimoine)}}</td>
                                        <td>{{ patrimoine.article|upper}}</td>
                                        <td>{{ patrimoine.quantite}}</td>

                                        <td>{{ patrimoine.prixunitaire}}</td>
                                        <td>  {% set quantite = patrimoine.quantite %}
                                            {% set prixunitaire = patrimoine.prixunitaire %}
                                            {% set montant = quantite * prixunitaire  %}

                                            <b> {{ montant|number_format(0, '.', ' ') }}</b>

                                        </td>



                                    </tr>


                                {% endfor %}


                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endif %}

{% endblock %}

