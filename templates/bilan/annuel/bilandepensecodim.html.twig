{% extends "home/index.html.twig" %}

{% block title %}Bilan depense ECODIM {% endblock %}

{% block body %}

    <div class="card card-body">
        <form action="{{ path('app_bilan_depensecodim') }}" method="POST" >

            <div class="card card-success">
                <div class="card-header">
                    <h3 class="card-title">Critères</h3>
                </div>
                <div class="row">


                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateDebut, {'label':'Date debut'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateFin , {'label':'Date fin'}) }}
                    </div>
                </div>

                <div class="col-md-4">
                    <input type="submit" value="Rechercher">
                </div>


            </div>    
    </div>
</form>    
</div> 

<div class="rows">
    {% if app.request.method == 'POST' and depensecodims |length==0 %}
        Aucune donnée trouvée

    {% else %}

        {% if depensecodims |length >0 %}
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">Resultats de la recherche</h3>
                </div>

                <div  class="card-body">
                    {% for depensecodim in depensecodims %}
                        {% set sum = depensecodim.montant + sum ?? 0 %}


                        {% if loop.last  %}

                            Totale depense :  <b> {{ sum|number_format(0, '.', ' ')}}  -- {{ sum|format_number(style='spellout')}} F CFA</b>  {% endif %}
                            {% endfor %}
                            </div>

                            <hr style="visibility: hidden" /> 

                            <div class="card-body">

                                <table id="example1" class="table table-bordered table-striped">
                                    <thead>
                                        <tr>

                                            <th>Date</th>
                                            <th>Objet</th>
                                            <th>Montant</th>
                                            <th>Detail</th>

                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for depensecodim in depensecodims %}
                                            <tr>
                                                <td>{{ date_format(depensecodim.datedepense)}}</td>
                                                <td>{{ depensecodim.objet }}</td>
                                                <td>{{ depensecodim.montant|format_number }}</td>
                                                <td>{{ depensecodim.detail }}</td>

                                   
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="13">Aucune donnée</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        {% endif %}
                            {% endif %}
                            </div>



                            {% endblock %}
