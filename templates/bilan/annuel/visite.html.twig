{% extends "home/index.html.twig" %}

{% block title %}Bilan des visites {% endblock %}

{% block body %}

    <div class="card card-body">
        <form action="{{ path('app_bilan_visite') }}" method="POST" >

            <div class="card card-success">
                <div class="card-header">
                    <h3 class="card-title">Critères</h3>
                </div>
                <div class="row">

                    <div class="col-md-3">
                        {{ form_row(form_recherche.receptionpar, {'label':'Reçu par'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.sexe, {'label':'Sexe'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateDebut, {'label':'Date debut'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateFin , {'label':'Date fin'}) }}
                    </div>
                </div>

                <div class="col-md-4">
                    <input type="submit" value="Rechercher">
                </div>


            </div>    
    </div>
</form>    
</div> 

<div class="rows">
    {% if app.request.method == 'POST' and visites |length==0 %}
        Aucune donnée trouvée

    {% else %}

        {% if visites |length >0 %}
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">Resultats de la recherche</h3>
                </div>

                <div class="card-body">

                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Date visite</th>
                                <th>Visiteurs</th>
                                <th>Genre</th>
                                <th>Contact</th>
                                <th>Reçu par</th>


                            </tr>
                        </thead>

                        <tbody>
                            {% for visite in visites %}

                                <tr>

                                    <td>{{ visite.datevisite ? date_format(visite.datevisite) }}</td>
                                    <td>{{ visite.visiteur }}</td>
                                    <td>{{ visite.sexe }}</td>
                                    <td>{{ visite.contact1 }}</td>
                                    <td> {% if visite.receptionpar is not empty %} {{ visite.receptionpar }} {% else %} {% endif %}</td>

                                </tr>


                            {% endfor %}


                        </tbody>
                    </table>
                </div>
                </div>
                </div>
            {% endif %}
        {% endif %}



    {% endblock %}

