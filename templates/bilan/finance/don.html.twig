{% extends "home/index.html.twig" %}

{% block title %}Bilan des dons {% endblock %}

{% block body %}

    <div class="card card-body">
        <form action="{{ path('app_bilan_don') }}" method="POST" >

            <div class="card card-success">
                <div class="card-header">
                    <h3 class="card-title">Critères</h3>
                </div>
                <div class="row">

  <div class="col-md-3">
                        {{ form_row(form_recherche.nature , {'label':'Nature don'}) }}
                    </div>
                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateDebut, {'label':'Date debut'}) }}
                    </div>

                    <div class="col-md-3">
                        {{ form_row(form_recherche.dateFin , {'label':'Date fin'}) }}
                    </div>
                </div>

                <div class="col-md-4">
                    <input type="submit" value="Rechercher">
                </div>


            </div>    
    </div>
</form>    
</div> 

<div class="rows">
    {% if app.request.method == 'POST' and dons |length==0 %}
        Aucune donnée trouvée

    {% else %}

        {% if dons |length >0 %}
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">Resultats de la recherche</h3>
                </div>
                    <div style="align-content: center">
                {% for don in dons %}
                    {% set sum = don.valeurdon + sum ?? 0 %}
                    {% if loop.last  %} Montant total :  <b> {{ sum|number_format(0, '.', ' ')}}F CFA -- {{ sum|format_number(style='spellout')}} F CFA</b>  {% endif %}
                {% endfor %}
                    </div>

                <hr style="visibility: hidden" /> 
                <div class="card-body">

                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                            <tr>
                                <th>Date </th>
                                <th>Nature don</th>
                                <th>Objet</th>
                                <th>Montant</th>


                            </tr>
                        </thead>

                        <tbody>
                            {% for don in dons %}

                                <tr>
                                    <td>{{ date_format(don.datedon) }}</td>
                                    <td>{{ don.nature }}</td>
                                    <td>{{ don.description|raw }}</td>
                                    <td>{{ don.valeurdon|number_format(0, '.', ' ')  }}</td>


                                </tr>


                            {% endfor %}


                        </tbody>
                    </table>
                </div>
            {% endif %}
        {% endif %}

    {% endblock %}

