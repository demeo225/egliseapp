{% extends "home/index.html.twig" %}

{% block title %}Detail des cotisations{% endblock %}

{% block body %}



    <div class="card-body">

        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Details paiment</h3>
            </div>
     {% for message in app.flashes('suppdetail') %}
                <div class="primary">
                    {{ message }}
                </div>
            {% endfor %}
            <!-- /.card-header -->
            <div class="card-body">


                <hr style="visibility: hidden" />  

                <table id="example1" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Fidèle</th>
                            <th>Contact</th>
                            <th>Objet</th>
                            <th>Montant à payer</th>
                            <th>Mont payé</th>
                            <th>Reste </th>
                            <th>Supprimer </th>

                        </tr>
                    </thead>
                    <tbody>
                        {% for detail in details %}
                            <tr>
                                <td>{{ detail.datedetail ? detail.datedetail|date('d-m-Y') : '' }}</td>
                                <td>{{ detail.fidele.nomfidele }}</td>
                                <td> {% if detail.fidele.contactwhatssap is not empty %} {{ detail.fidele.contactwhatssap}} {% else %} {{ detail.fidele.contact1}} {% endif %}</td>                                <td>{{ detail.cotisation.objet }}</td>
                                <td>{{ detail.cotisation.montant|number_format(0, '.', ' ') }}</td>
                                <td>{{ detail.montantpayer|number_format(0, '.', ' ') }}</td>
                                <td>

                                    {% if  detail.reste > 0 %}
                                        <b>{{ detail.reste|number_format(0, '.', ' ') }}</b>


                                    {% else %}
                                        <i class="btn btn-success">    Soldée</i> 
                                    {% endif %}


                                </td>
                                <td>
                                    <form method="post" action="{{ path('detailcotisation_delete', {'id': detail.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('deletedetail' ~ detail.id) }}">

                                        <button class="btn">
                                            <span style="font-size: 1em; color: red;">
                                                <i class="fas fa-trash-alt"></i>
                                            </span>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="13">Aucuné donnée trouvée</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
{# empty Twig template #}
