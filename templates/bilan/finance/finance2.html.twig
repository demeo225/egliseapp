{% extends "home/index.html.twig" %}

{% block title %}Bilan finance
{% endblock %}

{% block body %}

	<div class="card card-body">
		<form action="{{ path('app_bilan_finance2') }}" method="POST">

			<div class="card card-success">
				<div class="card-header">
					<h3 class="card-title">Critères</h3>
				</div>
				<div class="row">

                <div class="col-md-3">
                        {{ form_row(form_recherche.departement, {'label':'Departement'}) }}
                    </div>
                     <div class="col-md-3">
                        {{ form_row(form_recherche.objetrecette, {'label':'Objet recette'}) }}
                    </div>
                     <div class="col-md-3">
                        {{ form_row(form_recherche.objetcharge, {'label':'Objet depense'}) }}
                    </div>
					<div class="col-md-3">
						{{ form_row(form_recherche.dateDebut, {'label':'Date début'}) }}
					</div>

					<div class="col-md-3">
						{{ form_row(form_recherche.dateFin , {'label':'Date fin'}) }}
					</div>
				</div>

				<div class="col-md-4">
					<input type="submit" value="Rechercher">
				</div>


			</div>


		</form>
	</div>

	<div class="rows">
		{% if app.request.method == 'POST' and charges |length==0 %}
			Aucune donnée trouvée

		{% else %}

			{% if charges |length >0 %}
				<div class="card card-primary">
					<div class="card-header">
						<h3 class="card-title">Bilan des dépenses</h3>
					</div>
					<div style="align-content: center">
						{% for charge in charges %}
							{% set seance = charges|length %}
							{% set sum = charge.montant + sum ?? 0 %}
							{% if loop.last  %}
								Moyenne:
								<b>
									{{ (sum/seance)|number_format(0, '.', ' ') }}
									F CFA
								</b>
								par séance
								<br/>
								Montant total :
								<b>
									{{ sum|number_format(0, '.', ' ')}}F CFA --
									{{ sum|format_number(style='spellout')}}
									C CFA</b>
							{% endif %}
						{% endfor %}
					</div>

					<hr style="visibility: hidden"/>
					<div class="card-body">

						<table id="example1" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Montant</th>
                            <th>En Lettre</th>
                            <th>Objet dépense</th>
                            <th>Departement</th>
                          


                        </tr>
                    </thead>
                    <tbody> 
                        {% for charge in charges %}
                            <tr>
                                <td>{{ charge.datecharge|date('d-m-Y')}}</td>
                                <td>{{ charge.montant|number_format(0, '.', ' ')}}</td>
                                <td>{{ charge.montant|format_number(style='spellout') }}</td>
                                <td> {{ charge.objetcharge ?  charge.objetcharge.libelle }} </td>
                                <td> {{ charge.departement ?  charge.departement.nom }} </td>
                               
                                 
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5">aucune donnée trouvée</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
					</div>
				{% endif %}
			{% endif %}
		</div>
	</div>

 {% if app.request.method == 'POST' and recettes |length==0 %}
        Aucune donnée trouvée

    {% else %}

        {% if recettes |length >0 %}
            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">Bilan des recettes</h3>
                </div>
                <div style="align-content: center">
                    {% for recette in recettes %}
                        {% set seance = recettes|length %}
                        {% set sum = recette.montant + sum ?? 0 %}
                        {% if loop.last  %}
                             Moyenne:  <b> {{ (sum/seance)|number_format(0, '.', ' ') }} F CFA </b> par séance <br />
                            Montant total :  <b> {{ sum|number_format(0, '.', ' ')}}F CFA -- {{ sum|format_number(style='spellout')}} C CFA</b>  {% endif %}
                    {% endfor %}
                </div>

                <hr style="visibility: hidden" /> 
                <div class="card-body">

                     <table id="example1" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Montant</th>
                            <th>En Lettre</th>
                            <th>Objet recette</th>
                           


                        </tr>
                    </thead>
                    <tbody> 
                        {% for recette in recettes %}
                            <tr>
                                <td>{{ recette.daterecette|date('d-m-Y')}}</td>
                                <td>{{ recette.montant|number_format(0, '.', ' ')}}</td>
                                <td>{{ recette.montant|format_number(style='spellout') }}</td>
                     <td> {{ recette.objetrecette ?  recette.objetrecette.libelle }} </td>

                              
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5">aucune donnée trouvée</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                </div>
            {% endif %}
        {% endif %}

{% endblock %}
