  <div class="card card-body">


            {{ form_start(form) }}
            {% for message in app.flashes('offrande') %}
                <div class="primary">
                    {{ message }}
                </div>
            {% endfor %}
            <div class="my-custom-class-for-errors">
                {{ form_errors(form) }}

            </div>

            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.daterecette, {'label':'Date '}) }}
                </div>
                  <div class="col-md-4">
                    {{ form_row(form.objetrecette, {'label':'Objet recette'}) }}
                </div>
               
                      <div class="col-md-4">
                    {{ form_row(form.detail, {'label':'Detail recette '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.montant, {'label':'Montant'}) }}
                </div>
             
            </div>
           

            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>
                <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>
                <div class="col-md-2"><a href="{{ path('app_recette_index') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 

            {{ form_end(form) }}
        </div>
