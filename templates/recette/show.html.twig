{% extends 'base.html.twig' %}

{% block title %}Recette{% endblock %}

{% block body %}
    <h1>Recette</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ recette.id }}</td>
            </tr>
            <tr>
                <th>Montant</th>
                <td>{{ recette.montant }}</td>
            </tr>
            <tr>
                <th>Detail</th>
                <td>{{ recette.detail }}</td>
            </tr>
            <tr>
                <th>Daterecette</th>
                <td>{{ recette.daterecette ? recette.daterecette|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Ideglise</th>
                <td>{{ recette.ideglise }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_recette_index') }}">back to list</a>

    <a href="{{ path('app_recette_edit', {'id': recette.id}) }}">edit</a>

    {{ include('recette/_delete_form.html.twig') }}
{% endblock %}
