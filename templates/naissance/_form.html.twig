
<div class="card card-primary">

    <div class="card card-body">
        {{ form_start(form) }}
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.nomnaiss, {'label':'Nom & prénomns '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.poidsnaiss, {'label':'Poids à la naissance'}, {'fornumber_format' :'9.999'}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.sexenaiss, {'label':'Sexe '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.datenaissance, {'label':'Date de naissance '}) }}
            </div>
        </div>
        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.perenaisse, {'label':'Père membre '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.perenaiss, {'label':'Père '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.merenaisse, {'label':'Mère membre '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.merenaiss, {'label':'Mère '}) }}
            </div>
        </div>
        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.naturedon, {'label':' Dons en nature '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.especedon, {'label':' Don en espèce '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.lieunaissance, {'label':'Lieu '}) }}
            </div>

        </div>
        <div class="row"> 
            <div class="col-md-4">
                {{ form_row(form.photo, {'label':'Photo '}) }}
            </div>
        
        <div class="col-md-4">
            {{ form_row(form.datepresentation, {'label':'Date de présentation '}) }}
        </div>
    </div>
    <div class="row"> 
        <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

        <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

        <div class="col-md-2"><a href="{{ path('naissance_index') }}" class="btn btn-success">Afficher la liste</a> </div>
    </div>
    {{ form_end(form) }}

</div>
</div>
