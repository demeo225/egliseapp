<script>

document.getElementById('enfant_commune')
    .addEventListener('change', function() {

    const communeId = this.value;

    if (communeId === '') {
        return;
    }

    fetch(`/fidele/quartiers/${communeId}`)
        .then(response => response.json())
        .then(data => {

            const quartierSelect =
                document.getElementById('enfant_quartier');

            quartierSelect.innerHTML =
                '<option value="">-- Choisissez un quartier --</option>';

            data.forEach(quartier => {

                const option = document.createElement('option');

                option.value = quartier.id;
                option.textContent = quartier.libelle;

                quartierSelect.appendChild(option);

            });

        })
        .catch(error => {
            console.error(
                'Erreur lors du chargement des quartiers:',
                error
            );
        });

});

</script>

