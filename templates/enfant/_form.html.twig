


<style>

    body {
        background: #f4f6f9;
    }

    .multi-step-form {
        background: #fff;
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }

    .step {
        display: none;
        animation: fadeIn .4s ease-in-out;
    }

    .step.active {
        display: block;
    }

    @keyframes fadeIn {
        from {
            opacity: 0
            transform: translateX(20px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    .form-control,
    .form-select {
        border-radius: 10px;
        min-height: 45px;
    }

    .form-label {
        font-weight: 600;
        color: #344767;
        margin-bottom: 6px;
    }

    .step-indicator {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 30px;
    }

    .step-item {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: #dee2e6;
        color: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        transition: 0.3s;
    }

    .step-item.active {
        background: #0d6efd;
        color: #fff;
    }

    .btn-step {
        min-width: 140px;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 25px;
    }

    .camera-box {
        border: 2px dashed #ced4da;
        border-radius: 10px;
        padding: 10px;
        background: #f8f9fa;
        text-align: center;
    }

    .card-title {
        font-weight: bold;
    }

    .flash-text {
        font-size: 18px;
    }

</style>




<div class="container mt-4 mb-5">

    <div class="card card-primary border-0 shadow">

        <div class="card-header bg-primary text-white">
            <h3 class="card-title mb-0">
                Enregistrement enfant
            </h3>
        </div>

        <div class="card-body multi-step-form">

            {{ form_start(form) }}

           

            <div class="offset-md-1 col-md-10 mb-3">

                {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }}">
                            <span class="flash-text">{{ message }}</span>
                        </div>
                    {% endfor %}
                {% endfor %}

            </div>

            {# ================= ETAPES ================= #}

            <div class="step-indicator">
                <div class="step-item active">1</div>
                <div class="step-item">2</div>
                <div class="step-item">3</div>
            </div>

            {# ================= ETAPE 1 ================= #}

            <div class="step active">

                <div class="row g-4">

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.nom, {
                            'label':'Nom & prénoms',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.contact, {
                            'label':'Contact',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.contactwhatssap, {
                            'label':'Contact parent',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.sexe, {
                            'label':'Sexe',
                            'attr':{'class':'form-select'}
                        }) }}
                    </div>

                </div>

                <div class="row g-4 mt-1">

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.datenaiss, {
                            'label':'Date de naissance',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.comptefacebook, {
                            'label':'Compte Facebook',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.email, {
                            'label':'Email',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.niveauetude, {
                            'label':'Niveau d\'étude',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                </div>

                <div class="row g-4 mt-1">

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.numpiece, {
                            'label':'N° pièce',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.lieunaiss, {
                            'label':'Lieu de naissance',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.classenfant, {
                            'label':'Classe',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.ethnie, {
                            'label':'Ethnie'
                        }) }}
                    </div>

                </div>

                <div class="action-buttons justify-content-end">

                    <button type="button"
                            class="btn btn-primary btn-step next-btn">
                        Suivant
                    </button>

                </div>

            </div>

            {# ================= ETAPE 2 ================= #}

            <div class="step">

                <div class="row g-4">

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.pere, {
                            'label':'Père non fidèle',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.mere, {
                            'label':'Mère non fidèle',
                            'attr':{'class':'form-control'}
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.peremembre, {
                            'label':'Choix du père'
