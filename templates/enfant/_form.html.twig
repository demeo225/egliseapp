                    </div>

                </div>

                <div class="row g-4 mt-1">

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.lieuvivre, {
                            'label':'Situation sociale',
                            'attr':{'class':'form-select'}
