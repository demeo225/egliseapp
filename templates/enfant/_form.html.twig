                            'label':'Famille / Tribu'
                        }) }}
                    </div>

                    <div class="col-12 col-md-6 col-lg-3">
                        {{ form_row(form.nationalite, {
                            'label':'Nationalité'
                        }) }}
                    </div>

                </div>

                <div class="row g-4 mt-3">

                    <div class="col-md-4">

                        <div class="camera-box">
                            <div id="camera"></div>
                        </div>

                    </div>

                    <div class="col-md-4 d-flex align-items-center">

                        <input
                                type="button"
                                value="Capturer photo"
                                id="btPic"
                                onclick="takeSnapShot()"
                                class="btn btn-primary w-100"
                        />

                    </div>

                    <div class="col-md-4">

                        {{ form_row(form.photo, {
                            'label':'Télécharger photo',
                            'attr':{'class':'form-control'}
                        }) }}

                    </div>

                </div>

                <div class="action-buttons justify-content-between">

                    <button type="button"
                            class="btn btn-secondary btn-step previous-btn">
                        Précédent
                    </button>

                    {{ form_widget(form.save, {
                        'label': 'Valider',
                        'attr': {
                            'class': 'btn btn-success btn-step'
                        }
                    }) }}

                    {{ form_widget(form.saveAndAdd, {
                        'label': 'Valider ++',
                        'attr': {
                            'class': 'btn btn-warning btn-step'
                        }
                    }) }}

                    <a href="{{ path('enfant') }}"
                       class="btn btn-info text-white btn-step">
                        Afficher la liste
                    </a>

                </div>

            </div>

            {{ form_end(form) }}

        </div>

    </div>

</div>





<script>

    const steps = Array.from(document.querySelectorAll(".step"));
    const nextBtns = document.querySelectorAll(".next-btn");
    const prevBtns = document.querySelectorAll(".previous-btn");
    const indicators = document.querySelectorAll(".step-item");

    nextBtns.forEach(btn => {
        btn.addEventListener("click", () => {
            changeStep(1);
        });
    });

    prevBtns.forEach(btn => {
        btn.addEventListener("click", () => {
            changeStep(-1);
        });
    });

    function changeStep(direction)
    {
        let currentStep = steps.findIndex(step =>
            step.classList.contains("active")
        );

        steps[currentStep].classList.remove("active");
        indicators[currentStep].classList.remove("active");

        currentStep += direction;

        steps[currentStep].classList.add("active");
        indicators[currentStep].classList.add("active");

        window.scrollTo({
            top: 0,
            behavior: "smooth"
        });
    }

</script>

<script
        type="text/javascript"
        src="https://cdnjs.cloudflare.com/ajax/libs/webcamjs/1.0.25/webcam.js">
</script>

<script>

    Webcam.set({
        width: 220,
        height: 190,
        image_format: 'jpeg',
        jpeg_quality: 100
    });

    Webcam.attach('#camera');

    takeSnapShot = function () {

        Webcam.snap(function (data_uri) {
            downloadImage('photo_enfant', data_uri);
        });

    }

    downloadImage = function (name, datauri) {

        let a = document.createElement('a');

        a.setAttribute('download', name + '.png');
        a.setAttribute('href', datauri);

        a.click();

    }

</script>

        <script>
document.getElementById('enfant_commune').addEventListener('change', function() {
    const communesId = this.value;

    if (communesId === '') return;

    fetch(`/fidele/quartiers/${communesId}`)
        .then(response => response.json())
        .then(data => {
            const quartierSelect = document.getElementById('enfant_quartier');
            quartierSelect.innerHTML = '<option value="">-- Choisissez un quartier --</option>';

            data.forEach(quartier => {
                const option = document.createElement('option');
                option.value = quartier.id;
                option.textContent = quartier.libelle;
                quartierSelect.appendChild(option);
            });
        })
        .catch(error => console.error('Erreur lors du chargement des quartiers:', error));
});
</script>

    
