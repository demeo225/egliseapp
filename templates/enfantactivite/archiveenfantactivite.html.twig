{% extends "home/index.html.twig" %}

{% block title %}Liste des enfants retirés des activités{% endblock %}

{% block body %}
    <div class="card-body">

        <div class="card card-dark">
            <div class="card-header">
                <h3 class="card-title">Archive présence</h3>
            </div>
            <!-- /.card-header -->
            <div class="card-body">

                </a>
                <hr style="visibility: hidden" />

                <table id="example1" class="table table-bordered table-striped">

                    <thead>
                    <th>Activite</th>
                    <th>Date</th>
                    <th>Lieu</th>
                    <th>Code</th>
                    <th>Enfant</th>
                    <th>Contact Parents</th>
                    <th>Age</th>
                    <th>Photo</th>
                    <th>Restaurer</th>
                    </thead>
                    </tr>
                    <tbody>
                        {% for enfantactivite in enfantactivite %}

                            <tr>

                                <td> {% if enfantactivite.ecodimactivite is not empty  %} {{ enfantactivite.ecodimactivite.nomactivite|upper}} {% else %} {% endif %}</td>
                                <td>{% if enfantactivite.ecodimactivite is not empty  %}{{ enfantactivite.ecodimactivite.dateactivite ? enfantactivite.ecodimactivite.dateactivite|date('d-m-Y') : '' }}  {% else %} {% endif %}</td>
                                <td>{% if enfantactivite.ecodimactivite is not empty  %}{{ enfantactivite.ecodimactivite.lieu }}  {% else %} {% endif %}</td>
                                <td>{{ enfantactivite.enfant.code|upper}}</td>
                                <td>{{ enfantactivite.enfant.nom|upper}}</td>
                                <td>{{ enfantactivite.enfant.contact}}</td>
                                <td>{{ enfantactivite.enfant.age}}</td>

                                <td>    <a href="{{ path('enfantactivite_show', {'id': enfantactivite.id}) }}"> 
                                        <img src="{{ asset('uploads/photos/'~enfantactivite.enfant.photoFile )}}"  class="img-size-50 mr-3 img-suqare"/> </a>  </td>

                                <td>

                                    <a href="{{ path('enfantactive_restaureenftactive', {'id': enfantactivite.id}) }}">

                                        <form method="post" action="{{ path('enfantactive_restaureenftactive', {'id': enfantactivite.id}) }}" onsubmit="return confirm('Voulez-vous effectuer la restauration?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('restaure' ~ enfantactivite.id) }}">

                                            <button class="btn">
                                                <span style="font-size: 1em; color: blue;">
                                                    <i class="fas fa-edit"></i>
                                                </span>
                                            </button>
                                        </form>

                                </td>
                            </tr>

                        {% else %}
                            <tr>
                                <td colspan="5">aucune donnée trouvée</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>

    </div>



{% endblock %}
