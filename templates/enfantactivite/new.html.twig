{% extends "home/index.html.twig" %}

{% block title %}Droit de participation
{% endblock %}

{% block body %}


    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Enregistrement frais de participation</h3>
        </div>
        <div class="card card-body">

            {{ form_start(form) }}

 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        <div class="card-body">

            <div class="row mb-4">

                <div class="col-md-4">
                    {{ form_row(form.enfant, {'label':' * Enfant :'}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.montantpayer, {'label':' * Montant payé :','attr':{'class':'form-control'}}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.ecodimactivite, {'label':' Activité :'}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.datecotiser, {'label':' * Date :','attr':{'class':'form-control'}}) }}
                </div>

        
            </div>


            <div class="row"> 
               <div class="col-md-1.5">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

                 <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

                 <div class="col-md-2"><a href="{{ path('enfantactivite_index') }}" class="btn btn-success">Paiement participation</a> </div>
            </div>
         
            {{ form_end(form) }}
        </div>
    </div>


    </div>
       

{% endblock %}