{% extends "home/index.html.twig" %}

{% block title %}Modification droit de participation{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h2 class="card-title">Modification de participation</h2>
        </div>
        <div class="card card-body">

            {{ form_start(form) }}
            <div class="my-custom-class-for-errors">
                {{ form_errors(form) }}
            </div>

            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.enfant, {'label':' Enfant '})}}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.montantpayer, {'label':' Montant payé '})}}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.ecodimactivite, {'label':' Activité '})}}
                </div>

                <div class="col-md-3">
                    {{ form_row(form.datecotiser, {'label':'Date '}) }}
                </div>
            </div>



                <div class="row">
                    <div class="btn btn-default">{{ form_row(form.save, {'label':'Modifier ','attr':{'value':'save'}}) }}</div>

                    <div class="btn btn-default"><a href="{{ path('enfantactivite_index') }}" class="btn btn-success">Afficher la liste</a> </div>
                </div> 
                <div class="btn btn-default" style="display: none"> {{ form_row(form.saveAndAdd, {'label':'Enregistrer et continuer ','attr':{'value':'save-and-add'}}) }} </div>

                {{ form_end(form) }}


            </div>

        {% endblock %}
