

    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Enregistrement depense</h3>
        </div>
        <div class="card card-body">

        {{ form_start(form, {'attr': {'action' :path('operation_add1')}}) }}


            <div class="row mb-4">

                <div class="col-md-3">
                    {{ form_row(form.dateop, {'label':'Date ', 'attr':{'class':'form-control'}}) }}

                </div>



                <div class="col-md-3">
                    {{ form_row(form.objet, {'libel':'Objet '}) }}

                </div>

                <div class="col-md-3">
                    {{ form_row(form.montant, {'libel':'Montant '}) }}

                </div>



            </div>

            <div class="row mb-4">



                <div class="col-md-3">
                    {{ form_row(form.beneficiaire, {'libel':'Bénéficiaire '}) }}

                </div>
                <div class="col-md-3">
                    {{ form_row(form.numrecu, {'libel':'N° reçu '}) }}

                </div>
                <div class="col-md-3">
                    {{ form_row(form.description, {'libel':'Details '}) }}

                </div>

            </div>
            <div class="row mb-4">

                <div class="col-md-3">
                    {{ form_row(form.photo, {'label':'Image du reçu :'}) }}
                </div>

            </div>

                <div class="row"> 
                    <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>
                    <div class="col-md-2" style="display: none"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>
                </div> 

                {{ form_end(form) }}
            </div>

        </div>

