{% extends "home/index.html.twig" %}

{% block title %}Liste des dépenses{% endblock %}

{% block body %}


    <div class="card-body">

        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Gestion des dépenses</h3>
            </div>
  <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
            <!-- /.card-header -->
            <div class="card-body">
                <button type="button" title="Enregistrement rapide" id="btn-fideles-modal" data-target="{{ path('operation_add1') }}" class="btn btn-primary"> 
                    Nouveau
                </button>

                <a href='{{ path('operation_add') }}'>
                    <button class="btn btn-primary">Nouveau++</button>
                </a>
                <b>Solde</b>
                <button class="btn btn-success">
                    {% for solde in soldes %}
                        {{ solde.montant|number_format(0, '.', ' ') }} F CFA --    <b>{{ solde.montant|format_number(style='spellout') }} F CFA</b>
                    {% endfor %}
                </button>
                

                <hr style="visibility: hidden" />

                <table id="example1" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Bénéficiaire</th>
                            <th>N° reçu</th>
                            <th>Montant </th>
                            <th>Détais</th>
                            <th>Modifier</th>
                            <th>Supprimer</th>


                        </tr>
                    </thead>
                    <tbody>
                        {% for operation in operation %}
                            <tr>
                                <td>{{ operation.dateop|format_datetime('full', 'none', locale='fr')}}</td>
                                <td>{{ operation.beneficiaire|upper}}</td>
                                <td>{{ operation.numrecu}}</td>
                                <td> <b>{{ operation.montant|number_format(0, '.', ' ')}}</b></td>




                                <td>
                                    {% if operation.photoFile is not empty %}
                                    <a href="{{ path('operation_detail', {'id': operation.id}) }}">
                                        <img src="{{ asset('uploads/photos/'~operation.photoFile )}}"  class="img-size-50 mr-3 img-suqare" title="Voir details"/>
                                    </a>
                                    {% else %}
                                           <a href="{{ path('operation_detail', {'id': operation.id}) }}">
                                               Voir details
                                    </a> 
                                    {% endif %}
                                </td>


                                <td>
              
                                        
                                        
                                        
                                        
                                         <a href="{{ path('operation_update', {'id': operation.id}) }}"> 
                                        <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-edit" title="Modification"></i>
                                        </span></a>
                                </td>
                                <td>
                                    <form method="post" action="{{ path('operation_delete', {'id': operation.id}) }}" onsubmit="return confirm('etes vous sur de vouloir supprimer?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ operation.id) }}">
                                        <button class="btn">
                                            <span style="font-size: 1em; color: red;">
                                                <i class="fas fa-trash-alt"></i>
                                            </span>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                    
                        {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>


    </div>




    <!-- Modal des  -->
    <div class="modal fade bd-example-modal-lg" id="fidelesModal" tabindex="-1" aria-labelledby="fidelesModalLabel" aria-hidden="true">

        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-body">

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}





