{% extends "home/index.html.twig" %}

{% block title %}Cotisation cellule{% endblock %}

{% block body %}


    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Modificatio paiement</h3>
        </div>
        <div class="card card-body">
            {{ form_start(form) }}
            {{ form_errors(form) }}
            {% for message in app.flashes('cotisercellule') %}
                <div class="primary">
                    {{ message }}
                </div>
            {% endfor %}
            <div class="row">

                <div class="col-4">
                    {{ form_row(form.cotisationcellule, {'label':'Cotisation :'}) }}

                </div>
                <div class="col-md-4">
                    {{ form_row(form.datecotiser, {'label':'Date :','attr':{'class':'form-control'}}) }}
                </div>

            </div>
            <div class="row">
                <div class="col-4">
                    {{ form_row(form.fidele, {'label':'Choix du fidèle :'}) }}
                </div>
                <div class="col-4">
                    {{ form_row(form.montantpayer, {'label':'Montant :','attr':{'class':'form-control'}}) }}
                </div>

            </div>

            <div class="row"> 
             <div class="col-md-2">{{ form_row(form.save, {'label':'Modifier ','attr':{'value':'save'}}) }}</div>


              <div class="col-md-2"><a href="{{ path('cotisercellule_index') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 
         
            {{ form_end(form) }}
        </div>
    </div>





{% endblock %}