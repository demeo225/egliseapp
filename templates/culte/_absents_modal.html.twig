{# templates/culte/_absents_modal.html.twig #}
<div class="table-responsive">
    <div class="alert alert-warning">
        <strong>Total des absents :</strong> {{ total }} sur {{ totalMembres|default(0) }} membres
        {% if seance %}
            <span class="ml-3"><strong>Culte :</strong> {{ seance.theme }}</span>
            <span class="ml-3"><strong>Date :</strong> {{ seance.dateculte|date('d/m/Y H:i') }}</span>
        {% endif %}
    </div>
    
    <table class="table table-striped table-bordered">
        <thead class="thead-danger">
            <tr>
                <th>#</th>
                <th>Nom du fidèle</th>
                <th>Contact</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% if absents|length > 0 %}
                {% for absent in absents %}
                    <tr>
                        <td>{{ loop.index }}</td>
                        <td><i class="fas fa-user text-danger"></i> {{ absent.nom }}</td>
                        <td>{{ absent.contact }}</td>
                        <td><span class="badge badge-danger">Absent</span></td>
                    </tr>
                {% endfor %}
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-success">
                        <i class="fas fa-check-circle"></i> Tous les membres sont présents !
                    </td>
                </tr>
            {% endif %}
        </tbody>
    </table>
    
    {% if absents|length > 0 %}
        <div class="alert alert-info mt-3">
            <i class="fas fa-info-circle"></i> 
            <strong>Total :</strong> {{ total }} absent(s) sur {{ totalMembres|default(0) }} membres
        </div>
    {% endif %}
</div>