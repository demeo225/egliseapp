{# templates/culte/scan_form.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Enregistrement présence - {{ culte.libelle }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .card {
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        .card-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            text-align: center;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 12px;
            font-size: 18px;
            font-weight: bold;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .form-control {
            border-radius: 10px;
            padding: 12px;
            font-size: 16px;
        }
        .alert {
            border-radius: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-sm-10">
                <div class="card">
                    <div class="card-header">
                        <h3>📖 Enregistrement de présence</h3>
                        <p class="mb-0">{{ culte.libelle }} - {{ culte.dateculte|date('d/m/Y H:i') }}</p>
                    </div>
                    <div class="card-body p-4">
                        <div id="alert-container"></div>
                        
                        <form id="scanForm">
                            <input type="hidden" name="_token" value="{{ csrf_token('scan_culte') }}">
                            
                            <div class="mb-3">
                                <label for="contact1" class="form-label">📱 Numéro de téléphone *</label>
                                <input type="tel" 
                                       class="form-control" 
                                       id="contact1" 
                                       name="contact1" 
                                       required 
                                       placeholder="Ex: 690001122"
                                       autocomplete="off">
                                <small class="text-muted">Entrez votre numéro de téléphone principal</small>
                            </div>
                            
                            <div class="mb-3">
                                <label for="nomfidele" class="form-label">👤 Nom complet *</label>
                                <input type="text" 
                                       class="form-control" 
                                       id="nomfidele" 
                                       name="nomfidele" 
                                       required 
                                       placeholder="Votre nom et prénom"
                                       autocomplete="off">
                                <small class="text-muted">Votre nom tel qu'il apparaîtra sur la liste</small>
                            </div>
                            
                            <button type="submit" class="btn btn-primary w-100" id="submitBtn">
                                <span id="btnText">✓ Enregistrer ma présence</span>
                                <span id="btnSpinner" class="spinner-border spinner-border-sm d-none"></span>
                            </button>
                        </form>
                        
                        <hr class="my-4">
                        
                        <div class="text-center">
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i> 
                                En soumettant ce formulaire, vous confirmez votre participation au culte
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#scanForm').on('submit', function(e) {
                e.preventDefault();
                
                // Désactiver le bouton
                $('#submitBtn').prop('disabled', true);
                $('#btnText').addClass('d-none');
                $('#btnSpinner').removeClass('d-none');
                
                // Réinitialiser les alertes
                $('#alert-container').empty();
                
                $.ajax({
                    url: '{{ path('culte_scan_register') }}',
                    method: 'POST',
                    data: {
                        _token: $('input[name="_token"]').val(),
                        contact1: $('#contact1').val(),
                        nomfidele: $('#nomfidele').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            $('#alert-container').html(`
                                <div class="alert alert-success alert-dismissible fade show" role="alert">
                                    <strong>✓ Succès !</strong> ${response.message}
                                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                                </div>
                            `);
                            $('#scanForm')[0].reset();
                            
                            // Rediriger après 3 secondes
                            setTimeout(function() {
                                window.location.href = '{{ path('culte_scan_qr', {'id': culte.id}) }}';
                            }, 3000);
                        }
                    },
                    error: function(xhr) {
                        let errorMessage = 'Une erreur est survenue';
                        if (xhr.responseJSON && xhr.responseJSON.error) {
                            errorMessage = xhr.responseJSON.error;
                        }
                        $('#alert-container').html(`
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <strong>✗ Erreur !</strong> ${errorMessage}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        `);
                        $('#submitBtn').prop('disabled', false);
                        $('#btnText').removeClass('d-none');
                        $('#btnSpinner').addClass('d-none');
                    }
                });
            });
            
            // Auto-formatage du téléphone
            $('#contact1').on('input', function() {
                let value = $(this).val().replace(/\D/g, '');
                if (value.length > 9) value = value.slice(0, 9);
                $(this).val(value);
            });
        });
    </script>
</body>
</html>