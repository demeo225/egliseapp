{% extends "home/index.html.twig" %}

{% block title %}Liste des cultes{% endblock %}

{% block body %}
    <div class="card-body">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Gestion des cultes</h3>
            </div>
            <div class="offset-1 col-md-10 mt-2 mb-2">
                {% for label, messages in app.flashes(['success', 'warning', 'danger', 'commune']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} my-alert" role="alert">
                            <h1 class="m-0 flash-text">{{ message }}</h1>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
            <div class="card-body">
                <a href="{{ path('culte_add') }}" class="btn btn-primary">Nouveau</a>
                <a href="{{ path('invite_add') }}" class="btn btn-primary">Enregistrement invités</a>
                <a href="{{ path('culte_listepresence') }}" class="btn btn-success">Liste de présence</a>

                <hr style="visibility: hidden" />

                <table id="example1" class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Thème</th>
                            <th>Orateur</th>
                            <th>Présents</th>
                            <th>Absents</th>
                            <th>Rapport</th>
                            <th>Détail</th>
                            <th>Modifier</th>
                            <th>Supprimer</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for culte in cultes %}
                            <tr>
                                <td>{{ culte.dateculte|format_datetime('full', 'none', locale='fr')}}</td>
                                <td>{{ culte.theme}}</td>
                                <td>{% if culte.messager is not empty %} {{ culte.messager.nomfidele}} {% else %}{{ culte.orateur}}{% endif %}</td>

                                {# Calcul du nombre total de présents #}
                                {% set nmbrehomme = culte.nmbrehomme|default(0) %}
                                {% set nobrefemme = culte.nobrefemme|default(0) %}
                                {% set nbrefant = culte.nbrefant|default(0) %}
                                {% set nbreinvite = culte.invite|default(0) %}
                                {% set totalPresences = nmbrehomme + nobrefemme + nbrefant + nbreinvite %}

                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="badge badge-success mr-2">{{ totalPresences }}</span>
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-success btn-view-presents" 
                                                data-culte-id="{{ culte.id }}"
                                                data-toggle="modal" 
                                                data-target="#presentModal"
                                                title="Voir les présents">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                </td>
                                
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="badge badge-danger mr-2">{{ culte.nbreinvite|default(0) }}</span>
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-danger btn-view-absents" 
                                                data-culte-id="{{ culte.id }}"
                                                data-toggle="modal" 
                                                data-target="#absentModal"
                                                title="Voir les absents">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                </td>
                                
                                <td>
                                    {% if culte.photo is not empty %}
                                        <a href="{{ asset('uploads/photos/' ~ culte.photo) }}" target="_blank" class="btn btn-sm btn-success">
                                            <i class="fas fa-file-pdf"></i> Rapport
                                        </a>
                                    {% else %}
                                        <span class="text-muted">Indisponible</span>
                                    {% endif %}
                                </td>
                                
                                <!-- Détail button -->
                                <td>
                                    <button type="button" 
                                            class="btn btn-sm btn-primary btn-view-detail" 
                                            data-toggle="modal" 
                                            data-target="#detailModal{{ culte.id }}"
                                            title="Voir détails">
                                        <i class="fas fa-book"></i>
                                    </button>
                                </td>
                                
                                <!-- Edit button -->
                                <td>
                                    <a href="{{ path('culte_update', {'id': culte.id}) }}" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                                
                                <!-- Delete button -->
                                <td>
                                    <form method="post" action="{{ path('culte_delete', {'id': culte.id}) }}" 
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce culte ?');"
                                          style="display: inline-block;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ culte.id) }}">
                                        <button class="btn btn-sm btn-danger">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>

                            <!-- Modal Détail du culte -->
                            <div class="modal fade" id="detailModal{{ culte.id }}" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header bg-primary text-white">
                                            <h5 class="modal-title">
                                                <i class="fas fa-calendar-alt"></i>  {{ culte.theme }}
                                            </h5>
                                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                <span aria-hidden="true">&times;</span>
                                            </button>
                                        </div>
                                        <div class="modal-body">
                                            <div id="detailContent{{ culte.id }}">
                                                <div class="text-center">
                                                    <div class="spinner-border text-primary" role="status"></div>
                                                    <p>Chargement des détails...</p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Zone d'impression cachée pour le QR code -->
    <div id="printArea" style="display: none;"></div>

    {# Modal pour les présents #}
    <div class="modal fade" id="presentModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-success">
                    <h5 class="modal-title">
                        <i class="fas fa-check-circle"></i> Liste des présents
                    </h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div id="presentContent">
                        <div class="text-center">
                            <div class="spinner-border text-success" role="status"></div>
                            <p>Chargement des présents...</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

    {# Modal pour les absents #}
    <div class="modal fade" id="absentModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-danger">
                    <h5 class="modal-title">
                        <i class="fas fa-times-circle"></i> Liste des absents
                    </h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div id="absentContent">
                        <div class="text-center">
                            <div class="spinner-border text-danger" role="status"></div>
                            <p>Chargement des absents...</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

    {# Modal pour les invités (existant) #}
    <div class="modal fade" id="fidelesModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-info">
                    <h5 class="modal-title">
                        <i class="fas fa-users"></i> Liste des invités
                    </h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            // Charger les détails via AJAX quand on ouvre le modal
            $('[id^="detailModal"]').on('show.bs.modal', function (event) {
                var modalId = $(this).attr('id');
                var culteId = modalId.replace('detailModal', '');
                var contentDiv = $('#detailContent' + culteId);
                
                var url = '{{ path('culte_detail', {'id': 'ID_PLACEHOLDER'}) }}';
                url = url.replace('ID_PLACEHOLDER', culteId);
                
                $.ajax({
                    type: 'POST',
                    url: url,
                    beforeSend: function() {
                        contentDiv.html('<div class="text-center"><div class="spinner-border text-primary" role="status"></div><p>Chargement des détails...</p></div>');
                    },
                    success: function(html) {
                        contentDiv.html(html);
                    },
                    error: function() {
                        contentDiv.html('<div class="alert alert-danger">Erreur lors du chargement des détails</div>');
                    }
                });
            });

            // Charger les présents
            $('.btn-view-presents').on('click', function() {
                var culteId = $(this).data('culte-id');
                var contentDiv = $('#presentContent');
                
                var url = '{{ path('culte_presents') }}';
                
                $.ajax({
                    type: 'POST',
                    url: url,
                    data: {
                        culte_id: culteId
                    },
                    beforeSend: function() {
                        contentDiv.html('<div class="text-center"><div class="spinner-border text-success" role="status"></div><p>Chargement des présents...</p></div>');
                    },
                    success: function(html) {
                        contentDiv.html(html);
                    },
                    error: function() {
                        contentDiv.html('<div class="alert alert-danger">Erreur lors du chargement des présents</div>');
                    }
                });
            });

            // Charger les absents
            $('.btn-view-absents').on('click', function() {
                var culteId = $(this).data('culte-id');
                var contentDiv = $('#absentContent');
                
                var url = '{{ path('culte_absents') }}';
                
                $.ajax({
                    type: 'POST',
                    url: url,
                    data: {
                        culte_id: culteId
                    },
                    beforeSend: function() {
                        contentDiv.html('<div class="text-center"><div class="spinner-border text-danger" role="status"></div><p>Chargement des absents...</p></div>');
                    },
                    success: function(html) {
                        contentDiv.html(html);
                    },
                    error: function() {
                        contentDiv.html('<div class="alert alert-danger">Erreur lors du chargement des absents</div>');
                    }
                });
            });
        });

        // Fonction pour imprimer le QR code
        function imprimerQR(qrCodeDataUrl, theme, date) {
            var printWindow = window.open('', '_blank', 'width=800,height=600');
            
            printWindow.document.write('<!DOCTYPE html>');
            printWindow.document.write('<html>');
            printWindow.document.write('<head>');
            printWindow.document.write('<title>QR Code - ' + theme + '</title>');
            printWindow.document.write('<meta charset="UTF-8">');
            printWindow.document.write('<style>');
            printWindow.document.write(`
                body {
                    font-family: Arial, sans-serif;
                    text-align: center;
                    margin: 0;
                    padding: 20px;
                }
                .qr-container {
                    max-width: 400px;
                    margin: 0 auto;
                    padding: 20px;
                    border: 2px solid #ddd;
                    border-radius: 10px;
                    page-break-after: avoid;
                }
                .qr-title {
                    font-size: 24px;
                    font-weight: bold;
                    margin-bottom: 10px;
                    color: #333;
                }
                .qr-subtitle {
                    font-size: 18px;
                    margin-bottom: 20px;
                    color: #666;
                }
                .qr-code {
                    margin: 20px 0;
                }
                .qr-code img {
                    max-width: 300px;
                    height: auto;
                }
                .qr-info {
                    margin-top: 20px;
                    font-size: 14px;
                    color: #666;
                }
                .qr-footer {
                    margin-top: 30px;
                    font-size: 12px;
                    color: #999;
                    border-top: 1px solid #eee;
                    padding-top: 10px;
                }
                @media print {
                    .qr-container {
                        border: none;
                    }
                }
            `);
            printWindow.document.write('</style>');
            printWindow.document.write('</head>');
            printWindow.document.write('<body>');
            printWindow.document.write('<div class="qr-container">');
            printWindow.document.write('<div class="qr-title">🎯 QR Code - Culte</div>');
            printWindow.document.write('<div class="qr-subtitle">' + theme + '</div>');
            printWindow.document.write('<div class="qr-code">');
            printWindow.document.write('<img src="' + qrCodeDataUrl + '" alt="QR Code">');
            printWindow.document.write('</div>');
            printWindow.document.write('<div class="qr-info">');
            printWindow.document.write('<strong>Date:</strong> ' + date + '<br>');
            printWindow.document.write('<strong>Instructions:</strong><br>');
            printWindow.document.write('1. Scannez ce QR code avec votre téléphone<br>');
            printWindow.document.write('2. Entrez votre numéro de téléphone et votre nom<br>');
            printWindow.document.write('3. Validez votre présence au culte<br>');
            printWindow.document.write('</div>');
            printWindow.document.write('<div class="qr-footer">');
            printWindow.document.write('Présence scannée - Culte ' + date);
            printWindow.document.write('</div>');
            printWindow.document.write('</div>');
            printWindow.document.write('</body>');
            printWindow.document.write('</html>');
            
            printWindow.document.close();
            
            printWindow.onload = function() {
                setTimeout(function() {
                    printWindow.print();
                }, 500);
            };
        }
    </script>
{% endblock %}