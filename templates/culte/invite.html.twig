


<div class="card card-primary">

    <div class="card-header">
        <h3 class="card-title">Liste des invités 
        
        </h3>
    </div>
    <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger', 'commune']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
    <!-- /.card-header -->
    <div class="card-body">

        <table id="example1" class="table table-bordered table-striped">

            <thead>
                <tr>
                    <th>Nom & prenoms</th>
                    <th>Numero</th>
                    <th>Genre</th>
                    <th>Profession</th>
                    <th>Lieu d'habitation</th>




                </tr>
            </thead>
            <tbody>
                {% for invite in invites %}
                    <tr> 


                        <td>{{ invite.nom}}</td>
                        <td>{{ invite.contact}}</td>
                        <td>{{ invite.sexe}}</td>
                        <td>{{ invite.profession}}</td>
                        <td>{{ invite.habitation}}</td>
                   
                    </tr>
                {% endfor %}
            </tbody>
        </table>

    </div>

</div>


</div>

