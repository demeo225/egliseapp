{% extends "home/index.html.twig" %}

{% block title %}Présences & absences - {{ groupe.nom|upper }}{% endblock %}

{% block body %}
<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Gestion présence de : {{ groupe.nom|upper }}</h3>
    </div>
    
    <div class="card-body">
        <form action="{{ path('seancegroupe_presence') }}" method="post" id="presenceForm">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label for="seancegroupe">Sélectionnez la séance <span class="text-danger">*</span></label>
                    <select name="seancegroupe" id="seancegroupe" class="form-control select2" required>
                        <option value="">-- Choisir une séance --</option>
                        {% for seance in seancegroupes %}
                            <option value="{{ seance.id }}">
                                {{ seance.datesuper|date('d-m-Y') }} - {{ seance.theme|default('Sans thème') }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                
                {% if seancegroupes|length == 0 %}
                <div class="col-md-12">
                    <div class="alert alert-warning mt-3">
                        <i class="fas fa-exclamation-triangle"></i>
                        Aucune séance disponible pour ce groupe. Veuillez d'abord créer une séance.
                    </div>
                </div>
                {% endif %}
            </div>

            <hr/>

            <div class="table-responsive">
                <table id="example1" class="table table-bordered table-striped table-hover">
                    <thead>
                        <tr>
                            <th width="50">
                                <input type="checkbox" id="checkAll" title="Tout cocher/Décocher">
                            </th>
                            <th>Fidèle</th>
                            <th>Contact</th>
                            <th>Groupe</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody id="fidele-table-body">
                        {% for fidele in fideles %}
                            <tr class="fidele-row" data-fidele-id="{{ fidele.id }}">
                                <td class="text-center">
                                    <input type="checkbox" name="tab[]" class="fidele-checkbox" value="{{ fidele.id }}" title="Présent(e)">
                                </td>
                                <td>{{ fidele.nomfidele|upper }} {{ fidele.postnomfidele|default('')|upper }}</td>
                                <td>
                                    {% if fidele.contactwhatssap is not empty %}
                                        <i class="fab fa-whatsapp text-success"></i> {{ fidele.contactwhatssap }}
                                    {% elseif fidele.contact1 is not empty %}
                                        <i class="fas fa-phone text-primary"></i> {{ fidele.contact1 }}
                                    {% else %}
                                        <span class="text-muted">Non renseigné</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if fidele.groupefideles|length > 0 %}
                                        {% for gf in fidele.groupefideles %}
                                            {% if gf.groupe.id == groupe.id %}
                                                {{ gf.groupe.nom|upper }}
                                            {% endif %}
                                        {% endfor %}
                                    {% else %}
                                        <span class="badge badge-warning">Non assigné</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="status-badge badge badge-secondary">
                                        <i class="fas fa-clock"></i> Non vérifié
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            <div class="mt-3">
                <button type="submit" class="btn btn-primary" {% if seancegroupes|length == 0 %}disabled{% endif %}>
                    <i class="fas fa-save"></i> {{ button_label|default('Valider') }}
                </button>
                <a href="{{ path('seancegroupe_listeparticipant') }}" class="btn btn-success">
                    <i class="fas fa-list"></i> Liste de présence
                </a>
                <button type="button" id="resetBtn" class="btn btn-secondary">
                    <i class="fas fa-undo"></i> Réinitialiser
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function() {
        $('#checkAll').on('change', function() {
            $('.fidele-checkbox:not(:disabled)').prop('checked', $(this).prop('checked'));
        });
        
        $(document).on('change', '.fidele-checkbox', function() {
            var total = $('.fidele-checkbox:not(:disabled)').length;
            var checked = $('.fidele-checkbox:checked:not(:disabled)').length;
            $('#checkAll').prop('checked', checked === total && total > 0);
        });
        
        $('#resetBtn').on('click', function() {
            $('.fidele-checkbox:not(:disabled)').prop('checked', false);
            $('#checkAll').prop('checked', false);
        });
        
        $('#seancegroupe').on('change', function() {
            var seanceId = $(this).val();
            
            if (!seanceId) {
                $('.fidele-checkbox').prop('disabled', false).prop('checked', false);
                $('.fidele-row').removeClass('table-success');
                $('.status-badge').removeClass('badge-success badge-info').addClass('badge-secondary').html('<i class="fas fa-clock"></i> Non vérifié');
                $('#checkAll').prop('checked', false);
                return;
            }
            
            $('.status-badge').removeClass('badge-secondary').addClass('badge-info').html('<i class="fas fa-spinner fa-spin"></i> Chargement...');
            
            $.ajax({
                url: '{{ path("seancegroupe_get_presences") }}',
                type: 'POST',
                data: { seanceId: seanceId },
                dataType: 'json',
                success: function(response) {
                    if (response.success) {
                        $('.fidele-checkbox').each(function() {
                            var fideleId = parseInt($(this).val());
                            var $row = $(this).closest('.fidele-row');
                            var $statusBadge = $row.find('.status-badge');
                            
                            if (response.presences.includes(fideleId)) {
                                $(this).prop('disabled', true).prop('checked', true);
                                $row.addClass('table-success');
                                $statusBadge.removeClass('badge-secondary badge-info').addClass('badge-success').html('<i class="fas fa-check-circle"></i> Déjà présent');
                            } else {
                                $(this).prop('disabled', false).prop('checked', false);
                                $row.removeClass('table-success');
                                $statusBadge.removeClass('badge-success badge-info').addClass('badge-secondary').html('<i class="fas fa-circle"></i> Non présent');
                            }
                        });
                        $('#checkAll').prop('checked', false);
                    } else {
                        $('.status-badge').removeClass('badge-info').addClass('badge-danger').html('<i class="fas fa-exclamation-triangle"></i> Erreur');
                    }
                },
                error: function() {
                    $('.status-badge').removeClass('badge-info').addClass('badge-danger').html('<i class="fas fa-exclamation-triangle"></i> Erreur chargement');
                }
            });
        });
        
        $('#presenceForm').on('submit', function(e) {
            var seancegroupe = $('#seancegroupe').val();
            var checked = $('.fidele-checkbox:checked:not(:disabled)').length;
            
            if (!seancegroupe) {
                e.preventDefault();
                alert('Veuillez sélectionner une séance.');
                return false;
            }
            if (checked === 0) {
                e.preventDefault();
                alert('Veuillez sélectionner au moins un fidèle présent.');
                return false;
            }
            return true;
        });
        
        if ($('#seancegroupe').val()) {
            $('#seancegroupe').trigger('change');
        }
    });
</script>
{% endblock %}