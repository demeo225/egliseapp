{% extends "home/index.html.twig" %}

{% block title %}Gestion Nationalité{% endblock %}

{% block body %}

    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion des nationalités</h3>
        </div>
        <div class="card card-body">

            {{ form_start(form) }}
            {{ form_errors(form) }}
   

            <div class="row mb-4">

                <div class="col-3">

                    <div class="form-group">
                        {{ form_label(form.libelle, "Libellé", {'label_attr':{'class':'col-form-label'}})}}
                        {{ form_errors(form.libelle)  }}
                        <div>
                            {{ form_widget(form.libelle,{'label_attr':{'class':'foo'}}) }}
                        </div>
                    </div>

                </div>
            </div>

            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

                <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

                <div class="col-md-2"><a href="{{ path('nationalite') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div>  
        <div>
            {{ form_rest(form) }}
        </div>
        {{ form_end(form) }}
    </div>
</div



{% endblock %}