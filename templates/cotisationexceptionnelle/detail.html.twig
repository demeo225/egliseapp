{% extends "home/index.html.twig" %}

{% block title %}Details de la cotisation du {{cotisationexceptionnelle.datecotise|date('d-m-Y')}}
{% endblock %}

{% block body %}

    <h3>
        <u>
            <strong>Details de la cotisation du {{cotisationexceptionnelle.datecotise|date('d-m-Y')}}</strong>
        </u>
    </h3>
    <div class="card">
        <table class="table">

            <thead>
                <tr>
                    <th>Date</th>
                    <th>Objet</th>
                    <th>Beneficiaire</th>
                    <th>Montant estimé</th>
                    <th>Montant reçu</th>
                    <th>Etat cotisation</th>



                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>

                    <td>{{ cotisationexceptionnelle.datecotise|date('d-m-Y')}}</td>
                    <td>{{ cotisationexceptionnelle.objet}}</td>
                    <td>{{ cotisationexceptionnelle.beneficiaire}}</td>
                    <td>{{ cotisationexceptionnelle.montant|number_format(0, '.', ' ')}}</td>
                    <td>{{ cotisationexceptionnelle.montantpercu|number_format(0, '.', ' ')}}</td>
                    {% set montant =cotisationexceptionnelle.montant%}
                    {% set montantpercu = cotisationexceptionnelle.montantpercu %}
                    {% set reste =cotisationexceptionnelle.reste %}
                    {% set reste =(montant - montantpercu) %}


                    <td> 
                        {% if  reste > 0 %}
                       Manquant  {{ reste|abs }}
                        {% endif %}
                            {% if  reste < 0 %}
                            Excès {{ reste|abs }}
                        {% endif %}
                            {% if  reste == 0 %}
                             Montant atteint 
                        {% endif %}

                        </td>


                    <td>
                        <a href="{{ path('cotisationexceptionnelle_update', {'id': cotisationexceptionnelle.id}) }}">
                            <span style="font-size: 2em; color: Dodgerblue;">

                                <i class="fas fa-edit"></i>

                            </span>
                        </a>


                    </td>
                </tr>
            </tbody>
            </td>
            </tr></tbody><tfooter>
                <tr>
                    <td>
                        <a href='{{ path('cotisationexceptionnelle') }}'>
                            <button class="btn btn-primary">Retour à la liste</button>
                        </a>
                    </td>
                    <td>
                        <form method="post" action="{{ path('cotisationexceptionnelle_delete', {'id': cotisationexceptionnelle.id}) }}" onsubmit="return confirm('etes vous sur de vouloir supprimer?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cotisationexceptionnelle.id) }}">
                            <button class="btn btn-danger">
                                Delete
                            </button>
                        </form>

                    </td>

                </tr></tfooter></form></table></i></div>{% endblock %}
