{% extends "home/index.html.twig" %}

{% block title %}Gestion des cotisation exceptionnelles{% endblock %}

{% block body %}


    <div class="card-body">

        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Gestion des cotisations excepptionnelles</h3>
            </div>
      <div class="offset-1 col-md-10 mt-2 mb-2">
                {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} my-alert" role="alert">
                            <h5 class="m-0 flash-text">{{ message }}</h5>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
            <!-- /.card-header -->
            <div class="card-body">
                <a href='{{ path('cotisationexceptionnelle_add') }}'>
                    <button class="btn btn-primary">Nouveau</button>
                </a>
                <a href='{{ path('cotisation') }}'>
                    <button class="btn btn-success">Cotisation ordinaire </button>
                </a>

                <hr style="visibility: hidden" /> 

                <table id="example1" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Objet</th>
                            <th>Bénéficiaire</th>
                            <th>Montant Visé</th>
                            <th>Montant cotisé</th>
                            <th>Objectif</th>
                            <th>Detail</th>
                            <th>Modifier</th>
                            <th>Supprimer</th>


                        </tr>
                    </thead>
                    <tbody>
                        {% for cotisationexceptionnelle in cotisationexceptionnelles %}
                            <tr>
                                <td>{{ date_format(cotisationexceptionnelle.datecotise)}}</td>
                                <td>{{ cotisationexceptionnelle.objet}}</td>
                                <td>{{ cotisationexceptionnelle.beneficiaire}}</td>
                                <td>{{ cotisationexceptionnelle.montant}}</td>
                                <td>{{ cotisationexceptionnelle.montantpercu}}</td>
                                <td>
                                    {% set cotisation =cotisationexceptionnelle.montant  %}
                                    {% set recu = cotisationexceptionnelle.montantpercu %}
                                    {% if (cotisation - recu ) > 0 %}
                                        Non atteint
                                    {% else %}
                                        <b>Atteint</b>
                                    {% endif %}

                                </td>

                                <td>
                                    <a href="{{ path('cotisationexceptionnelle_detail', {'id': cotisationexceptionnelle.id}) }}">
                                        <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-list"></i>
                                        </span>
                                    </a>
                                </td>


                                <td>
                                    <a href="{{ path('cotisationexceptionnelle_update', {'id': cotisationexceptionnelle.id}) }}">
                                        <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-edit"></i>
                                        </span>
                                    </a>
                                </td>
                                <td>
                                    <form method="post" action="{{ path('cotisationexceptionnelle_delete', {'id': cotisationexceptionnelle.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cotisationexceptionnelle.id) }}">

                                        <button class="btn">
                                            <span style="font-size: 1em; color: red;">
                                                <i class="fas fa-trash-alt"></i>
                                            </span>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                      
                        {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>


    </div>



{% endblock %}
