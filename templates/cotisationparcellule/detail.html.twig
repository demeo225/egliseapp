{% extends 'home/index.html.twig' %}


{% block title %}
    Details {{ nomcotisationparcellule|upper }} {% endblock %}

    {% block body %}



        <div class="card card-primary">

            <div class="card-header">
                <h3 class="card-title">Fidèles ayant cotisé pour: {{ nomcotisationparcellule|upper }} </h3>
            </div>
            <h3><b> </b></h3>
            <div class="container-fluid">
                <div class="row">

                    <!-- /.card-header -->
                    <div class="card-body">

                        <a href='{{ path('app_cotisationparcellule_index') }}'>
                            <button class="btn btn-success">Liste des cotisations</button>
                        </a>
                        {% for cotiserparcellule in cotiserparcellules %}
                            
                            {% set sum = cotiserparcellule.montantpayer + sum ?? 0 %}
                            {% if loop.last  %} Total cotisé :<b> {{ sum|number_format(0, '.', ' ')}} F CFA -- {{ sum|format_number(style='spellout')}}F CFA</b>  {% endif %}
                             
                        {% endfor %}
                        <hr style="visibility: hidden" />
                        <table id="example1" class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Objet</th>
                                    <th>Cellule</th>
                                    <th>Montant </th>
                                    <th>Montant payé</th>
                                    <th>Reste</th>
                                  
                                </tr>
                            </thead>
                            <tbody>
                                {% for cotiserparcellule in cotiserparcellules %}
                                        <tr>
                                            <td> {% if cotiserparcellule.cotisationparcellule is not null  %} {{ cotiserparcellule.cotisationparcellule.objet|upper }}{% else %} {% endif %}</td>
                                            <td>{% if cotiserparcellule.cellule is not null  %}{{ cotiserparcellule.cellule.nom|upper }}{% else %} {% endif %}</td>
                                            <td>{{ cotiserparcellule.cotisationparcellule.montant|number_format(0, '.', ' ') }}</td>
                                            <td>{{ cotiserparcellule.montantpayer|number_format(0, '.', ' ') }}</td>
                                            <td>  {% if  cotiserparcellule.reste == 0 %} <b>Soldé</b> 
                                            {% elseif cotiserparcellule.reste >0 %} {{ cotiserparcellule.reste|number_format(0, '.', ' ') }} {% elseif cotiserparcellule.reste < 0 %} 
                                                <i class="btn btn-success"> Soldé </i> {% endif %}

                                            </td>
                                   
                                    {% else %}
                                        <tr>
                                            <td colspan="4">Aucune donnée trouvée</td>
                                        </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>

                            </div>


                        </div>
                    </div>


                    {% endblock %}
