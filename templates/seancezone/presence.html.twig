{% extends "home/index.html.twig" %}

{% block title %}Présences & absences - {{ zone.nom|upper }}{% endblock %}

{% block body %}
<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Gestion présence de : {{ zone.nom|upper }}</h3>
    </div>
    
    <div class="card-body">
        <form action="{{ path('app_seancezone_presence') }}" method="post" id="presenceForm">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label for="seancezone">Sélectionnez la séance <span class="text-danger">*</span></label>
                    <select name="seancezone" id="seancezone" class="form-control select2" required>
                        <option value="">-- Choisir une séance --</option>
                        {% for seance in seancezones %}
                            <option value="{{ seance.id }}">
                                {{ seance.datesuper|date('d-m-Y') }} - {{ seance.theme|default('Sans thème') }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                
                {% if seancezones|length == 0 %}
                <div class="col-md-12">
                    <div class="alert alert-warning mt-3">
                        <i class="fas fa-exclamation-triangle"></i>
                        Aucune séance disponible pour cette zone. Veuillez d'abord créer une séance.
                    </div>
                </div>
                {% endif %}
            </div>

            <hr/>

            <div class="table-responsive">
                <table id="example1" class="table table-bordered table-striped table-hover">
                    <thead>
                        <tr>
                            <th width="50">
                                <input type="checkbox" id="checkAll" title="Tout cocher/Décocher">
                            </th>
                            <th>Fidèle</th>
                            <th>Contact</th>
                            <th>Famille</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody id="fidele-table-body">
                        {% for fidele in fideles %}
                            <tr class="fidele-row" data-fidele-id="{{ fidele.id }}">
                                <td class="text-center">
                                    <input type="checkbox" name="tab[]" class="fidele-checkbox" value="{{ fidele.id }}" title="Présent(e)">
                                </td>
                                <td>{{ fidele.nomfidele|upper }} {{ fidele.postnomfidele|default('')|upper }} {# Ajout du postnom si disponible #}</td>
                                <td>
                                    {% if fidele.contactwhatssap is not empty %}
                                        <i class="fab fa-whatsapp text-success"></i> {{ fidele.contactwhatssap }}
                                    {% elseif fidele.contact1 is not empty %}
                                        <i class="fas fa-phone text-primary"></i> {{ fidele.contact1 }}
                                    {% else %}
                                        <span class="text-muted">Non renseigné</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if fidele.zone is not null %}
                                        {{ fidele.zone.nom|upper }}
                                    {% else %}
                                        <span class="badge badge-warning">Non assigné</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="status-badge badge badge-secondary">
                                        <i class="fas fa-clock"></i> Non vérifié
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            <div class="mt-3">
                <button type="submit" class="btn btn-primary" {% if seancezones|length == 0 %}disabled{% endif %}>
                    <i class="fas fa-save"></i> {{ button_label|default('Valider') }}
                </button>
                <a href="{{ path('app_seancezone_listeparticipant') }}" class="btn btn-success">
                    <i class="fas fa-list"></i> Liste de présence
                </a>
                <button type="button" id="resetBtn" class="btn btn-secondary">
                    <i class="fas fa-undo"></i> Réinitialiser
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    $(document).ready(function() {
        // Variable pour stocker l'état des présences
        var presencesData = {};
        
        // Gestion du checkbox "Tout cocher"
        $('#checkAll').on('change', function() {
            $('.fidele-checkbox:not(:disabled)').prop('checked', $(this).prop('checked'));
        });
        
        // Si un checkbox est décoché, décocher "Tout cocher"
        $(document).on('change', '.fidele-checkbox', function() {
            var totalCheckboxes = $('.fidele-checkbox:not(:disabled)').length;
            var checkedCheckboxes = $('.fidele-checkbox:checked:not(:disabled)').length;
            
            if (checkedCheckboxes === totalCheckboxes && totalCheckboxes > 0) {
                $('#checkAll').prop('checked', true);
            } else {
                $('#checkAll').prop('checked', false);
            }
        });
        
        // Bouton réinitialiser
        $('#resetBtn').on('click', function() {
            $('.fidele-checkbox:not(:disabled)').prop('checked', false);
            $('#checkAll').prop('checked', false);
        });
        
        // Chargement des présences quand la séance change
        $('#seancezone').on('change', function() {
            var seanceId = $(this).val();
            
            if (!seanceId) {
                // Réinitialiser l'affichage
                $('.fidele-checkbox').prop('disabled', false).prop('checked', false);
                $('.fidele-row').removeClass('table-success table-danger');
                $('.status-badge').removeClass('badge-success badge-info badge-danger').addClass('badge-secondary').html('<i class="fas fa-clock"></i> Non vérifié');
                $('#checkAll').prop('checked', false);
                return;
            }
            
            // Afficher un indicateur de chargement
            $('.status-badge').removeClass('badge-secondary').addClass('badge-info').html('<i class="fas fa-spinner fa-spin"></i> Chargement...');
            
            // Requête AJAX
            $.ajax({
                url: '{{ path("seancezone_get_presences") }}',
                type: 'POST',
                data: { seanceId: seanceId },
                dataType: 'json',
                timeout: 10000, // Timeout après 10 secondes
                success: function(response) {
                    if (response.success) {
                        presencesData = response;
                        
                        // Mettre à jour les checkboxes
                        $('.fidele-checkbox').each(function() {
                            var fideleId = parseInt($(this).val());
                            var $row = $(this).closest('.fidele-row');
                            var $statusBadge = $row.find('.status-badge');
                            
                            if (response.presences && response.presences.includes(fideleId)) {
                                $(this).prop('disabled', true).prop('checked', true);
                                $row.addClass('table-success');
                                $statusBadge.removeClass('badge-secondary badge-info').addClass('badge-success').html('<i class="fas fa-check-circle"></i> Déjà présent');
                            } else {
                                $(this).prop('disabled', false).prop('checked', false);
                                $row.removeClass('table-success');
                                $statusBadge.removeClass('badge-success badge-info').addClass('badge-secondary').html('<i class="fas fa-circle"></i> Non présent');
                            }
                        });
                        
                        // Décocher le checkbox "Tout cocher"
                        $('#checkAll').prop('checked', false);
                        
                        // Afficher une notification toast (optionnel)
                        console.log('✓ Séance chargée: ' + response.seanceDate + ' - ' + response.seanceTheme);
                        
                        // Compter le nombre de présences déjà enregistrées
                        var dejaPres = response.presences ? response.presences.length : 0;
                        if (dejaPres > 0) {
                            console.log(dejaPres + ' fidèle(s) déjà présent(s) pour cette séance');
                        }
                        
                    } else {
                        console.error('Erreur:', response.error);
                        $('.status-badge').removeClass('badge-info').addClass('badge-danger').html('<i class="fas fa-exclamation-triangle"></i> ' + (response.error || 'Erreur'));
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Erreur AJAX:', error);
                    var errorMsg = 'Erreur chargement';
                    if (status === 'timeout') {
                        errorMsg = 'Délai dépassé';
                    } else if (xhr.status === 403) {
                        errorMsg = 'Accès refusé';
                    } else if (xhr.status === 404) {
                        errorMsg = 'Service non trouvé';
                    }
                    $('.status-badge').removeClass('badge-info').addClass('badge-danger').html('<i class="fas fa-exclamation-triangle"></i> ' + errorMsg);
                }
            });
        });
        
        // Validation avant soumission
        $('#presenceForm').on('submit', function(e) {
            var seancezone = $('#seancezone').val();
            var checked = $('.fidele-checkbox:checked:not(:disabled)').length;
            
            if (!seancezone) {
                e.preventDefault();
                showAlert('Veuillez sélectionner une séance.', 'warning');
                return false;
            }
            
            if (checked === 0) {
                e.preventDefault();
                showAlert('Veuillez sélectionner au moins un fidèle présent.', 'warning');
                return false;
            }
            
            // Confirmation optionnelle
            return confirm('Voulez-vous vraiment enregistrer ' + checked + ' présence(s) ?');
        });
        
        // Déclencher le changement de séance si une séance est déjà sélectionnée
        if ($('#seancezone').val()) {
            $('#seancezone').trigger('change');
        }
        
        // Fonction d'alerte personnalisée (si vous utilisez SweetAlert ou autre)
        function showAlert(message, type) {
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    title: type === 'warning' ? 'Attention' : 'Information',
                    text: message,
                    icon: type,
                    confirmButtonText: 'OK'
                });
            } else {
                alert(message);
            }
        }
    });
</script>
{% endblock %}