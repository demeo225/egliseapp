{% extends "home/index.html.twig" %}

{% block title %}Liste de présence des zones{% endblock %}

{% block body %}
<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-map-marker-alt"></i> Liste de présence des zones
        </h3>
    </div>
    
    <div class="card-body">
     <a href="{{ path('seancezone_presence') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nouvelle présence
        </a>
        <a href="{{ path('seancezone_index') }}" class="btn btn-success">
            <i class="fas fa-list"></i> Liste des activités
        </a>
           <hr />
        {% if presencesParDateEtZone is empty %}
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> Aucune présence enregistrée.
            </div>
        {% else %}
            {# Cartes des taux globaux #}
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="small-box bg-info">
                        <div class="inner">
                            <h3>{{ totalGeneral }}</h3>
                            <p>Total des présences</p>
                        </div>
                        <div class="icon"><i class="fas fa-user-check"></i></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="small-box bg-primary">
                        <div class="inner">
                            <h3>{{ totalMembresGeneral }}</h3>
                            <p>Total des membres</p>
                        </div>
                        <div class="icon"><i class="fas fa-users"></i></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="small-box bg-success">
                        <div class="inner">
                            <h3>{{ tauxGeneral }}%</h3>
                            <p>Taux de participation global</p>
                        </div>
                        <div class="icon"><i class="fas fa-chart-line"></i></div>
                    </div>
                </div>
            </div>
            
            {# Boucle sur les dates #}
            {% for dateKey, dateData in presencesParDateEtZone|sort|reverse %}
                <div class="card card-dark mt-3">
                    <div class="card-header bg-dark text-white">
                        <h4 class="card-title">
                            <i class="fas fa-calendar"></i> 
                            Séance du {{ dateData.date|date('d/m/Y') }}
                        </h4>
                        <div class="card-tools">
                            <span class="badge badge-light">
                                Taux global: {{ dateData.taux_global_jour }}%
                            </span>
                        </div>
                    </div>
                    <div class="card-body">
                        {% for zoneData in dateData.zones %}
                            <div class="card card-info mt-2 mb-3">
                                <div class="card-header bg-info text-white">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="card-title">
                                                <i class="fas fa-map-marker-alt"></i> 
                                                Zone : <strong>{{ zoneData.zone_nom }}</strong>
                                            </h5>
                                        </div>
                                        <div class="col-md-6 text-right">
                                            <span class="badge badge-light mr-2">
                                                <i class="fas fa-users"></i> Membres: {{ zoneData.nb_membres }}
                                            </span>
                                            <span class="badge badge-light">
                                                <i class="fas fa-user-check"></i> Présents: {{ zoneData.total_presences }}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="progress mb-3" style="height: 25px;">
                                        {% set taux = zoneData.taux_presence %}
                                        {% set couleur = taux >= 75 ? 'success' : (taux >= 50 ? 'warning' : (taux >= 25 ? 'info' : 'danger')) %}
                                        <div class="progress-bar bg-{{ couleur }} progress-bar-striped" 
                                             role="progressbar" 
                                             style="width: {{ taux }}%">
                                            Taux de présence: {{ taux }}%
                                        </div>
                                    </div>
                                    
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-striped">
                                            <thead>
                                                <tr>
                                                    <th>#</th>
                                                    <th>Fidèle</th>
                                                    <th>Contact</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {% for presence in zoneData.presences %}
                                                    {% if is_granted("seancezone_presence", presence) %}
                                                        <tr>
                                                            <td>{{ loop.index }}</td>
                                                            <td>{{ presence.fidele.nomfidele }} </td>
                                                            <td>{{ presence.fidele.contact1|default('-') }}</td>
                                                            <td class="text-center">
                                                                {% if is_granted("POST_EDIT", presence) %}
                                                                    <form method="post" action="{{ path('presencezone_delete', {'id': presence.id}) }}" 
                                                                          onsubmit="return confirm('Supprimer cette présence ?');">
                                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ presence.id) }}">
                                                                        <button class="btn btn-sm btn-danger">
                                                                            <i class="fas fa-trash-alt"></i>
                                                                        </button>
                                                                    </form>
                                                                {% endif %}
                                                            </td>
                                                        </tr>
                                                    {% endif %}
                                                {% endfor %}
                                            </tbody>
                                            <tfoot>
                                                <tr class="bg-light">
                                                    <th colspan="3" class="text-right">SOUS-TOTAL :</th>
                                                    <th class="text-center">{{ zoneData.total_presences }}</th>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                        
                        <div class="alert alert-secondary mt-2">
                            <strong>Total de la journée :</strong> {{ dateData.total_jour }} présence(s)
                            - <strong>Taux de participation :</strong> {{ dateData.taux_global_jour }}%
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>
{% endblock %}