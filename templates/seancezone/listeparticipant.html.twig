{% extends "home/index.html.twig" %}

{% block title %}Liste de presence Zone{% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste de présence aux activités des zones</h3>
        </div>
    <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
        <div class="container-fluid">
           

                <!-- /.card-header -->
                <div class="card-body">
    
                    <a href='{{ path('app_seancezone_presence') }}'>
                        <button class="btn btn-primary">Nouveau</button>
                    </a>
                    <a href="{{ path('app_cotiserzone_index') }}">
                        <button class="btn btn-success">Paiement de cotisation</button>

                    </a>
                    <a href='{{ path('app_seancezone_index') }}'>
                        <button class="btn btn-success">Liste des activités </button>
                    </a>

                    <hr style="visibility: hidden" />

                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                        <tr>
                        <th>Zone</th>
                        <th>Objet</th>
                        <th>Date</th>
                        <th>Lieu</th>
                        <th>Fidèle</th>
                        <th>Contact</th>
                        <th>Photo</th>
                        <th>Retirer</th>
                        </tr>
                        </thead>
                        
                        <tbody>
                            {% for diff in differences %}
                                {% set presence = 0 %}
                                {% set presencezone = 0 %}
                                {% for presencezone in presencezones %}
                                    {% if is_granted("seancezone_presence", presencezone) %}
                                        {% if diff.datesuper ==  presencezone.seancezone.datesuper %}
                                            {% set presence = (presencezone|length) + presence ?? 0 %}
                                            <tr>

                                                <td>{{ presencezone.zone.nom|upper}}</td>
                                                <td>{{ presencezone.seancezone.objet}}</td>
                                                <td>{{ presencezone.seancezone.datesuper ? presencezone.seancezone.datesuper|date('d-m-Y') : '' }}</td>
                                                <td>{{ presencezone.seancezone.lieu}}</td>
                                                <td>{{ presencezone.fidele.nomfidele|upper}}</td>
                                                <td> {% if presencezone.fidele.contactwhatssap is not empty %} {{ presencezone.fidele.contactwhatssap}} {% else %} {{ presencezone.fidele.contact1}} {% endif %}</td>
                                                <td>    
                                                    <img src="{{ asset('uploads/photos/'~presencezone.fidele.photoFile )}}"  class="img-size-50 mr-3 img-suqare"/> 

                                                </td>

                                                <td>
                                                    <form method="post" action="{{ path('presencezone_delete', {'id': presencezone.id}) }}" onsubmit="return confirm('etes vous-sûr de vouloir supprimer?');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ presencezone.id) }}">

                                                        <button class="btn">
                                                            <span style="font-size: 1em; color: red;">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </span>
                                                        </button>
                                                    </form>
                                                </td>

                                            </tr>
                                        {% endif %}
                                    {% endif %}

                                {% endfor %}
                                {% if presence == 0 %}

                                {% elseif presence != 0  %}

                                    <tr>
                                        <td colspan="6"><b>Total fidèles</b> </td>

                                        <td colspan="2"><b> {{ presence }} </b> </td>
                                    </tr>

                                {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

            </div>


        </div>
    </div>



{% endblock %}
