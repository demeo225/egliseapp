{% extends "home/index.html.twig" %}

{% block title %}Liste des séances zones{% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Activités des zones</h3>
        </div>
  <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
           
        <!-- /.card-header -->
        <div class="card-body">
            {% if is_granted('seancezone_create') %}
                <a href="{{ path('app_seancezone_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Nouveau
                </a>
            {% endif %}
            <a href="{{ path('app_invitezone_index') }}" class="btn btn-success">
                <i class="fas fa-user-plus"></i> Invités
            </a>
            <a href="{{ path('app_cotisationzone_index') }}" class="btn btn-success">
                <i class="fas fa-hand-holding-usd"></i> Cotisation
            </a>
            <a href="{{ path('app_cotiserzone_index') }}" class="btn btn-success">
                <i class="fas fa-money-bill"></i> Paiement de cotisation
            </a>
            <a href="{{ path('app_seancezone_listeparticipant') }}" class="btn btn-success">
                <i class="fas fa-list"></i> Liste de présence
            </a>
            <a href="{{ path('app_bilan_zone2') }}" class="btn btn-danger">
                <i class="fas fa-chart-bar"></i> Bilan
            </a>
            <a href="{{ path('app_depensezone_index') }}" class="btn btn-primary">
                <i class="fas fa-shopping-cart"></i> Dépenses
            </a>
        </div>
            <hr style="visibility: hidden" />

            <table id="example1" class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Zone</th>
                        <th>Lieu</th>
                        <th>Theme</th>
                        <th>Invités</th>
                        <th>Présents</th>
                        <th>Absents</th>
                        <th>Details</th>

                    </tr>
                </thead>
                  <tbody>
                {% if is_granted('ROLE_RESPONSABLE_ZONE') %}
                    {% for diff in differences %}
                        {% set totaux = 0 %}
                        {% for seancezone in seancezones %}
                            {% if diff.datesuper == seancezone.datesuper %}
                                {% if is_granted("seancezone_edit", seancezone) %}
                                    <tr>
                                        <td>{{ seancezone.datesuper|format_datetime('full', 'none', locale='fr') }}</td>
                                        <td>{{ seancezone.zone.nom }}</td>
                                        <td>{{ seancezone.lieu }}</td>
                                        <td>
                                            {% set nbrepresent = seancezone.nbrepresent|default(0) %}
                                            {% set femme = seancezone.femme|default(0) %}
                                            {% set enfant = seancezone.enfant|default(0) %}
                                            {% set total = enfant + nbrepresent + femme %}
                                            {% set totaux = total + totaux %}
                                            {{ total }}
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-info btn-invites" 
                                                    data-target="{{ path('seancezone_search_invitezones', {'id': seancezone.id}) }}">
                                                <i class="fas fa-users"></i> {{ seancezone.invitezones|length }}
                                            </button>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-success btn-present" 
                                                    data-id="{{ seancezone.id }}"
                                                    data-zone="{{ seancezone.zone.id }}">
                                                <i class="fas fa-check-circle"></i> Présents
                                            </button>
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-danger btn-absent" 
                                                    data-id="{{ seancezone.id }}"
                                                    data-zone="{{ seancezone.zone.id }}">
                                                <i class="fas fa-times-circle"></i> Absents
                                            </button>
                                        </td>
                                        <td class="text-center">
                                            <a href="{{ path('app_seancezone_show', {'id': seancezone.id}) }}" class="btn btn-sm btn-primary">
                                                <i class="fas fa-list"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                        {% if totaux > 0 %}
                            <tr class="bg-light">
                                <td colspan="3"><strong>Totaux</strong></td>
                                <td><strong>{{ totaux }}</strong></td>
                                <td colspan="4"></td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    {% for seancezone in seancezones %}
                        {% if is_granted("seancezone_edit", seancezone) %}
                            <tr>
                                <td>{{ seancezone.datesuper ? seancezone.datesuper|date('d-m-Y') : '' }}</td>
                                <td>{{ seancezone.zone.nom }}</td>
                                <td>{{ seancezone.lieu }}</td>
                                <td>
                                    {% set nbrepresent = seancezone.nbrepresent|default(0) %}
                                    {% set femme = seancezone.femme|default(0) %}
                                    {% set enfant = seancezone.enfant|default(0) %}
                                    {{ enfant + nbrepresent + femme }}
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-info btn-invites" 
                                            data-target="{{ path('seancezone_search_invitezones', {'id': seancezone.id}) }}">
                                        <i class="fas fa-users"></i> {{ seancezone.invitezones|length }}
                                    </button>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-success btn-present" 
                                            data-id="{{ seancezone.id }}"
                                            data-zone="{{ seancezone.zone.id }}">
                                        <i class="fas fa-check-circle"></i> Présents
                                    </button>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-danger btn-absent" 
                                            data-id="{{ seancezone.id }}"
                                            data-zone="{{ seancezone.zone.id }}">
                                        <i class="fas fa-times-circle"></i> Absents
                                    </button>
                                </td>
                                <td class="text-center">
                                    <a href="{{ path('app_seancezone_show', {'id': seancezone.id}) }}" class="btn btn-sm btn-primary">
                                        <i class="fas fa-list"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endif %}
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
    </div>
</div>

{# Modal pour les présents #}
<div class="modal fade" id="presentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success">
                <h5 class="modal-title">
                    <i class="fas fa-check-circle"></i> Liste des présents
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

{# Modal pour les absents #}
<div class="modal fade" id="absentModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-danger">
                <h5 class="modal-title">
                    <i class="fas fa-times-circle"></i> Liste des absents
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

{# Modal pour les invités (existant) #}
<div class="modal fade" id="fidelesModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info">
                <h5 class="modal-title">
                    <i class="fas fa-users"></i> Liste des invités
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
  
    
<script>
$(document).ready(function() {
    // Modal pour les invités
    $(document).on('click', 'button.btn-invites', function() {
        let modal = new bootstrap.Modal(document.getElementById('fidelesModal'), { keyboard: false });
        let container = $('#fidelesModal .modal-body');
        
        container.html('<div class="text-center"><i class="fas fa-spinner fa-spin fa-2x"></i><p>Chargement...</p></div>');
        
        $.ajax({
            type: 'POST',
            url: $(this).data('target'),
            success: function(html) {
                container.html(html);
                modal.show();
            },
            error: function() {
                container.html('<div class="alert alert-danger">Erreur lors du chargement</div>');
                modal.show();
            }
        });
    });
    
    // Modal pour les présents
    $(document).on('click', 'button.btn-present', function() {
        let modal = new bootstrap.Modal(document.getElementById('presentModal'), { keyboard: false });
        let container = $('#presentModal .modal-body');
        let seanceId = $(this).data('id');
        let zoneId = $(this).data('zone');
        
        container.html('<div class="text-center"><i class="fas fa-spinner fa-spin fa-2x"></i><p>Chargement de la liste des présents...</p></div>');
        
        $.ajax({
            type: 'POST',
            url: '{{ path('seancezone_presents') }}',
            data: {
                seance_id: seanceId,
                zone_id: zoneId
            },
            success: function(html) {
                container.html(html);
                modal.show();
            },
            error: function() {
                container.html('<div class="alert alert-danger">Erreur lors du chargement de la liste des présents</div>');
                modal.show();
            }
        });
    });
    
    // Modal pour les absents
    $(document).on('click', 'button.btn-absent', function() {
        let modal = new bootstrap.Modal(document.getElementById('absentModal'), { keyboard: false });
        let container = $('#absentModal .modal-body');
        let seanceId = $(this).data('id');
        let zoneId = $(this).data('zone');
        
        container.html('<div class="text-center"><i class="fas fa-spinner fa-spin fa-2x"></i><p>Chargement de la liste des absents...</p></div>');
        
        $.ajax({
            type: 'POST',
            url: '{{ path('seancezone_absents') }}',
            data: {
                seance_id: seanceId,
                zone_id: zoneId
            },
            success: function(html) {
                container.html(html);
                modal.show();
            },
            error: function() {
                container.html('<div class="alert alert-danger">Erreur lors du chargement de la liste des absents</div>');
                modal.show();
            }
        });
    });
});
</script>
{% endblock %}