{% extends "home/index.html.twig" %}

{% block title %}Liste de presence {% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste de présence </h3>
        </div>
         <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        <div class="container-fluid">

                <!-- /.card-header -->
                <div class="card-body">


                    <a href='{{ path('pastorale_presence') }}'>
                        <button class="btn btn-primary">Nouveau</button>
                    </a>
                    <a href='{{ path('app_pastorale_index') }}'>
                        <button class="btn btn-success">Liste des pastorale </button>
                    </a>

                    <hr style="visibility: hidden" />

                    <table id="example1" class="table table-bordered table-striped">

                        <thead>
                        <tr>
                        <th>Date</th>
                        <th>Fidèle</th>
                        <th>Photo</th>
                        <th>Retirer</th>
                        </tr>
                        </thead>
                        
                        <tbody>
                            {% for diff in differences %}
                                {% set presence = 0 %}
                                {% set presencepastorale = 0 %}
                                {% for presencepastorale in presencepastorales %}

                                    {% if diff.datepastorale ==  presencepastorale.pastorale.datepastorale %}
                                        {% set presence = (presencepastorale|length) + presence ?? 0 %}
                                        {% if loop.last  %} <b hidden>    {{ presence }}    </b>  {% endif %}
                                    <tr>
                                        <td> {% if presencepastorale.pastorale is not empty %} {{ presencepastorale.pastorale.datepastorale ? presencepastorale.pastorale.datepastorale|date('d-m-Y') : '' }} 
                                        {% else %} {% endif %}</td>
                                    <td>{{ presencepastorale.fidele.nomfidele|upper}}</td>


                                    <td>    
                                        <img src="{{ asset('uploads/photos/'~presencepastorale.fidele.photoFile )}}"  class="img-size-50 mr-3 img-suqare"/> 

                                    </td>
                                    <td>
                                        <form method="post" action="{{ path('presencepastorale_delete', {'id': presencepastorale.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ presencepastorale.id) }}">

                                            <button class="btn">
                                                <span style="font-size: 1em; color: red;">
                                                    <i class="fas fa-trash-alt" title="Retirer"></i>
                                                </span>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                {% endif %}
                                    {% else %}
                                        {% if (presencepastorale|length) ==0 %}
                                            <tr>
                                                <td colspan="5">aucune donnée trouvée</td>
                                            </tr>
                                        {% endif %}
                                        {% endfor %}
                                            {% if presence !=0 %}
                                                <tr>
                                                    <td><b>Total fidèles</b> </td>
                                                    <td colspan="3"><b> {{ presence }} </b> </td>

                                                    <td colspan="3"> </td>
                                                </tr>
                                            {% else %}
                                            {% endif %}

                                            {% endfor %}
                                                </tbody>
                                            </table>
                                        </div>

                                    </div>


                                </div>
                            </div>



                            {% endblock %}
