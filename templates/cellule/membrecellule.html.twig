{% extends "home/index.html.twig" %}

{% block title %}Membres de la cellule CELLULE :{{ nomcellule|upper }}{% endblock %}

{% block body %}


    <div class="card card-primary">

        <div class="card-header">
            <h3 class="card-title">LISTE DES MEMBRES DE LA CELLULE :{{ nomcellule|upper }} </h3>
        </div>
        <div class="row">

            <!-- /.card-header -->
            <div class="card-body">

                <a href='{{ path('cellule') }}'>
                    <button class="btn btn-success">Retour à la liste</button>
                </a>   <a href='{{ path('cellule_printmembre',{'id':id}) }}'>


                    <button class="btn btn-primary">Impression avancée</button>
                </a>  
                <hr style="visibility: hidden" />

                <table id="example1" class="table table-bordered table-striped">

                    <thead>
                    <th>Fidèle</th>
                    <th>Contact</th>
                    <th>Quartier</th>
                    <th>baptème</th>
                    <th>Photo</th>
                    </thead>
                    </tr>
                    <tbody>
                        {% for fidele in fidele %}

                            <tr>

                                <td>{{ fidele.nomfidele|upper}}</td>
                                <td> {% if fidele.contactwhatssap is not empty %} {{ fidele.contactwhatssap}} {% else %} {{ fidele.contact1}} {% endif %}</td>
                                <td> {% if  fidele.quartier is not empty %} {{ fidele.quartier.libelle}} {% else %} {% endif %}</td>
                                <td> {% set stutbapteme= fidele.stutbapteme %}
                                    {% set sexe= fidele.sexe %}

                                    {% if stutbapteme == 'Oui' and sexe == 'Homme' %}
                                        Baptisé
                                    {% elseif stutbapteme == 'Non' and sexe == 'Homme' %}
                                        Non baptisé
                                    {% elseif stutbapteme == 'Oui' and sexe == 'Femme' %}
                                        Baptisée
                                    {% else %}
                                        Non Baptisée
                                    {% endif %}


                                </td>

                                <td>    <a href="{{ path('fidele_detail', {'id': fidele.id}) }}">    <img src="{{ asset('uploads/photos/'~fidele.photoFile )}}"  class="img-size-50 mr-3 img-suqare"/> </a>  </td>

                            </tr>

                        {% else %}
                            <tr>
                                <td colspan="5">aucune donnée trouvée</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>


    </div>



{% endblock %}
