


    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion quartier</h3>
        </div>
        <div class="card card-body">

        {{ form_start(form, {'attr': {'action': path('quartier_update', {'id': quartier.id}) }}) }}
            {{ form_errors(form) }}

            <div class="row mb-4">
                <div class="col-4">
                    <div class="form-group">
                        {{ form_label(form.libelle, "Libelle", {'label_attr':{'class':'col-form-label'}})}}
                        {{ form_errors(form.libelle)  }}
                        <div>
                            {{ form_widget(form.libelle,{'label_attr':{'class':'foo'}}) }}
                        </div>
                    </div>
                </div>


                <div class="col-4">
                    <div class="form-group">
                        {{ form_label(form.commune, "Commune", {'label_attr':{'class':'col-form-label'}})}}
                        {{ form_errors(form.commune)  }}
                        <div>
                            {{ form_widget(form.commune,{'label_attr':{'class':'foo'}}) }}
                        </div>
                    </div>

                </div>
            </div>
         <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Modifier ','attr':{'value':'save'}}) }}</div>

                <div class="col-md-2" style="display: none"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

            </div> 
            <div>
                {{ form_rest(form) }}
            </div>
            {{ form_end(form) }}
        </div>
    </div>
