

<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Gestion quartier</h3>
    </div>
    <div class="card card-body">

        {{ form_start(form, {'attr': {'action': path('quartier_add')} }) }}

        {{ form_errors(form) }}

        <div class="row">
                
                    <div class="col-md-3">
                    {{ form_row(form.libelle, {'libelle':'Quartier ', 'attr':{'class':'form-control'}}) }}
                </div>
                
                    <div class="col-md-3">
                    {{ form_row(form.commune, {'label':'Commune '}) }}
                </div>
                
            
            </div>


       
        <div class="row"> 
            <div class="col-md-1.5">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

            <div class="col-md-2" style="display: none" > {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

        </div> 
   
        {{ form_end(form) }}
    </div>

</div>

