{% extends 'home/index.html.twig' %}

{% block title %}Gestion Quartier{% endblock %}

{% block body %}


    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Gestion quartier</h3>
        </div>
         <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
        <div class="card card-body">

            {{ form_start(form) }}


            <div class="row">

                <div class="col-md-3">
                    {{ form_row(form.libelle, {'libelle':'Quartier ', 'attr':{'class':'form-control'}}) }}
                </div>

                <div class="col-md-3">
                    {{ form_row(form.commune, {'label':'Commune '}) }}
                </div>


            </div>


            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>

                <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>

                <div class="col-md-2"><a href="{{ path('quartier') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 
          
            {{ form_end(form) }}
        </div>

    </div>


{% endblock %}