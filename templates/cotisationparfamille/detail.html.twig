{% extends 'home/index.html.twig' %}


{% block title %}
    Details {{ nomcotisationparfamille|upper }} {% endblock %}

    {% block body %}



        <div class="card card-primary">

            <div class="card-header">
                <h3 class="card-title">Fidèles ayant cotisé pour: {{ nomcotisationparfamille|upper }} </h3>
            </div>
            <h3><b> </b></h3>
            <div class="container-fluid">
                <div class="row">

                    <!-- /.card-header -->
                    <div class="card-body">

                        <a href='{{ path('app_cotisationparfamille_index') }}'>
                            <button class="btn btn-success">Liste des cotisations</button>
                        </a>
                        {% for cotiserparfamille in cotiserparfamilles %}
                            
                            {% set sum = cotiserparfamille.montantpayer + sum ?? 0 %}
                            {% if loop.last  %}  Total cotisé :<b> {{ sum|number_format(0, '.', ' ')}}F CFA -- {{ sum|format_number(style='spellout')}} F CFA</b>  {% endif %}
                               
                        {% endfor %}
                        <hr style="visibility: hidden" />
                        <table id="example1" class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Objet</th>
                                    <th>Tribu</th>
                                    <th>Montant </th>
                                    <th>Montant payé</th>
                                    <th>Reste</th>
                                  
                                </tr>
                            </thead>
                            <tbody>
                                {% for cotiserparfamille in cotiserparfamilles %}
                                        <tr>
                                            <td> {% if cotiserparfamille.cotisationparfamille is not null  %} {{ cotiserparfamille.cotisationparfamille.objet|upper }}{% else %} {% endif %}</td>
                                            <td>{% if cotiserparfamille.famille is not null  %}{{ cotiserparfamille.famille.nom|upper }}{% else %} {% endif %}</td>
                                            <td>{{ cotiserparfamille.cotisationparfamille.montant|number_format(0, '.', ' ') }}</td>
                                            <td>{{ cotiserparfamille.montantpayer|number_format(0, '.', ' ') }}</td>
                                            <td>  {% if  cotiserparfamille.reste == 0 %} <b>Soldé</b> 
                                            {% elseif cotiserparfamille.reste >0 %} {{ cotiserparfamille.reste|number_format(0, '.', ' ') }} {% elseif cotiserparfamille.reste < 0 %} 
                                                <i class="btn btn-success"> Soldé </i> {% endif %}

                                            </td>
                                   
                                    {% else %}
                                        <tr>
                                            <td colspan="4">Aucune donnée trouvée</td>
                                        </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>

                            </div>


                        </div>
                    </div>


                    {% endblock %}
