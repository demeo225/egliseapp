{% extends "home/index.html.twig" %}

{% block title %}Gestion offrande{% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Modification dîme de {{ dime.fidele.code|upper}} montant {{ dime.montant}}</h3>
        </div>
        <div class="card card-body">


            {{ form_start(form) }}
<div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

            <div class="row">
                <div class="col-md-4">
                    {{ form_row(form.datedime, {'label':'Date '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.fidele, {'label':'Choix du fidèle '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.typeoff, {'label':'Choix action '}) }}
                </div>
                <div class="col-md-4">
                    {{ form_row(form.ajout, {'label':'Montant '}) }}
                </div>

            </div>
            <div class="row"> 
                <div class="col-md-1">{{ form_row(form.save, {'label':'Modifier ','attr':{'value':'save'}}) }}</div>
                <div class="col-md-3"><a href="{{ path('dime') }}" class="btn btn-success">Afficher la liste</a> </div>
            </div> 

            {{ form_end(form) }}
        </div>


    </div>


{% endblock %}