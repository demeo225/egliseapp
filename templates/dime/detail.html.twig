{% extends "home/index.html.twig" %}

{% block title %}Dîmes de {{ dime.fidele.nomfidele|upper}}
{% endblock %}

{% block body %}

    <h3>
        <u>
            <strong>Details de la dîme de {{ dime.fidele.nomfidele|upper}}</strong>
        </u>
    </h3>
    <div class="card">
        <table class="table">

            <thead>
                <tr>
                    <th>Date</th>
                        {% if is_granted('ROLE_RESPONSABLE_FINANCE') %}
                        <th>Montant</th>

                    {% endif %}

                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>

                    <td>{{ dime.datedime|date('d-m-Y')}}</td>

                    <td>{{ dime.montant}}</td>

                    {% if is_granted('ROLE_RESPONSABLE_FINANCE') %}
                        <td>
                            <a href="{{ path('dime_update', {'id': dime.id}) }}">
                                <span style="font-size: 2em; color: Dodgerblue;">

                                    <i class="fas fa-edit"></i>

                                </span>
                            </a>


                        </td>
                    {% endif %}
                </tr>
            </tbody>
            </td>
            </tr></tbody>
            <tfooter>
                <tr>
                    <td>
                        <a href='{{ path('dime') }}'>
                            <button class="btn btn-primary">Liste dîmes</button>
                        </a>
                    </td>


                </tr>
            </tfooter>
           
        </table>
    </div>

{% endblock %}
