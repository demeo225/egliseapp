{% extends "home/index.html.twig" %}

{% block title %}Evangelisation index{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des évangelisations</h3>
        </div>
 <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
        {% if is_granted('ROLE_RESPONSABLE_EVANGELISATION') %}
            <div class="card-body">
                <a href="{{ path('app_evangelisation_new') }}">
                    <button class="btn btn-primary">Nouveau</button>
                </a>
                <a href="{{ path('app_ame_index') }}">
                    <button class="btn btn-success">Nouvelles âmes</button>
                </a>
            {% endif %}
            <hr style="visibility: hidden" />
            <table id="example1" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Lieu</th>
                        <th>Responsable</th>
                        <th>Nouvelles âmes</th>

                        <th>Detail</th>
                        <th>Modifier</th>
                    </tr>
                </thead>
                <tbody>
                    {% for evangelisation in evangelisations %}
                        <tr>
                            <td>{{ evangelisation.dateop ? evangelisation.dateop|date('d-m-Y') : '' }}</td>
                            <td>{{ evangelisation.lieu }}</td>
                            <td>{{ evangelisation.responsable1 }}</td>
                            <td>
                                <button type="button" id="btn-fideles-modal" class="btn btn-primary" data-target="{{ path('evangelisation_search_ames', {'id':evangelisation.id}) }}"> 
                                    <i class="fas fa-users" title="Details"></i>
                                </button> 
                            </td>

                            <td>
                                <button type="button" id="btn-evangile-modal" class="btn btn-primary" data-target="{{ path('app_evangelisation_show', {'id':evangelisation.id}) }}"> 
                                    <i class="fas fa-list" title="Details"></i>
                                </button> 

                            </td>
                            <td>

                                <button type="button" id="btn-evangile-modal" class="btn btn-primary" data-target="{{ path('app_evangelisation_edit', {'id':evangelisation.id}) }}"> 
                                    <i class="fas fa-edit" title="Modifier"></i>
                                </button> 
                            </td>
                        </tr>

                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade bd-example-modal-lg" id="fidelesModal" tabindex="-1" aria-labelledby="fidelesModalLabel" aria-hidden="true">

        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-body">

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade bd-example-modal-lg" id="evangileModal" tabindex="-1" aria-labelledby="evangileModalLabel" aria-hidden="true">

        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-body">

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            // quand on clic sur le button voir les fideles pour ouvrir la fenêtre modal
            $(document).on('click', 'button#btn-fideles-modal', function () {
                // créer le modal qui porte l'id fidelesModal
                let modal = new bootstrap.Modal(document.getElementById('fidelesModal'), {
                    keyboard: false
                });

                // recupere le div class="modal-body" du div id="fidelesModal"
                let container = $('#fidelesModal .modal-body');

                $.ajax({
                    type: 'POST',
                    url: $(this).attr('data-target'),
                    async: true,
                    beforeSend: function () { // avant d'envoyé le post on vide le div.modal-body
                        container.empty();
                    },
                    success: function (html) {
                        container.append(html); // une fois la réponse, on rempli le div.modal-body
                        modal.show(); // on affiche la fenêtre modal
                        //console.log(html);
                    }
                });
            });
        });
    </script>

    <script>
        $(document).ready(function () {
            // quand on clic sur le button voir les evangile pour ouvrir la fenêtre modal
            $(document).on('click', 'button#btn-evangile-modal', function () {
                // créer le modal qui porte l'id evangileModal
                let modal = new bootstrap.Modal(document.getElementById('evangileModal'), {
                    keyboard: false
                });

                // recupere le div class="modal-body" du div id="evangileModal"
                let container = $('#evangileModal .modal-body');

                $.ajax({
                    type: 'POST',
                    url: $(this).attr('data-target'),
                    async: true,
                    beforeSend: function () { // avant d'envoyé le post on vide le div.modal-body
                        container.empty();
                    },
                    success: function (html) {
                        container.append(html); // une fois la réponse, on rempli le div.modal-body
                        modal.show(); // on affiche la fenêtre modal
                        //console.log(html);
                    }
                });
            });
        });
    </script>
{% endblock %}
