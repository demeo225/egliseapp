{% extends "home/index.html.twig" %}

{% block title %}Liste des courriers{% endblock %}

{% block body %}


    <div class="card-body">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">Gestion des courriers</h3>
            </div>
    <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger', 'commune']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
            <div class="card-body">
                <a href="{{ path('app_courrier_new') }}" class="btn btn-primary">Nouveau</a>

                <hr style="visibility: hidden" />

                <table id="example1" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Date Expedition</th>
                            <th>Date recepetion</th>
                            <th>Type courrier</th>
                            <th>Expéditeur</th>
                            <th>Destinataire</th>
                            <th>Objet</th>
                            <th>Fichier</th>
                            <th>Detail</th>
                            <th>Modifier</th>
                            <th>Supprimer</th>


                        </tr>
                    </thead>
                    <tbody>
                        {% for courrier in courriers %}
                            <tr>
                                <td> {% if courrier.dateexpedition is not empty %}   {{ date_format(courrier.dateexpedition) }} {% else %}  {% endif %} </td>
                                <td> {% if courrier.daterecep is not empty %}   {{ date_format(courrier.daterecep) }} {% else %}  {% endif %} </td>
                                <td>{{ courrier.typecourrier }}</td>
                                <td>{{ courrier.expediteur}}</td>
                                <td>{{ courrier.destinataire}}</td>
                                <td>{{ courrier.objet }}</td>
                                <td>
                             {% if courrier.photo is not empty %}  <a href="{{ asset('uploads/brochures/' ~ courrier.photo) }}">Voir courrier</a>
                                {% else %} (Photo non importée) {% endif %} </td>
                           
                                <td>
                                    <button type="button" id="btn-fideles-modal" data-target="{{ path('app_courrier_show', {'id': courrier.id}) }}"> 
                                        <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-list" title="Details"></i>
                                        </span>
                                    </button>


                                </td>


                                <td>
                                    <a href="{{ path('app_courrier_edit', {'id': courrier.id}) }}">
                                        <span style="font-size: 1em; color: Dodgerblue;">
                                            <i class="fas fa-edit"></i>
                                        </span>
                                    </a>
                                </td>
                                <td>
                                    <form method="post" action="{{ path('app_courrier_delete', {'id': courrier.id}) }}" onsubmit="return confirm('etes vous sur de vouloir supprimer?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ courrier.id) }}">

                                        <button class="btn">
                                            <span style="font-size: 1em; color: red;">
                                                <i class="fas fa-trash-alt"></i>
                                            </span>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                      

                        {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>


    </div>





    <!-- Modal des  -->
    <div class="modal fade bd-example-modal-lg" id="fidelesModal" tabindex="-1" aria-labelledby="fidelesModalLabel" aria-hidden="true">

        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-body">

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" data-dismiss="modal">Fermer</button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}




{% block javascripts %}
    {{ parent() }}
    <script>
        $(document).ready(function () {
            // quand on clic sur le button voir les fideles pour ouvrir la fenêtre modal
            $(document).on('click', 'button#btn-fideles-modal', function () {
                // créer le modal qui porte l'id fidelesModal
                let modal = new bootstrap.Modal(document.getElementById('fidelesModal'), {
                    keyboard: false
                });

                // recupere le div class="modal-body" du div id="fidelesModal"
                let container = $('#fidelesModal .modal-body');

                $.ajax({
                    type: 'POST',
                    url: $(this).attr('data-target'),
                    async: true,
                    beforeSend: function () { // avant d'envoyé le post on vide le div.modal-body
                        container.empty();
                    },
                    success: function (html) {
                        container.append(html); // une fois la réponse, on rempli le div.modal-body
                        modal.show(); // on affiche la fenêtre modal
                        //console.log(html);
                    }
                });
            });
        });
    </script>



{% endblock %}