{% extends 'base.html.twig' %}

{% block title %}Typeculte{% endblock %}

{% block body %}
    <h1>Typeculte</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ typeculte.id }}</td>
            </tr>
            <tr>
                <th>Libelle</th>
                <td>{{ typeculte.libelle }}</td>
            </tr>
            <tr>
                <th>Heuredebut</th>
                <td>{{ typeculte.heuredebut ? typeculte.heuredebut|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Heurefin</th>
                <td>{{ typeculte.heurefin ? typeculte.heurefin|date('H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Ideglise</th>
                <td>{{ typeculte.ideglise }}</td>
            </tr>
            <tr>
                <th>CreatedFromIp</th>
                <td>{{ typeculte.createdFromIp }}</td>
            </tr>
            <tr>
                <th>UpdatedFromIp</th>
                <td>{{ typeculte.updatedFromIp }}</td>
            </tr>
            <tr>
                <th>DeletedAt</th>
                <td>{{ typeculte.deletedAt ? typeculte.deletedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>DeletedFromIp</th>
                <td>{{ typeculte.deletedFromIp }}</td>
            </tr>
            <tr>
                <th>Editable</th>
                <td>{{ typeculte.editable ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_typeculte_index') }}">back to list</a>

    <a href="{{ path('app_typeculte_edit', {'id': typeculte.id}) }}">edit</a>

    {{ include('typeculte/_delete_form.html.twig') }}
{% endblock %}
