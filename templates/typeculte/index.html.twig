{% extends "home/index.html.twig" %}

{% block title %}Liste Types cultes{% endblock %}

{% block body %}



    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Liste des différents types de culte</h3>
        </div>
  <div class="offset-1 col-md-10 mt-2 mb-2">
        {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} my-alert" role="alert">
                    <h1 class="m-0 flash-text">{{ message }}</h1>
                </div>
            {% endfor %}
        {% endfor %}
    </div>
          
        <!-- /.card-header -->
        <div class="car card-body">
            <a href='{{ path('app_typeculte_new') }}'>
                <button class="btn btn-primary">Nouveau</button>
            </a>


            <hr style="visibility: hidden" />  
            <table id="example1" class="table table-bordered table-striped">

                <thead>
                    <tr>
                        <th>Type culte</th>
                        <th>Heure debut</th>
                        <th>Heure fin</th>
                 
                        <th>Modifier</th>
                        <th>Supprimer</th>


                    </tr>
                </thead>
                <tbody>
                    {% for typeculte in typecultes %}
                        <tr>
                            <td>{{ typeculte.libelle }}</td>
                            <td>{{ typeculte.heuredebut|date('H:i:s')  }}</td>
                            <td>{{ typeculte.heurefin|date('H:i:s') }}</td>
                     



                            <td>
                                <a href="{{ path('app_typeculte_edit', {'id': typeculte.id}) }}">
                                    <span style="font-size: 1em; color: Dodgerblue;">
                                        <i class="fas fa-edit"></i>
                                    </span>
                                </a>
                            </td>
                            <td>
                                <form method="post" action="{{ path('app_typeculte_delete', {'id': typeculte.id}) }}" onsubmit="return confirm('Voulez-vous supprimer?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ typeculte.id) }}">
                                    <button class="btn">
                                        <span style="font-size: 1em; color: red;">
                                            <i class="fas fa-trash-alt"></i>
                                        </span>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                   
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>




{% endblock %}


