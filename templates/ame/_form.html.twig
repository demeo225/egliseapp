
<div class="card card-primary">

    <div class="card card-body">
        {{ form_start(form) }}
                 <div class="offset-1 col-md-10 mt-2 mb-2">
                {% for label, messages in app.flashes(['success', 'warning', 'danger']) %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label }} my-alert" role="alert">
                            <h5 class="m-0 flash-text">{{ message }}</h5>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.evangelisation, {'label':'Date '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.nom, {'label':'Nom & pénoms  '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.contact, {'label':'Contact '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.sexe, {'label':'Sexe '}) }}
            </div>
        </div>
        <div class="row">

            <div class="col-md-3">
                {{ form_row(form.habitation, {'label':'Lieu d\'habitation '}) }}
            </div>

            <div class="col-md-3">
                {{ form_row(form.rdv, {'label':'Rendez-vous confirmé? '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.converti, {'label':'Conversion ? '}) }}
            </div>
            <div class="col-md-3">
                {{ form_row(form.invitation, {'label':'Présence au culte ? '}) }}
            </div>

        </div>

        <div class="row"> 
            <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>
            <div class="col-md-2.5"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>
            <div class="col-md-3"><a href="{{ path('app_ame_index') }}" class="btn btn-success">Afficher la liste</a> </div>
        </div> 
        {{ form_end(form) }}

    </div>
</div>