{% extends "home/index.html.twig" %}

{% block title %}Detailcotisationcellule index{% endblock %}

{% block body %}
    <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Details paiment</h3>
        </div>

        <!-- /.card-header -->
        <div class="card-body">



            <a href='{{ path('cotisercellule_index') }}'>
                <button class="btn btn-success">Paiements cotisation</button>
            </a>

            <a href='{{ path('cotisationcellule_index') }}'>
                <button class="btn btn-success">Liste des cotisations</button>
            </a>

            <hr style="visibility: hidden" />  


            <table id="example1" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Cellule</th>
                        <th>Fidèle</th>
                        <th>Contact</th>
                        <th>Objet</th>
                        <th>Montant à payer</th>
                        <th>Mont payé</th>
                        <th>Reste </th>

                        <th>actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for detailcotisationcellule in detailcotisationcellules %}
                        {% if is_granted("cotisercellule_detailcellule", detailcotisationcellule) %}
                            <tr>
                                <td>{{ detailcotisationcellule.datedetail ? detailcotisationcellule.datedetail|date('d-m-Y') : '' }}</td>
                                <td>{% if detailcotisationcellule.fidele.cellule is not empty %} {{ detailcotisationcellule.fidele.cellule.nom }} {% else %} {% endif %}</td>
                                <td>{{ detailcotisationcellule.fidele.nomfidele }}</td>
                                <td> {% if detailcotisationcellule.fidele.contactwhatssap is not empty %} {{ detailcotisationcellule.fidele.contactwhatssap}} {% else %} {{ detailcotisationcellule.fidele.contact1}} {% endif %}</td>
                                <td>{{ detailcotisationcellule.cotisationcellule.objet }}</td>
                                <td>{{ detailcotisationcellule.cotisationcellule.montant|number_format(0, '.', ' ') }}</td>
                                <td>{{ detailcotisationcellule.montantpayer|number_format(0, '.', ' ') }}</td>
                                <td>

                                    {% if  detailcotisationcellule.reste > 0 %}
                                        <b>{{ detailcotisationcellule.reste|number_format(0, '.', ' ') }}</b>


                                    {% else %}
                                        <i class="btn btn-success">    Soldée</i> 
                                    {% endif %}


                                </td>
                                <td>
                                    <a href="{{ path('app_detailcotisationcellule_edit', {'id': detailcotisationcellule.id}) }}">edit</a>
                                </td>
                            </tr>
                        {% endif %}
                 
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

{% endblock %}
