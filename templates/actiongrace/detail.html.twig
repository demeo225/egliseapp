{% extends "home/index.html.twig" %}

{% block title %}Actions de grâce de {{ actiongrace.fidele.nomfidele|upper}}
{% endblock %}

{% block body %}

    <h3>
        <u>
            <strong>Actions de grâces {{ actiongrace.fidele.nomfidele|upper}}</strong>
        </u>
    </h3>
    <div class="card">
        <table class="table">

            <thead>
                <tr>
                    <th>Date</th>
                    <th>Montant</th>



                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>

                    <td>{{ actiongrace.dateactiongrace|date('d-m-Y')}}</td>

                    <td>{{ actiongrace.montant|number_format(0, '.', ' ')}}</td>


                    <td>
                        <a href="{{ path('actiongrace_update', {'id': actiongrace.id}) }}">
                            <span style="font-size: 2em; color: Dodgerblue;">

                                <i class="fas fa-edit"></i>

                            </span>
                        </a>
                        {% if is_granted('ROLE_RESPONSABLE_FINANCE') %}

                            <form method="post" action="{{ path('actiongrace_delete', {'id': actiongrace.id}) }}" onsubmit="return confirm('Voulez-vous supprimer cet enregistrement?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ actiongrace.id) }}">

                                <button class="btn">
                                    <span style="font-size: 1em; color: red;">
                                        <i class="fas fa-trash-alt"></i>
                                    </span>
                                </button>
                            </form>
                        {% endif %}
                    </td>
                </tr>


            </tbody><tfooter>
                <tr>
                    <td>
                        <a href='{{ path('actiongrace') }}'>
                            <button class="btn btn-primary">Retour à la liste</button>
                        </a>
                    </td>


                </tr>
            </tfooter>
        </table>
    </i></div>{% endblock %}
